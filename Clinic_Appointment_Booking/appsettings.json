{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "ClinicAppointmentBooking-SuperSecretKey-MinimumLength32Characters!@#",
    "Issuer": "ClinicAppointmentBookingAPI",
    "Audience": "ClinicAppointmentBookingClient",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderEmail": "your-email@gmail.com",
    "SenderName": "Clinic Appointment Booking",
    "Username": "your-email@gmail.com",
    "Password": "your-app-password-here",
    "EnableSsl": true
  },
  "AppSettings": {
    "ClientUrl": "https://localhost:7001",
    "EmailVerificationUrl": "https://localhost:7001/Account/VerifyEmail",
    "PasswordResetUrl": "https://localhost:7001/Account/ResetPassword"
  }
}
