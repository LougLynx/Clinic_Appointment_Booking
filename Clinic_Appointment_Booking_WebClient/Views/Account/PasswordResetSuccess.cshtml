@{
    ViewData["Title"] = "Password Reset Successful";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediClinic</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: { "primary": "#13b6ec" },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                },
            },
        }
    </script>
</head>
<body class="bg-slate-50 dark:bg-slate-900 font-display min-h-screen flex items-center justify-center p-6">
    <div class="w-full max-w-lg">
        <div class="bg-white dark:bg-slate-800 rounded-xl shadow-lg p-8 text-center">
            <!-- Success Icon -->
            <div class="flex justify-center mb-6">
                <div class="w-20 h-20 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
                    <span class="material-symbols-outlined text-green-600 dark:text-green-400 text-5xl">check_circle</span>
                </div>
            </div>

            <!-- Title -->
            <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-3">Password Reset Successful!</h1>
            
            <!-- Message -->
            <p class="text-slate-600 dark:text-slate-400 mb-8 leading-relaxed">
                Your password has been successfully reset. You can now log in with your new password.
            </p>

            <!-- Actions -->
            <div class="flex flex-col gap-3">
                <a asp-action="Login" 
                   class="flex items-center justify-center rounded-lg h-12 bg-primary hover:bg-primary/90 text-white font-bold transition-colors shadow-md">
                    <span class="material-symbols-outlined mr-2">login</span>
                    Log In Now
                </a>
                <a asp-controller="Home" asp-action="Index" 
                   class="text-sm text-slate-600 dark:text-slate-400 hover:text-primary">
                    Back to Home
                </a>
            </div>
        </div>
    </div>
</body>
</html>
