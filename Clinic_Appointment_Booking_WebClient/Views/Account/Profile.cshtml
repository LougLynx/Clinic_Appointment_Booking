@model Clinic_Appointment_Booking_WebClient.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "_LayoutMediClinic";
}

<div class="mb-8 px-4">
    <h1 class="text-3xl md:text-4xl font-black leading-tight tracking-tight mb-2 text-slate-900 dark:text-white">My Profile</h1>
    <p class="text-slate-500 dark:text-slate-400">Manage your account information</p>
</div>

<div class="max-w-2xl px-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 p-4 rounded-xl bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800">
            <p class="text-green-800 dark:text-green-200 text-sm">@TempData["SuccessMessage"]</p>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-6 p-4 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800">
            <p class="text-red-800 dark:text-red-200 text-sm">@TempData["ErrorMessage"]</p>
        </div>
    }

    <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-700 shadow-sm">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">person</span>
            Personal Information
        </h2>

        <form asp-action="Profile" method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm bg-red-50 dark:bg-red-900/20 p-3 rounded-lg"></div>

            <div>
                <label asp-for="FullName" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Full Name</label>
                <input asp-for="FullName" 
                       class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-primary focus:border-primary shadow-sm" 
                       placeholder="Your full name" />
                <span asp-validation-for="FullName" class="text-red-600 text-sm"></span>
            </div>

            <div>
                <label asp-for="Email" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Email</label>
                <input asp-for="Email" 
                       class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 cursor-not-allowed" 
                       readonly tabindex="-1" />
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Email cannot be changed</p>
            </div>

            <div>
                <label asp-for="PhoneNumber" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Phone Number</label>
                <input asp-for="PhoneNumber" 
                       class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-primary focus:border-primary shadow-sm" 
                       placeholder="Your phone number" />
                <span asp-validation-for="PhoneNumber" class="text-red-600 text-sm"></span>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Role</label>
                <div class="px-4 py-3 rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700">
                    <span class="inline-block px-2 py-1 text-sm font-semibold rounded-full @(Model.Role == "Admin" ? "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400" : Model.Role == "Doctor" ? "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400" : "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400")">
                        @Model.Role
                    </span>
                </div>
            </div>

            <div class="flex flex-wrap gap-4 pt-4">
                <button type="submit" class="px-6 py-3 rounded-lg bg-primary text-white font-bold hover:bg-primary/90 transition-colors shadow-md">
                    Save Changes
                </button>
                <a asp-controller="Home" asp-action="Index" class="px-6 py-3 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 font-semibold hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors no-underline">
                    Cancel
                </a>
                <a asp-controller="Account" asp-action="Settings" class="px-6 py-3 rounded-lg border border-primary/50 text-primary font-semibold hover:bg-primary/10 transition-colors no-underline flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">lock</span>
                    Change Password
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
