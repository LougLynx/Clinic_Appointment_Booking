@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediClinic</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <!-- Inter Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    
    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#0d9488",
                        "primary-hover": "#0f766e",
                        "accent-blue": "#3b82f6",
                        "background-light": "#f0fdfa",
                        "surface-light": "#ffffff",
                    },
                    fontFamily: {
                        "display": ["Inter", "Noto Sans", "sans-serif"]
                    },
                },
            },
        }
    </script>
</head>
<body class="bg-background-light text-slate-800 font-display flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-64 bg-slate-900 text-slate-300 flex flex-col transition-all duration-300 flex-shrink-0 border-r border-slate-800">
        <!-- Logo -->
        <div class="h-16 flex items-center px-6 border-b border-slate-800 bg-slate-950/50">
            <span class="material-symbols-outlined text-primary text-3xl mr-3">admin_panel_settings</span>
            <h1 class="text-white font-bold text-lg tracking-wide">MediAdmin</h1>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 overflow-y-auto py-6 flex flex-col gap-2 px-3">
            <a asp-area="" asp-controller="Admin" asp-action="Dashboard" 
               class="flex items-center gap-3 px-4 py-3 bg-primary/20 text-white rounded-lg transition-colors border-l-4 border-primary no-underline">
                <span class="material-symbols-outlined text-[20px]">dashboard</span>
                <span class="font-medium">Dashboard</span>
            </a>
            <a asp-area="" asp-controller="Admin" asp-action="DoctorManagement" 
               class="flex items-center gap-3 px-4 py-3 hover:bg-slate-800 rounded-lg transition-colors text-slate-400 hover:text-white border-l-4 border-transparent no-underline">
                <span class="material-symbols-outlined text-[20px]">stethoscope</span>
                <span class="font-medium">Doctor Management</span>
            </a>
            <a asp-area="" asp-controller="Admin" asp-action="PatientRecords" 
               class="flex items-center gap-3 px-4 py-3 hover:bg-slate-800 rounded-lg transition-colors text-slate-400 hover:text-white border-l-4 border-transparent no-underline">
                <span class="material-symbols-outlined text-[20px]">folder_shared</span>
                <span class="font-medium">Patient Records</span>
            </a>
            <a asp-area="" asp-controller="Admin" asp-action="Financials" 
               class="flex items-center gap-3 px-4 py-3 hover:bg-slate-800 rounded-lg transition-colors text-slate-400 hover:text-white border-l-4 border-transparent no-underline">
                <span class="material-symbols-outlined text-[20px]">account_balance_wallet</span>
                <span class="font-medium">Financials</span>
            </a>
            <a asp-area="" asp-controller="Admin" asp-action="Settings" 
               class="flex items-center gap-3 px-4 py-3 hover:bg-slate-800 rounded-lg transition-colors text-slate-400 hover:text-white border-l-4 border-transparent no-underline">
                <span class="material-symbols-outlined text-[20px]">settings</span>
                <span class="font-medium">System Settings</span>
            </a>
        </nav>

        <!-- User Profile -->
        <div class="p-4 border-t border-slate-800">
            <div class="flex items-center gap-3 px-2 mb-3">
                <div class="w-10 h-10 rounded-full bg-slate-700 flex items-center justify-center text-white font-bold">
                    SA
                </div>
                <div>
                    <p class="text-white text-sm font-medium">System Admin</p>
                    <p class="text-xs text-slate-500">admin@mediclinic.com</p>
                </div>
            </div>
            <!-- Back to Home Button -->
            <a asp-area="" asp-controller="Home" asp-action="Index" 
               class="flex items-center gap-2 px-4 py-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-colors text-sm no-underline">
                <span class="material-symbols-outlined text-[18px]">home</span>
                <span>Back to Home</span>
            </a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <div class="flex-1 flex flex-col overflow-hidden">
        <!-- Top Header -->
        <header class="h-16 bg-surface-light border-b border-slate-200 flex items-center justify-between px-8 shadow-sm flex-shrink-0 z-10">
            <!-- Search Bar -->
            <div class="flex items-center bg-slate-100 rounded-lg px-3 py-2 w-96 border border-slate-200 focus-within:border-primary focus-within:ring-1 focus-within:ring-primary transition-all">
                <span class="material-symbols-outlined text-slate-400 mr-2">search</span>
                <input class="bg-transparent border-none outline-none text-sm w-full text-slate-700 placeholder-slate-400 focus:ring-0 p-0" 
                       placeholder="Search records, doctors..." 
                       type="text" />
            </div>

            <!-- Header Actions -->
            <div class="flex items-center gap-5">
                <button class="relative text-slate-500 hover:text-primary transition-colors">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full border border-white"></span>
                </button>
                <div class="h-8 w-px bg-slate-200"></div>
                <button class="flex items-center gap-2 text-slate-600 hover:text-slate-900 font-medium text-sm">
                    <span>Export Report</span>
                    <span class="material-symbols-outlined text-[18px]">download</span>
                </button>
            </div>
        </header>

        <!-- Main Dashboard Content -->
        <main class="flex-1 overflow-y-auto p-8 bg-slate-50/50">
            <!-- Page Header -->
            <div class="flex justify-between items-end mb-8">
                <div>
                    <h2 class="text-2xl font-bold text-slate-900">Clinic Overview</h2>
                    <p class="text-slate-500 text-sm mt-1">Monitor daily operations and financial performance.</p>
                </div>
                <div class="flex gap-2">
                    <select id="period-filter" class="text-sm border-slate-200 rounded-lg text-slate-600 focus:ring-primary focus:border-primary bg-white shadow-sm">
                        <option>Last 7 Days</option>
                        <option>This Month</option>
                        <option>This Year</option>
                    </select>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
                <!-- Monthly Revenue -->
                <div class="bg-surface-light p-6 rounded-xl border border-slate-200 shadow-sm flex flex-col justify-between">
                    <div class="flex justify-between items-start mb-4">
                        <div class="w-10 h-10 rounded-lg bg-teal-100 flex items-center justify-center text-teal-600">
                            <span class="material-symbols-outlined">payments</span>
                        </div>
                        <span class="flex items-center text-xs font-medium text-emerald-600 bg-emerald-50 px-2 py-1 rounded-full">
                            <span class="material-symbols-outlined text-[14px] mr-1">trending_up</span> 12.5%
                        </span>
                    </div>
                    <div>
                        <p class="text-slate-500 text-sm font-medium mb-1">Monthly Revenue</p>
                        <h3 class="text-2xl font-bold text-slate-900">$124,500</h3>
                    </div>
                </div>

                <!-- Total Appointments -->
                <div class="bg-surface-light p-6 rounded-xl border border-slate-200 shadow-sm flex flex-col justify-between">
                    <div class="flex justify-between items-start mb-4">
                        <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center text-blue-600">
                            <span class="material-symbols-outlined">event_available</span>
                        </div>
                        <span class="flex items-center text-xs font-medium text-emerald-600 bg-emerald-50 px-2 py-1 rounded-full">
                            <span class="material-symbols-outlined text-[14px] mr-1">trending_up</span> 8.2%
                        </span>
                    </div>
                    <div>
                        <p class="text-slate-500 text-sm font-medium mb-1">Total Appointments</p>
                        <h3 class="text-2xl font-bold text-slate-900">1,284</h3>
                    </div>
                </div>

                <!-- New Patients -->
                <div class="bg-surface-light p-6 rounded-xl border border-slate-200 shadow-sm flex flex-col justify-between">
                    <div class="flex justify-between items-start mb-4">
                        <div class="w-10 h-10 rounded-lg bg-indigo-100 flex items-center justify-center text-indigo-600">
                            <span class="material-symbols-outlined">person_add</span>
                        </div>
                        <span class="flex items-center text-xs font-medium text-rose-600 bg-rose-50 px-2 py-1 rounded-full">
                            <span class="material-symbols-outlined text-[14px] mr-1">trending_down</span> 2.1%
                        </span>
                    </div>
                    <div>
                        <p class="text-slate-500 text-sm font-medium mb-1">New Patients</p>
                        <h3 class="text-2xl font-bold text-slate-900">342</h3>
                    </div>
                </div>

                <!-- Active Doctors -->
                <div class="bg-surface-light p-6 rounded-xl border border-slate-200 shadow-sm flex flex-col justify-between">
                    <div class="flex justify-between items-start mb-4">
                        <div class="w-10 h-10 rounded-lg bg-amber-100 flex items-center justify-center text-amber-600">
                            <span class="material-symbols-outlined">stethoscope</span>
                        </div>
                        <span class="flex items-center text-xs font-medium text-slate-500 bg-slate-100 px-2 py-1 rounded-full">
                            <span class="material-symbols-outlined text-[14px] mr-1">horizontal_rule</span> 0%
                        </span>
                    </div>
                    <div>
                        <p class="text-slate-500 text-sm font-medium mb-1">New Active Doctors</p>
                        <h3 class="text-2xl font-bold text-slate-900">45</h3>
                    </div>
                </div>
            </div>

            <!-- Charts Row -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
                <!-- Revenue & Appointment Trends Chart -->
                <div class="col-span-2 bg-surface-light p-6 rounded-xl border border-slate-200 shadow-sm">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="text-lg font-bold text-slate-800">Revenue &amp; Appointment Trends</h3>
                        <button class="text-slate-400 hover:text-primary">
                            <span class="material-symbols-outlined">more_horiz</span>
                        </button>
                    </div>
                    <div class="h-64 flex items-end justify-between gap-2 px-2 relative">
                        <!-- Grid Lines -->
                        <div class="absolute w-full border-b border-dashed border-slate-200 bottom-[25%]"></div>
                        <div class="absolute w-full border-b border-dashed border-slate-200 bottom-[50%]"></div>
                        <div class="absolute w-full border-b border-dashed border-slate-200 bottom-[75%]"></div>
                        
                        <!-- Bar Chart -->
                        <div id="chart-container" class="w-full flex justify-between items-end h-full z-10 pt-4">
                            <div class="w-[8%] bg-primary/20 rounded-t-sm h-[40%] relative hover:bg-primary/40 transition-colors">
                                <div class="absolute bottom-0 w-full bg-primary rounded-t-sm h-[60%]"></div>
                            </div>
                            <div class="w-[8%] bg-primary/20 rounded-t-sm h-[55%] relative hover:bg-primary/40 transition-colors">
                                <div class="absolute bottom-0 w-full bg-primary rounded-t-sm h-[70%]"></div>
                            </div>
                            <div class="w-[8%] bg-primary/20 rounded-t-sm h-[45%] relative hover:bg-primary/40 transition-colors">
                                <div class="absolute bottom-0 w-full bg-primary rounded-t-sm h-[65%]"></div>
                            </div>
                            <div class="w-[8%] bg-primary/20 rounded-t-sm h-[70%] relative hover:bg-primary/40 transition-colors">
                                <div class="absolute bottom-0 w-full bg-accent-blue rounded-t-sm h-[80%]"></div>
                            </div>
                            <div class="w-[8%] bg-primary/20 rounded-t-sm h-[60%] relative hover:bg-primary/40 transition-colors">
                                <div class="absolute bottom-0 w-full bg-primary rounded-t-sm h-[50%]"></div>
                            </div>
                            <div class="w-[8%] bg-primary/20 rounded-t-sm h-[85%] relative hover:bg-primary/40 transition-colors">
                                <div class="absolute bottom-0 w-full bg-accent-blue rounded-t-sm h-[90%]"></div>
                            </div>
                            <div class="w-[8%] bg-primary/20 rounded-t-sm h-[75%] relative hover:bg-primary/40 transition-colors">
                                <div class="absolute bottom-0 w-full bg-primary rounded-t-sm h-[85%]"></div>
                            </div>
                        </div>
                    </div>
                    <div class="flex justify-between text-xs text-slate-400 mt-3 px-2">
                        <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
                    </div>
                </div>

                <!-- Department Performance -->
                <div class="bg-surface-light p-6 rounded-xl border border-slate-200 shadow-sm flex flex-col">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="text-lg font-bold text-slate-800">Department Performance</h3>
                        <button class="text-slate-400 hover:text-primary">
                            <span class="material-symbols-outlined">more_horiz</span>
                        </button>
                    </div>
                    <div class="flex-1 flex flex-col justify-center gap-6" id="department-list">
                        <!-- Cardiology -->
                        <div>
                            <div class="flex justify-between text-sm mb-1">
                                <span class="font-medium text-slate-700">Cardiology</span>
                                <span class="text-slate-500">35%</span>
                            </div>
                            <div class="w-full bg-slate-100 rounded-full h-2">
                                <div id="dept-cardiology" class="bg-teal-500 h-2 rounded-full" style="width: 35%"></div>
                            </div>
                        </div>
                        <!-- Pediatrics -->
                        <div>
                            <div class="flex justify-between text-sm mb-1">
                                <span class="font-medium text-slate-700">Pediatrics</span>
                                <span class="text-slate-500">28%</span>
                            </div>
                            <div class="w-full bg-slate-100 rounded-full h-2">
                                <div id="dept-Pediatrics" class="bg-blue-500 h-2 rounded-full" style="width: 28%"></div>
                            </div>
                        </div>
                        <!-- Orthopedics -->
                        <div>
                            <div class="flex justify-between text-sm mb-1">
                                <span class="font-medium text-slate-700">Orthopedics</span>
                                <span class="text-slate-500">22%</span>
                            </div>
                            <div class="w-full bg-slate-100 rounded-full h-2">
                                <div id="dept-Orthopedics" class="bg-indigo-500 h-2 rounded-full" style="width: 22%"></div>
                            </div>
                        </div>
                        <!-- Neurology -->
                        <div>
                            <div class="flex justify-between text-sm mb-1">
                                <span class="font-medium text-slate-700">Neurology</span>
                                <span class="text-slate-500">15%</span>
                            </div>
                            <div class="w-full bg-slate-100 rounded-full h-2">
                                <div id="dept-cardiology" class="bg-amber-500 h-2 rounded-full" style="width: 15%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bottom Row -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Staff Overview Table -->
                <div class="col-span-2 bg-surface-light rounded-xl border border-slate-200 shadow-sm overflow-hidden flex flex-col">
                    <div class="p-6 border-b border-slate-100 flex justify-between items-center">
                        <h3 class="text-lg font-bold text-slate-800">Staff Overview</h3>
                        <a class="text-sm font-medium text-primary hover:text-primary-hover no-underline" href="#">View All</a>
                    </div>
                    <div class="overflow-x-auto flex-1">
                        <table class="w-full text-left text-sm text-slate-600">
                            <thead class="bg-slate-50 text-slate-500 uppercase text-xs font-semibold">
                                <tr>
                                    <th class="px-6 py-4">Doctor Name</th>
                                    <th class="px-6 py-4">Department</th>
                                    <th class="px-6 py-4">Today's Appts</th>
                                    <th class="px-6 py-4">Status</th>
                                </tr>
                            </thead>
                            <tbody id="staff-table-body" class="divide-y divide-slate-100">
                                <!-- Doctor 1 -->
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-4 flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-teal-100 text-teal-700 flex items-center justify-center font-bold text-xs">AS</div>
                                        <span class="font-medium text-slate-800">Dr. Alice Smith</span>
                                    </td>
                                    <td class="px-6 py-4">Cardiology</td>
                                    <td class="px-6 py-4 font-medium">8</td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700">
                                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Active
                                        </span>
                                    </td>
                                </tr>
                                <!-- Doctor 2 -->
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-4 flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-700 flex items-center justify-center font-bold text-xs">RJ</div>
                                        <span class="font-medium text-slate-800">Dr. Robert Jones</span>
                                    </td>
                                    <td class="px-6 py-4">Pediatrics</td>
                                    <td class="px-6 py-4 font-medium">12</td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700">
                                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Active
                                        </span>
                                    </td>
                                </tr>
                                <!-- Doctor 3 -->
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-4 flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-slate-100 text-slate-700 flex items-center justify-center font-bold text-xs">ML</div>
                                        <span class="font-medium text-slate-800">Dr. Maria Garcia</span>
                                    </td>
                                    <td class="px-6 py-4">Neurology</td>
                                    <td class="px-6 py-4 font-medium">0</td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700">
                                            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> Away
                                        </span>
                                    </td>
                                </tr>
                                <!-- Doctor 4 -->
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-4 flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center font-bold text-xs">DW</div>
                                        <span class="font-medium text-slate-800">Dr. David Wong</span>
                                    </td>
                                    <td class="px-6 py-4">Orthopedics</td>
                                    <td class="px-6 py-4 font-medium">5</td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700">
                                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Active
                                        </span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Recent Activity -->
                <div class="bg-surface-light p-6 rounded-xl border border-slate-200 shadow-sm">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="text-lg font-bold text-slate-800">Recent Activity</h3>
                    </div>
                    <div class="relative border-l border-slate-200 ml-3 space-y-6">
                        <!-- Activity 1 -->
                        <div class="relative pl-6">
                            <div class="absolute -left-1.5 top-1.5 w-3 h-3 rounded-full bg-blue-500 border-2 border-white"></div>
                            <div>
                                <p class="text-sm font-medium text-slate-800">New Registration</p>
                                <p class="text-xs text-slate-500 mt-0.5">Patient <span class="font-medium text-slate-700">Sarah Connor</span> created an account.</p>
                                <p class="text-xs text-slate-400 mt-1">10 mins ago</p>
                            </div>
                        </div>
                        <!-- Activity 2 -->
                        <div class="relative pl-6">
                            <div class="absolute -left-1.5 top-1.5 w-3 h-3 rounded-full bg-teal-500 border-2 border-white"></div>
                            <div>
                                <p class="text-sm font-medium text-slate-800">Appointment Confirmed</p>
                                <p class="text-xs text-slate-500 mt-0.5">Dr. Smith with John Doe at 14:00.</p>
                                <p class="text-xs text-slate-400 mt-1">25 mins ago</p>
                            </div>
                        </div>
                        <!-- Activity 3 -->
                        <div class="relative pl-6">
                            <div class="absolute -left-1.5 top-1.5 w-3 h-3 rounded-full bg-amber-500 border-2 border-white"></div>
                            <div>
                                <p class="text-sm font-medium text-slate-800">Schedule Updated</p>
                                <p class="text-xs text-slate-500 mt-0.5">Dr. Maria Garcia marked as 'Away'.</p>
                                <p class="text-xs text-slate-400 mt-1">1 hour ago</p>
                            </div>
                        </div>
                        <!-- Activity 4 -->
                        <div class="relative pl-6">
                            <div class="absolute -left-1.5 top-1.5 w-3 h-3 rounded-full bg-teal-500 border-2 border-white"></div>
                            <div>
                                <p class="text-sm font-medium text-slate-800">Appointment Confirmed</p>
                                <p class="text-xs text-slate-500 mt-0.5">Dr. Jones with Emily Chen at 11:30.</p>
                                <p class="text-xs text-slate-400 mt-1">2 hours ago</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>

<script>
    const API_BASE = "@ViewData["ApiBaseUrl"]";
    const BASE_URL = `${API_BASE}/api/Admin`;;

    // Hàm định dạng tiền tệ
    const formatCurrency = (amount) => {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(amount);
    };

    // 1. Load Stats Cards
    async function loadStats() {
        try {
            const response = await fetch(`${BASE_URL}/stats`);
            const data = await response.json();

            // Cập nhật lên giao diện (Sử dụng ID hoặc thứ tự các thẻ)
            document.querySelectorAll('h3.text-2xl.font-bold')[0].innerText = formatCurrency(data.monthlyRevenue);
            document.querySelectorAll('h3.text-2xl.font-bold')[1].innerText = data.totalAppointments.toLocaleString();
            document.querySelectorAll('h3.text-2xl.font-bold')[2].innerText = data.newPatients.toLocaleString();
            document.querySelectorAll('h3.text-2xl.font-bold')[3].innerText = data.activeDoctors.toLocaleString();
        } catch (error) {
            console.error("Error loading stats:", error);
        }
    }
    // 1. Cập nhật Staff Table
    async function loadStaff() {
        try {
            const response = await fetch(`${BASE_URL}/staff-overview`);
            const staff = await response.json();
            const tbody = document.getElementById('staff-table-body'); // Đảm bảo đã thêm id này vào HTML

            if (!staff || staff.length === 0) {
                tbody.innerHTML = `<tr><td colspan="4" class="px-6 py-10 text-center text-slate-400">No doctors found</td></tr>`;
                return;
            }

            tbody.innerHTML = '';
            staff.forEach(doc => {
                const initials = doc.fullName.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);
                const statusColor = doc.status === 'Active' ? 'emerald' : 'amber';
                tbody.innerHTML += `
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4 flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-teal-100 text-teal-700 flex items-center justify-center font-bold text-xs">${initials}</div>
                            <span class="font-medium text-slate-800">${doc.fullName}</span>
                        </td>
                        <td class="px-6 py-4">${doc.specialty}</td>
                        <td class="px-6 py-4 font-medium">${doc.todayAppointments}</td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-xs font-medium bg-${statusColor}-50 text-${statusColor}-700">
                                <span class="w-1.5 h-1.5 rounded-full bg-${statusColor}-500"></span> ${doc.status}
                            </span>
                        </td>
                    </tr>`;
            });
        } catch (error) { console.error(error); }
    }

    // 2. Cập nhật Biểu đồ cột
    async function loadTrends(period = "last 7 days") {
        try {
            const response = await fetch(`${BASE_URL}/trends?period=${period}`);
            const trends = await response.json();
            const chartContainer = document.getElementById('chart-container');

            if (!trends || trends.length === 0) {
                chartContainer.innerHTML = `<div class="w-full h-full flex items-center justify-center text-slate-400 text-sm">No data for this period</div>`;
                return;
            }

            chartContainer.innerHTML = '';
            const maxVal = Math.max(...trends.map(t => t.appointments), 1);

            trends.forEach((t, index) => {
                const heightPercent = (t.appointments / maxVal) * 100;
                const colHtml = `
                    <div class="w-[8%] bg-primary/20 rounded-t-sm relative hover:bg-primary/40 transition-all group" style="height: 100%">
                        <div id="bar-${index}" class="absolute bottom-0 w-full bg-primary rounded-t-sm transition-all duration-700 ease-out" style="height: 0%"></div>
                        <span class="absolute -top-10 left-1/2 -translate-x-1/2 bg-slate-800 text-white text-[10px] px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap z-30">
                            ${t.label}: ${t.appointments} appts
                        </span>
                    </div>`;
                chartContainer.insertAdjacentHTML('beforeend', colHtml);
                setTimeout(() => {
                    const bar = document.getElementById(`bar-${index}`);
                    if (bar) bar.style.height = `${heightPercent}%`;
                }, 50 + (index * 30));
            });
        } catch (e) { console.error(e); }
    }

    // 3. Cập nhật Recent Activity
    async function loadActivities() {
        try {
            const response = await fetch(`${BASE_URL}/recent-activities`);
            const activities = await response.json();
            const container = document.querySelector('.relative.border-l.border-slate-200');

            if (!activities || activities.length === 0) {
                container.innerHTML = `<p class="pl-6 text-slate-400 text-sm">No recent activities</p>`;
                return;
            }

            container.innerHTML = '';
            activities.forEach(act => {
                const date = new Date(act.timeAgo || act.createdAt);
                const timeString = date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                container.innerHTML += `
                    <div class="relative pl-6">
                        <div class="absolute -left-1.5 top-1.5 w-3 h-3 rounded-full bg-blue-500 border-2 border-white"></div>
                        <div>
                            <p class="text-sm font-medium text-slate-800">${act.title}</p>
                            <p class="text-xs text-slate-500 mt-0.5">${act.message}</p>
                            <p class="text-xs text-slate-400 mt-1">${timeString}</p>
                        </div>
                    </div>`;
            });
        } catch (error) { console.error(error); }
    }

        async function loadStats(period = "last 7 days") {
        try {
            const response = await fetch(`${BASE_URL}/stats?period=${period}`);
            const data = await response.json();

            // 1. Cập nhật con số tổng quát
            const h3s = document.querySelectorAll('h3.text-2xl.font-bold');
            h3s[0].innerText = formatCurrency(data.monthlyRevenue);
            h3s[1].innerText = data.totalAppointments.toLocaleString();
            h3s[2].innerText = data.newPatients.toLocaleString();
            h3s[3].innerText = data.activeDoctors.toLocaleString();

            // 2. Cập nhật màu sắc và icon cho các thẻ Growth
            const growthSpans = document.querySelectorAll('main .grid .bg-surface-light span.flex.items-center');

            updateGrowthBadge(growthSpans[0], data.revenueGrowth);
            updateGrowthBadge(growthSpans[1], data.appointmentGrowth);
            updateGrowthBadge(growthSpans[2], data.patientGrowth);
            updateGrowthBadge(growthSpans[3], data.doctorGrowth);
            // Thẻ bác sĩ thường không có growth hoặc fix 0%
        } catch (error) {
            console.error("Lỗi cập nhật stats:", error);
        }
    }

        async function loadDepartmentPerformance(period = "last 7 days") {
        try {
            const response = await fetch(`${BASE_URL}/department-performance?period=${period}`);
            const data = await response.json();
            const container = document.getElementById('department-list');

            // Nếu rỗng thì hiện thông báo
            if (!data || data.length === 0) {
                container.innerHTML = `<p class="text-center text-slate-400 text-sm">No data available</p>`;
                return;
            }

            container.innerHTML = '';
            const colors = ['bg-teal-500', 'bg-blue-500', 'bg-indigo-500', 'bg-amber-500'];

            data.forEach((item, index) => {
                const html = `
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="font-medium text-slate-700">${item.departmentName}</span>
                            <span class="text-slate-500">${item.percentage}%</span>
                        </div>
                        <div class="w-full bg-slate-100 rounded-full h-2">
                            <div id="dept-bar-${index}"
                                 class="${colors[index % colors.length]} h-2 rounded-full transition-all duration-1000 ease-out"
                                 style="width: 0%">
                            </div>
                        </div>
                    </div>`;

                container.insertAdjacentHTML('beforeend', html);

                // Hiệu ứng chạy thanh bar từ 0% đến giá trị thật
                setTimeout(() => {
                    const bar = document.getElementById(`dept-bar-${index}`);
                    if (bar) bar.style.width = `${item.percentage}%`;
                }, 100);
            });
        } catch (e) { console.error("Lỗi load Department Chart:", e); }
    }

    

    function updateGrowthBadge(element, value) {
        const isPositive = value >= 0;
        // Đổi màu background và text dựa trên giá trị âm/dương
        element.className = `flex items-center text-xs font-medium px-2 py-1 rounded-full ${
            isPositive ? 'text-emerald-600 bg-emerald-50' : 'text-rose-600 bg-rose-50'
        }`;
        // Đổi icon và giá trị %
        element.innerHTML = `
            <span class="material-symbols-outlined text-[14px] mr-1">
                ${isPositive ? 'trending_up' : 'trending_down'}
            </span>
            ${Math.abs(value)}%
        `;
    }

    // Bắt sự kiện Dropdown thay đổi
    document.getElementById('period-filter').addEventListener('change', (e) => {
        const period = e.target.value;
        loadStats(period);
        loadTrends(period);
        loadDepartmentPerformance(period); // Cập nhật lại biểu đồ ngang
    });

    // Khởi tạo trang lần đầu
    document.addEventListener('DOMContentLoaded', () => {
        const defaultPeriod = "last 7 days";
        loadStats(defaultPeriod);
        loadTrends(defaultPeriod); // Chạy chart lần đầu
        loadStaff();
        loadActivities();
        loadDepartmentPerformance();
    });
</script>
