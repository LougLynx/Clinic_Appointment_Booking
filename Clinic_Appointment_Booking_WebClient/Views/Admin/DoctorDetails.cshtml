@model BussinessObjects.DTOs.DoctorDetailDTO
@{
    ViewData["Title"] = $"{Model.FullName} - Doctor Profile";
    Layout = "_LayoutMediClinic";

    var statusLabel = Model.IsAvailable ? "Active" : "Inactive";
    var statusClass = Model.IsAvailable
        ? "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400"
        : "bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400";

    var medicalId = $"DR-{Model.DoctorId:00000}";
}

<main class="max-w-7xl mx-auto w-full px-4 lg:px-8 py-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div>
            <nav class="flex items-center gap-2 text-sm text-slate-500 mb-2">
                <a class="hover:text-primary no-underline" asp-area="" asp-controller="Admin" asp-action="DoctorManagement">Doctor Management</a>
                <span class="material-symbols-outlined text-xs">chevron_right</span>
                <span class="text-slate-900 dark:text-slate-100 font-medium">Doctor Profile</span>
            </nav>
            <div class="flex items-center gap-3">
                <h1 class="text-3xl font-extrabold tracking-tight">@Model.FullName</h1>
                <span class="@statusClass text-xs font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">@statusLabel</span>
            </div>
            <p class="text-slate-500 dark:text-slate-400 mt-1">
                Medical ID: <span class="font-mono">#@medicalId</span>
                • @Model.SpecialtyName
            </p>
        </div>
        <div class="flex flex-wrap items-center gap-3">
            <a asp-area="" asp-controller="Admin" asp-action="DoctorManagement"
               class="flex-1 sm:flex-none inline-flex items-center justify-center px-4 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-bold text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors no-underline">
                <span class="material-symbols-outlined text-lg mr-2">arrow_back</span>
                Back
            </a>
            <button type="button" disabled
                    class="flex-1 sm:flex-none inline-flex items-center justify-center px-4 py-2 bg-primary text-white rounded-lg text-sm font-bold shadow-sm opacity-60 cursor-not-allowed">
                <span class="material-symbols-outlined text-lg mr-2">edit</span>
                Edit Profile
            </button>
            <button type="button" disabled
                    class="flex-1 sm:flex-none inline-flex items-center justify-center px-4 py-2 bg-rose-50 dark:bg-rose-900/20 text-rose-600 dark:text-rose-400 rounded-lg text-sm font-bold opacity-60 cursor-not-allowed border border-rose-100 dark:border-rose-900/30">
                Deactivate
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <aside class="lg:col-span-4 flex flex-col gap-6">
            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
                <div class="w-full aspect-square rounded-xl overflow-hidden mb-6 bg-slate-100 dark:bg-slate-800">
                    @if (!string.IsNullOrWhiteSpace(Model.ProfilePictureUrl))
                    {
                        <img class="w-full h-full object-cover" alt="@Model.FullName portrait" src="@Model.ProfilePictureUrl" />
                    }
                    else
                    {
                        <div class="w-full h-full flex items-center justify-center text-slate-400">
                            <span class="material-symbols-outlined text-[80px]">account_circle</span>
                        </div>
                    }
                </div>

                <div class="space-y-4">
                    <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-primary mt-0.5">mail</span>
                        <div>
                            <p class="text-xs text-slate-500 uppercase font-bold tracking-wider">Email Address</p>
                            <p class="text-slate-900 dark:text-slate-100 font-medium">@Model.Email</p>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.PhoneNumber))
                    {
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary mt-0.5">call</span>
                            <div>
                                <p class="text-xs text-slate-500 uppercase font-bold tracking-wider">Phone Number</p>
                                <p class="text-slate-900 dark:text-slate-100 font-medium">@Model.PhoneNumber</p>
                            </div>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Location))
                    {
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary mt-0.5">location_on</span>
                            <div>
                                <p class="text-xs text-slate-500 uppercase font-bold tracking-wider">Department</p>
                                <p class="text-slate-900 dark:text-slate-100 font-medium">@Model.Location</p>
                            </div>
                        </div>
                    }
                    <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-primary mt-0.5">badge</span>
                        <div>
                            <p class="text-xs text-slate-500 uppercase font-bold tracking-wider">Experience</p>
                            <p class="text-slate-900 dark:text-slate-100 font-medium">@Model.YearsOfExperience years</p>
                        </div>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-slate-100 dark:border-slate-800">
                    <h4 class="text-sm font-bold mb-4">Account Stats</h4>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="bg-slate-50 dark:bg-slate-800/50 p-3 rounded-lg text-center">
                            <p class="text-2xl font-bold text-primary">@Model.Rating.ToString("0.0")</p>
                            <p class="text-[10px] text-slate-500 uppercase font-bold">Rating</p>
                        </div>
                        <div class="bg-slate-50 dark:bg-slate-800/50 p-3 rounded-lg text-center">
                            <p class="text-2xl font-bold text-primary">@Model.ReviewCount</p>
                            <p class="text-[10px] text-slate-500 uppercase font-bold">Reviews</p>
                        </div>
                    </div>
                </div>
            </div>
        </aside>

        <div class="lg:col-span-8 flex flex-col gap-8">
            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-1 flex overflow-x-auto no-scrollbar">
                <button type="button" class="flex-1 min-w-[160px] py-2.5 text-sm font-bold rounded-lg bg-primary/10 text-primary border border-primary/20">
                    Professional Info
                </button>
                <button type="button" class="flex-1 min-w-[160px] py-2.5 text-sm font-medium rounded-lg text-slate-500 dark:text-slate-400 cursor-not-allowed opacity-70">
                    Performance Analytics
                </button>
                <button type="button" class="flex-1 min-w-[160px] py-2.5 text-sm font-medium rounded-lg text-slate-500 dark:text-slate-400 cursor-not-allowed opacity-70">
                    Schedule
                </button>
            </div>

            <div class="space-y-6">
                <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-8 shadow-sm">
                    <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">history_edu</span>
                        Biography
                    </h3>
                    @if (!string.IsNullOrWhiteSpace(Model.Bio))
                    {
                        <p class="text-slate-600 dark:text-slate-400 leading-relaxed whitespace-pre-line">@Model.Bio</p>
                    }
                    else
                    {
                        <p class="text-slate-500 dark:text-slate-400">No biography provided.</p>
                    }
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-8 shadow-sm">
                        <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">school</span>
                            Education
                        </h3>
                        @if (!string.IsNullOrWhiteSpace(Model.Education))
                        {
                            <p class="text-slate-600 dark:text-slate-400 leading-relaxed whitespace-pre-line">@Model.Education</p>
                        }
                        else
                        {
                            <p class="text-slate-500 dark:text-slate-400">No education details.</p>
                        }
                    </div>

                    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-8 shadow-sm">
                        <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">verified_user</span>
                            Certifications
                        </h3>
                        @if (!string.IsNullOrWhiteSpace(Model.Qualifications))
                        {
                            <ul class="space-y-3">
                                @foreach (var cert in Model.Qualifications.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                {
                                    <li class="flex items-center gap-3 bg-slate-50 dark:bg-slate-800 p-2.5 rounded-lg border border-slate-100 dark:border-slate-700">
                                        <span class="material-symbols-outlined text-emerald-500">check_circle</span>
                                        <span class="text-sm font-medium">@cert</span>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-slate-500 dark:text-slate-400">No certifications listed.</p>
                        }
                    </div>
                </div>

                <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-8 shadow-sm">
                    <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">translate</span>
                        Languages Spoken
                    </h3>
                    @if (Model.Languages != null && Model.Languages.Count > 0)
                    {
                        <div class="flex flex-wrap gap-3">
                            @foreach (var language in Model.Languages)
                            {
                                <span class="px-4 py-1.5 bg-slate-100 dark:bg-slate-800 rounded-full text-sm font-semibold">@language</span>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-slate-500 dark:text-slate-400">No languages specified.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</main>

