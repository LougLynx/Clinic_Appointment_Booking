@{
    ViewData["Title"] = "Doctor Management";
    Layout = "_AdminLayout";
}

<div class="max-w-7xl mx-auto space-y-8">
    <!-- Page Heading -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div class="space-y-1">
            <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Doctor Management</h2>
            <p class="text-slate-500">View and manage your clinic's medical professionals.</p>
        </div>
        <button onclick="openAddDoctorModal()" class="flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-white px-5 py-2.5 rounded-lg font-bold text-sm transition-all shadow-lg shadow-primary/20">
            <span class="material-symbols-outlined">add</span>
            Add New Doctor
        </button>
    </div>

    <!-- Statistics Bar -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Total Doctors -->
        <div class="bg-white p-4 rounded-xl border border-slate-200 flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600">
                <span class="material-symbols-outlined">groups</span>
            </div>
            <div>
                <p class="text-xs text-slate-500">Total Doctors</p>
                <p id="stat-total-doctors" class="text-xl font-bold text-slate-900">42</p>
            </div>
        </div>

        <!-- Active Now -->
        <div class="bg-white p-4 rounded-xl border border-slate-200 flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-green-50 flex items-center justify-center text-green-600">
                <span class="material-symbols-outlined">task_alt</span>
            </div>
            <div>
                <p class="text-xs text-slate-500">Active Now</p>
                <p id="stat-active-doctors" class="text-xl font-bold text-slate-900">38</p>
            </div>
        </div>

        <!-- On Leave -->
        <div class="bg-white p-4 rounded-xl border border-slate-200 flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-amber-50 flex items-center justify-center text-amber-600">
                <span class="material-symbols-outlined">event_busy</span>
            </div>
            <div>
                <p class="text-xs text-slate-500">On Leave</p>
                <p id="stat-on-leave" class="text-xl font-bold text-slate-900">4</p>
            </div>
        </div>

        <!-- Specialties -->
        <div class="bg-white p-4 rounded-xl border border-slate-200 flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined">medical_information</span>
            </div>
            <div>
                <p class="text-xs text-slate-500">Specialties</p>
                <p id="stat-specialties" class="text-xl font-bold text-slate-900">12</p>
            </div>
        </div>
    </div>

    <!-- Filters and Table -->
    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden shadow-sm">
        <!-- Table Filters -->
        <div class="p-4 border-b border-slate-200 flex flex-wrap items-center gap-3">
            <div class="flex items-center gap-2 px-3 py-1.5 bg-slate-50 rounded-lg text-sm font-medium border border-slate-200">
                <span class="text-slate-500">Specialty:</span>
                <select class="bg-transparent border-none p-0 pr-6 text-sm focus:ring-0">
                    <option>All Specialties</option>
                    <option>Cardiology</option>
                    <option>Neurology</option>
                    <option>Pediatrics</option>
                </select>
            </div>
            <div class="flex items-center gap-2 px-3 py-1.5 bg-slate-50 rounded-lg text-sm font-medium border border-slate-200">
                <span class="text-slate-500">Status:</span>
                <select class="bg-transparent border-none p-0 pr-6 text-sm focus:ring-0">
                    <option>Any Status</option>
                    <option>Active</option>
                    <option>On Leave</option>
                </select>
            </div>
            <button class="ml-auto text-sm font-semibold text-primary flex items-center gap-1">
                <span class="material-symbols-outlined text-lg">filter_list</span>
                More Filters
            </button>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Doctor Name</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Specialty</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Status</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Contact</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="doctorTableBody" class="divide-y divide-slate-200">
                    <tr>
                        <td colspan="5" class="text-center py-10 text-slate-400">
                            <span class="animate-pulse">Loading medical staff...</span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-6 py-4 bg-slate-50 flex items-center justify-between border-t border-slate-200">
            <p id="showing-info" class="text-xs text-slate-500 font-medium">Showing 1 to 4 of 42 results</p>
            <div id="pagination-controls" class="flex gap-2">
                <!-- Controls will be rendered via script -->
            </div>
        </div>
    </div>
</div>

<!-- Add Doctor Modal -->
<div id="addDoctorModal" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl overflow-hidden animate-in fade-in zoom-in duration-200">
        <!-- Modal Header -->
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
            <h3 class="text-xl font-bold text-slate-900">Add New Doctor</h3>
            <button onclick="closeAddDoctorModal()" class="p-2 hover:bg-slate-200 rounded-lg transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <!-- Modal Body -->
        <form id="addDoctorForm" class="p-6 space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="space-y-1.5">
                    <label class="text-sm font-bold text-slate-700">Full Name</label>
                    <input type="text" name="fullName" required class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all placeholder:text-slate-400" placeholder="Dr. John Doe">
                </div>
                <div class="space-y-1.5">
                    <label class="text-sm font-bold text-slate-700">Email Address</label>
                    <input type="email" name="email" required class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all placeholder:text-slate-400" placeholder="john.doe@clinic.com">
                </div>
                <div class="space-y-1.5">
                    <label class="text-sm font-bold text-slate-700">Password</label>
                    <input type="password" name="password" required minlength="6" class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all placeholder:text-slate-400" placeholder="••••••••">
                </div>
                <div class="space-y-1.5">
                    <label class="text-sm font-bold text-slate-700">Phone Number</label>
                    <input type="tel" name="phoneNumber" required class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all placeholder:text-slate-400" placeholder="+1 (555) 000-0000">
                </div>
                <div class="space-y-1.5">
                    <label class="text-sm font-bold text-slate-700">Specialty</label>
                    <select id="specialtySelect" name="specialtyId" required class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all">
                        <option value="">Select Specialty</option>
                    </select>
                </div>
                <div class="space-y-1.5">
                    <label class="text-sm font-bold text-slate-700">Consultation Fee ($)</label>
                    <input type="number" name="consultationFee" required step="0.01" class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all placeholder:text-slate-400" placeholder="150.00">
                </div>
                <div class="space-y-1.5">
                    <label class="text-sm font-bold text-slate-700">Years of Experience</label>
                    <input type="number" name="yearsOfExperience" required class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all placeholder:text-slate-400" placeholder="10">
                </div>
                <div class="space-y-1.5">
                    <label class="text-sm font-bold text-slate-700">Location</label>
                    <input type="text" name="location" class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all placeholder:text-slate-400" placeholder="Building A, Room 302">
                </div>
            </div>

            <div class="space-y-1.5">
                <label class="text-sm font-bold text-slate-700">Profile Image</label>
                <div class="flex items-center gap-4">
                    <div id="imagePreview" class="w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 border border-slate-200 overflow-hidden">
                        <span class="material-symbols-outlined text-2xl">person</span>
                    </div>
                    <label class="px-4 py-2 bg-white border border-slate-200 rounded-lg text-sm font-bold text-slate-700 hover:bg-slate-50 cursor-pointer transition-all">
                        Browse Image
                        <input type="file" name="profileImage" accept="image/*" class="hidden" onchange="previewProfileImage(this)">
                    </label>
                    <p class="text-xs text-slate-500">JPG, PNG or GIF. Max 2MB.</p>
                </div>
            </div>
            
            <div class="space-y-1.5">
                <label class="text-sm font-bold text-slate-700">Qualifications</label>
                <input type="text" name="qualifications" class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all placeholder:text-slate-400" placeholder="MD, PhD in Cardiology">
            </div>

            <div class="space-y-1.5">
                <label class="text-sm font-bold text-slate-700">Short Bio</label>
                <textarea name="bio" rows="3" class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all placeholder:text-slate-400 resize-none" placeholder="Brief description of the doctor's expertise..."></textarea>
            </div>

            <!-- Modal Footer -->
            <div class="pt-4 flex items-center justify-end gap-3">
                <button type="button" onclick="closeAddDoctorModal()" class="px-5 py-2.5 rounded-lg font-bold text-sm text-slate-600 hover:bg-slate-100 transition-all">Cancel</button>
                <button type="submit" class="px-5 py-2.5 rounded-lg bg-primary hover:bg-primary/90 text-white font-bold text-sm transition-all shadow-lg shadow-primary/20 flex items-center gap-2">
                    <span id="submitBtnText">Create Account</span>
                    <span id="submitBtnLoader" class="material-symbols-outlined animate-spin hidden">sync</span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const API_BASE = "@ViewData["ApiBaseUrl"]";
    const BASE_URL = `${API_BASE}/api/Admin`;
    let currentPage = 1;
    const pageSize = 5;

    document.addEventListener("DOMContentLoaded", function () {
        loadManagementStats();
        loadDoctors(1);

        document.querySelectorAll('select').forEach(select => {
            select.addEventListener('change', () => loadDoctors(1));
        });

        const searchInput = document.querySelector('header input');
        if (searchInput) {
            searchInput.addEventListener('input', debounce(() => {
                loadDoctors(1, searchInput.value);
            }, 500));
        }
    });

    async function loadManagementStats() {
        try {
            const response = await fetch(`${BASE_URL}/management-stats`);
            if (!response.ok) throw new Error("Failed to fetch stats");
            const stats = await response.json();
            document.getElementById('stat-total-doctors').innerText = stats.totalDoctors || 0;
            document.getElementById('stat-active-doctors').innerText = stats.activeDoctors || 0;
            document.getElementById('stat-on-leave').innerText = stats.onLeaveDoctors || 0;
            document.getElementById('stat-specialties').innerText = stats.totalSpecialties || 0;
        } catch (error) {
            console.error("Error in loadManagementStats:", error);
        }
    }

    async function loadDoctors(page = 1, searchName = "") {
        currentPage = page;
        const tbody = document.getElementById('doctorTableBody');
        const selects = document.querySelectorAll('select');
        const specialty = selects[0]?.value || "All Specialties";
        const status = selects[1]?.value || "Any Status";

        tbody.innerHTML = '<tr><td colspan="5" class="text-center py-10 text-slate-400">Loading...</td></tr>';

        try {
            const url = `${BASE_URL}/doctors?specialty=${encodeURIComponent(specialty)}&status=${encodeURIComponent(status)}&page=${page}&pageSize=${pageSize}&search=${encodeURIComponent(searchName)}`;
            const response = await fetch(url);
            const result = await response.json();

            renderTable(result.data);
            renderPagination(result.totalPages, result.currentPage);
            updateShowingText(result.totalRecords, result.data.length, page);

        } catch (error) {
            console.error("Error:", error);
            tbody.innerHTML = '<tr><td colspan="5" class="text-center text-red-500">Failed to load data.</td></tr>';
        }
    }

    function renderTable(doctors) {
        const tbody = document.getElementById('doctorTableBody');
        tbody.innerHTML = '';
        if (!doctors || doctors.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" class="text-center py-10">No doctors found.</td></tr>';
            return;
        }

        doctors.forEach(doc => {
            const isActive = doc.status === 'Active';
            const detailsUrl = `/Admin/DoctorDetails/${doc.doctorId}`;
            const safePhone = doc.phoneNumber || '';
            const safeEmail = doc.email || '';
            let safeImage = doc.profileImage || 'https://via.placeholder.com/100';
            if (safeImage && !safeImage.startsWith('http')) {
                // Ensure it starts with / for relative paths
                const path = safeImage.startsWith('/') ? safeImage : `/${safeImage}`;
                safeImage = `${API_BASE}${path}`;
            }

            const row = `
                <tr class="hover:bg-slate-50/50 transition-colors border-b border-slate-100 last:border-none">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <a href="${detailsUrl}" class="no-underline">
                                <img class="w-10 h-10 rounded-full object-cover border border-slate-200" 
                                     src="${safeImage}" 
                                     alt="${doc.fullName}"
                                     onerror="this.onerror=null; this.src='https://via.placeholder.com/100';" />
                            </a>
                            <div>
                                <a href="${detailsUrl}" class="font-bold text-sm text-slate-900 hover:text-primary no-underline">${doc.fullName}</a>
                                <p class="text-xs text-slate-500">ID: DOC-${doc.doctorId}</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4"><span class="px-2.5 py-1 rounded-full text-[11px] font-bold ${getSpecialtyBadgeClass(doc.specialty)}">${doc.specialty}</span></td>
                    <td class="px-6 py-4">
                        <div id="status-badge-${doc.doctorId}" class="flex items-center gap-1.5 ${isActive ? 'text-green-600' : 'text-slate-500'}">
                            <span class="w-2 h-2 rounded-full ${isActive ? 'bg-green-500' : 'bg-slate-400'}"></span>
                            <span class="text-sm font-medium">${doc.status}</span>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="text-sm text-slate-700">${safeEmail}</div>
                        <div class="text-xs text-slate-500">${safePhone}</div>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <div class="inline-flex items-center gap-3 justify-end">
                            <a href="${detailsUrl}" class="inline-flex items-center justify-center px-3 py-1.5 rounded-lg border border-slate-200 hover:border-primary bg-white hover:bg-slate-50 text-slate-700 text-xs font-bold transition-colors no-underline">
                                View
                            </a>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" value="" class="sr-only peer" ${isActive ? 'checked' : ''} onchange="toggleDoctorStatus(${doc.doctorId}, this)">
                                <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                            </label>
                        </div>
                    </td>
                </tr>`;
            tbody.insertAdjacentHTML('beforeend', row);
        });
    }

    function renderPagination(totalPages, current) {
        const container = document.getElementById('pagination-controls');
        container.innerHTML = '';
        if (totalPages <= 1) return;

        container.innerHTML += `<button onclick="loadDoctors(${current - 1})" ${current === 1 ? 'disabled' : ''} class="px-3 py-1 bg-white border border-slate-200 rounded text-xs font-semibold hover:bg-slate-50 disabled:opacity-50">Previous</button>`;

        for (let i = 1; i <= totalPages; i++) {
            container.innerHTML += `
                <button onclick="loadDoctors(${i})" class="px-3 py-1 border rounded text-xs font-semibold ${i === current ? 'bg-primary text-white border-primary' : 'bg-white border-slate-200 hover:bg-slate-50'}">
                    ${i}
                </button>`;
        }

        container.innerHTML += `<button onclick="loadDoctors(${current + 1})" ${current === totalPages ? 'disabled' : ''} class="px-3 py-1 bg-white border border-slate-200 rounded text-xs font-semibold hover:bg-slate-50 disabled:opacity-50">Next</button>`;
    }

    function updateShowingText(total, count, page) {
        const start = (page - 1) * pageSize + 1;
        const end = start + count - 1;
        document.getElementById('showing-info').innerText = `Showing ${total === 0 ? 0 : start} to ${end} of ${total} results`;
    }

    function getSpecialtyBadgeClass(specialty) {
        const maps = {
            'Cardiology': 'bg-blue-100 text-blue-600',
            'Pediatrics': 'bg-purple-100 text-purple-600',
            'Neurology': 'bg-cyan-100 text-cyan-600',
            'Dermatology': 'bg-pink-100 text-pink-600',
            'General Medicine': 'bg-amber-100 text-amber-600',
            'Orthopedics': 'bg-indigo-100 text-indigo-600'
        };
        return maps[specialty] || 'bg-slate-100 text-slate-600';
    }

    async function toggleDoctorStatus(doctorId, checkboxElement) {
        const originalState = !checkboxElement.checked;
        try {
            const response = await fetch(`${BASE_URL}/doctors/${doctorId}/toggle-status`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' }
            });
            if (!response.ok) throw new Error("Update failed");
            const statusBadge = document.getElementById(`status-badge-${doctorId}`);
            const isNowActive = checkboxElement.checked;
            statusBadge.className = `flex items-center gap-1.5 ${isNowActive ? 'text-green-600' : 'text-slate-500'}`;
            statusBadge.innerHTML = `
                <span class="w-2 h-2 rounded-full ${isNowActive ? 'bg-green-500' : 'bg-slate-400'}"></span>
                <span class="text-sm font-medium">${isNowActive ? 'Active' : 'On Leave'}</span>
            `;
            loadManagementStats();
        } catch (error) {
            console.error("Error:", error);
            alert("Could not update status. Please try again.");
            checkboxElement.checked = originalState;
        }
    }

    function debounce(func, timeout = 300) {
        let timer;
        return (...args) => {
            clearTimeout(timer);
            timer = setTimeout(() => { func.apply(this, args); }, timeout);
        };
    }

    // Modal Logic
    function openAddDoctorModal() {
        document.getElementById('addDoctorModal').classList.remove('hidden');
        document.getElementById('addDoctorModal').classList.add('flex');
        loadSpecialties();
    }

    function closeAddDoctorModal() {
        document.getElementById('addDoctorModal').classList.add('hidden');
        document.getElementById('addDoctorModal').classList.remove('flex');
        document.getElementById('addDoctorForm').reset();
        document.getElementById('imagePreview').innerHTML = '<span class="material-symbols-outlined text-2xl">person</span>';
    }

    function previewProfileImage(input) {
        const preview = document.getElementById('imagePreview');
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.innerHTML = `<img src="${e.target.result}" class="w-full h-full object-cover">`;
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    async function loadSpecialties() {
        const specialtySelect = document.getElementById('specialtySelect');
        if (specialtySelect.options.length > 1) return; // Already loaded

        try {
            const response = await fetch(`${API_BASE}/api/Specialty`);
            const result = await response.json();
            
            if (result.success && result.data) {
                result.data.forEach(s => {
                    const option = document.createElement('option');
                    option.value = s.specialtyId;
                    option.textContent = s.name;
                    specialtySelect.appendChild(option);
                });
            }
        } catch (error) {
            console.error("Error loading specialties:", error);
        }
    }

    document.getElementById('addDoctorForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const submitBtnText = document.getElementById('submitBtnText');
        const submitBtnLoader = document.getElementById('submitBtnLoader');
        const submitBtn = e.target.querySelector('button[type="submit"]');

        // Show loading state
        submitBtnText.textContent = "Creating...";
        submitBtnLoader.classList.remove('hidden');
        submitBtn.disabled = true;

        const formData = new FormData(this);

        try {
            const response = await fetch(`${BASE_URL}/doctors`, {
                method: 'POST',
                // Important: Don't set Content-Type header when using FormData
                body: formData
            });

            if (response.ok) {
                alert("Doctor created successfully!");
                closeAddDoctorModal();
                loadDoctors(1); // Refresh the table
                loadManagementStats(); // Refresh stats
            } else {
                const errorData = await response.json();
                console.error("Creation failed:", errorData);
                alert("Failed to create doctor. Please check the data and try again.");
            }
        } catch (error) {
            console.error("Error:", error);
            alert("An unexpected error occurred.");
        } finally {
            // Restore button state
            submitBtnText.textContent = "Create Account";
            submitBtnLoader.classList.add('hidden');
            submitBtn.disabled = false;
        }
    });
</script>
}