@{
    ViewData["Title"] = "Financial Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediClinic</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <!-- Inter Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    
    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#13b6ec",
                        "background-light": "#f6f8f8",
                        "background-dark": "#101d22",
                    },
                    fontFamily: {
                        "display": ["Inter"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside class="w-64 border-r border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hidden md:flex flex-col">
            <!-- Logo -->
            <div class="p-6 flex items-center gap-3">
                <div class="bg-primary rounded-lg p-2 text-white">
                    <span class="material-symbols-outlined">medical_services</span>
                </div>
                <div>
                    <h1 class="font-bold text-slate-900 dark:text-white leading-none">MediClinic</h1>
                    <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Admin Panel v2.1</p>
                </div>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 px-4 space-y-1">
                <a asp-area="" asp-controller="Admin" asp-action="Dashboard" 
                   class="flex items-center gap-3 px-3 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg no-underline">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span class="text-sm font-medium">Dashboard</span>
                </a>
                <a asp-area="" asp-controller="Admin" asp-action="PatientRecords" 
                   class="flex items-center gap-3 px-3 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg no-underline">
                    <span class="material-symbols-outlined">group</span>
                    <span class="text-sm font-medium">Patients</span>
                </a>
                <a asp-area="" asp-controller="Admin" asp-action="Appointments" 
                   class="flex items-center gap-3 px-3 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg no-underline">
                    <span class="material-symbols-outlined">calendar_today</span>
                    <span class="text-sm font-medium">Appointments</span>
                </a>
                <a asp-area="" asp-controller="Admin" asp-action="Financials" 
                   class="flex items-center gap-3 px-3 py-2 bg-primary/10 text-primary rounded-lg no-underline">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">account_balance_wallet</span>
                    <span class="text-sm font-medium">Financials</span>
                </a>
                <a asp-area="" asp-controller="Admin" asp-action="DoctorManagement" 
                   class="flex items-center gap-3 px-3 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg no-underline">
                    <span class="material-symbols-outlined">badge</span>
                    <span class="text-sm font-medium">Staff</span>
                </a>
                <a asp-area="" asp-controller="Admin" asp-action="Settings" 
                   class="flex items-center gap-3 px-3 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg no-underline">
                    <span class="material-symbols-outlined">settings</span>
                    <span class="text-sm font-medium">Settings</span>
                </a>
            </nav>

            <!-- User Profile -->
            <div class="p-4 border-t border-slate-200 dark:border-slate-800">
                <div class="flex items-center gap-3 p-2 rounded-lg bg-slate-50 dark:bg-slate-800">
                    <img alt="User Profile" 
                         class="w-10 h-10 rounded-full bg-slate-200" 
                         src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=100&h=100&fit=crop" />
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-semibold truncate">Dr. Sarah Miller</p>
                        <p class="text-xs text-slate-500 truncate">Administrator</p>
                    </div>
                    <span class="material-symbols-outlined text-slate-400 text-sm">unfold_more</span>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col min-w-0 overflow-y-auto">
            <!-- Top Header -->
            <header class="h-16 border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 flex items-center justify-between px-8 sticky top-0 z-10">
                <div class="flex items-center gap-4 flex-1">
                    <div class="relative w-full max-w-md">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
                        <input class="w-full pl-10 pr-4 py-2 rounded-lg bg-slate-50 dark:bg-slate-800 border-none focus:ring-2 focus:ring-primary text-sm" 
                               placeholder="Search transactions, patients, or invoices..." 
                               type="text" />
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <button class="p-2 text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg relative">
                        <span class="material-symbols-outlined">notifications</span>
                        <span class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full border-2 border-white dark:border-slate-900"></span>
                    </button>
                    <button class="flex items-center gap-2 bg-primary text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-primary/90">
                        <span class="material-symbols-outlined text-sm">add</span>
                        New Payment
                    </button>
                </div>
            </header>

            <!-- Content -->
            <div class="p-8 space-y-8">
                <!-- Page Title -->
                <div class="flex flex-col gap-2">
                    <h2 class="text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Financial Performance</h2>
                    <p class="text-slate-500 dark:text-slate-400 max-w-2xl">Monitor clinical revenue streams, operational expenses, and profitability metrics for the current fiscal period.</p>
                </div>

                <!-- KPI Cards -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Total Revenue -->
                    <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-sm font-medium text-slate-500">Total Revenue</span>
                            <span class="bg-emerald-100 text-emerald-700 text-xs font-bold px-2 py-1 rounded-full">+12.5%</span>
                        </div>
                        <p class="text-3xl font-bold text-slate-900 dark:text-white">$128,450.00</p>
                        <p class="text-xs text-slate-400 mt-2">vs. $114,178 last month</p>
                    </div>

                    <!-- Operational Expenses -->
                    <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-sm font-medium text-slate-500">Operational Expenses</span>
                            <span class="bg-red-100 text-red-700 text-xs font-bold px-2 py-1 rounded-full">-2.3%</span>
                        </div>
                        <p class="text-3xl font-bold text-slate-900 dark:text-white">$42,300.00</p>
                        <p class="text-xs text-slate-400 mt-2">vs. $43,295 last month</p>
                    </div>

                    <!-- Net Profit -->
                    <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-sm font-medium text-slate-500">Net Profit</span>
                            <span class="bg-emerald-100 text-emerald-700 text-xs font-bold px-2 py-1 rounded-full">+14.8%</span>
                        </div>
                        <p class="text-3xl font-bold text-slate-900 dark:text-white">$86,150.00</p>
                        <p class="text-xs text-slate-400 mt-2">vs. $75,043 last month</p>
                    </div>
                </div>

                <!-- Charts Section -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <!-- Revenue Trends -->
                    <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                        <div class="flex items-center justify-between mb-8">
                            <div>
                                <h3 class="font-bold text-slate-900 dark:text-white">Revenue Trends</h3>
                                <p class="text-sm text-slate-500">Gross earnings over the last 6 months</p>
                            </div>
                            <select class="bg-slate-50 dark:bg-slate-800 border-none rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 py-1">
                                <option>Last 6 Months</option>
                                <option>Last Year</option>
                            </select>
                        </div>
                        <div class="relative h-64 w-full">
                            <!-- SVG Chart -->
                            <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 400 150">
                                <defs>
                                    <linearGradient id="revenueGradient" x1="0" x2="0" y1="0" y2="1">
                                        <stop offset="0%" stop-color="#13b6ec" stop-opacity="0.2"></stop>
                                        <stop offset="100%" stop-color="#13b6ec" stop-opacity="0"></stop>
                                    </linearGradient>
                                </defs>
                                <path d="M0 120 Q 50 110, 100 80 T 200 60 T 300 90 T 400 30" fill="none" stroke="#13b6ec" stroke-width="3"></path>
                                <path d="M0 120 Q 50 110, 100 80 T 200 60 T 300 90 T 400 30 V 150 H 0 Z" fill="url(#revenueGradient)"></path>
                            </svg>
                            <div class="flex justify-between mt-4">
                                <span class="text-xs font-bold text-slate-400">JAN</span>
                                <span class="text-xs font-bold text-slate-400">FEB</span>
                                <span class="text-xs font-bold text-slate-400">MAR</span>
                                <span class="text-xs font-bold text-slate-400">APR</span>
                                <span class="text-xs font-bold text-slate-400">MAY</span>
                                <span class="text-xs font-bold text-slate-400">JUN</span>
                            </div>
                        </div>
                    </div>

                    <!-- Expenses by Category -->
                    <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                        <div class="flex items-center justify-between mb-8">
                            <div>
                                <h3 class="font-bold text-slate-900 dark:text-white">Expenses by Category</h3>
                                <p class="text-sm text-slate-500">Distribution of operational costs</p>
                            </div>
                        </div>
                        <div class="space-y-5">
                            <!-- Staff Salaries -->
                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="text-slate-600 dark:text-slate-400">Staff Salaries</span>
                                    <span class="font-bold">$24,000 (56%)</span>
                                </div>
                                <div class="w-full h-2 bg-slate-100 dark:bg-slate-800 rounded-full">
                                    <div class="h-full bg-primary rounded-full" style="width: 56%"></div>
                                </div>
                            </div>
                            <!-- Medical Supplies -->
                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="text-slate-600 dark:text-slate-400">Medical Supplies</span>
                                    <span class="font-bold">$10,500 (25%)</span>
                                </div>
                                <div class="w-full h-2 bg-slate-100 dark:bg-slate-800 rounded-full">
                                    <div class="h-full bg-primary/60 rounded-full" style="width: 25%"></div>
                                </div>
                            </div>
                            <!-- Facility Maintenance -->
                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="text-slate-600 dark:text-slate-400">Facility Maintenance</span>
                                    <span class="font-bold">$4,800 (11%)</span>
                                </div>
                                <div class="w-full h-2 bg-slate-100 dark:bg-slate-800 rounded-full">
                                    <div class="h-full bg-primary/40 rounded-full" style="width: 11%"></div>
                                </div>
                            </div>
                            <!-- Other Utilities -->
                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="text-slate-600 dark:text-slate-400">Other Utilities</span>
                                    <span class="font-bold">$3,000 (8%)</span>
                                </div>
                                <div class="w-full h-2 bg-slate-100 dark:bg-slate-800 rounded-full">
                                    <div class="h-full bg-primary/20 rounded-full" style="width: 8%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Transaction History Table -->
                <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden">
                    <div class="p-6 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between">
                        <h3 class="font-bold text-slate-900 dark:text-white">Recent Transactions</h3>
                        <div class="flex gap-2">
                            <button class="flex items-center gap-2 px-3 py-1.5 border border-slate-200 dark:border-slate-800 rounded-lg text-xs font-semibold hover:bg-slate-50 dark:hover:bg-slate-800">
                                <span class="material-symbols-outlined text-sm">filter_list</span>
                                Filter
                            </button>
                            <button class="flex items-center gap-2 px-3 py-1.5 border border-slate-200 dark:border-slate-800 rounded-lg text-xs font-semibold hover:bg-slate-50 dark:hover:bg-slate-800">
                                <span class="material-symbols-outlined text-sm">download</span>
                                Export
                            </button>
                        </div>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead class="bg-slate-50 dark:bg-slate-800/50 text-slate-500 text-xs font-bold uppercase tracking-wider">
                                <tr>
                                    <th class="px-6 py-4">Transaction ID</th>
                                    <th class="px-6 py-4">Patient / Vendor</th>
                                    <th class="px-6 py-4">Category</th>
                                    <th class="px-6 py-4">Date</th>
                                    <th class="px-6 py-4">Amount</th>
                                    <th class="px-6 py-4">Status</th>
                                    <th class="px-6 py-4"></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 dark:divide-slate-800 text-sm">
                                <!-- Transaction 1 -->
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30">
                                    <td class="px-6 py-4 font-medium text-slate-900 dark:text-white">#TRX-94821</td>
                                    <td class="px-6 py-4">James Wilson</td>
                                    <td class="px-6 py-4 text-slate-500">Medical Consultation</td>
                                    <td class="px-6 py-4 text-slate-500">Oct 24, 2023</td>
                                    <td class="px-6 py-4 font-semibold text-emerald-600">+$150.00</td>
                                    <td class="px-6 py-4">
                                        <span class="bg-emerald-100 text-emerald-700 text-[10px] font-bold px-2 py-0.5 rounded-full">COMPLETED</span>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <button class="text-slate-400 hover:text-primary"><span class="material-symbols-outlined">more_vert</span></button>
                                    </td>
                                </tr>
                                <!-- Transaction 2 -->
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30">
                                    <td class="px-6 py-4 font-medium text-slate-900 dark:text-white">#TRX-94819</td>
                                    <td class="px-6 py-4">BioHealth Supplies</td>
                                    <td class="px-6 py-4 text-slate-500">Medical Equipment</td>
                                    <td class="px-6 py-4 text-slate-500">Oct 23, 2023</td>
                                    <td class="px-6 py-4 font-semibold text-red-600">-$2,400.00</td>
                                    <td class="px-6 py-4">
                                        <span class="bg-amber-100 text-amber-700 text-[10px] font-bold px-2 py-0.5 rounded-full">PENDING</span>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <button class="text-slate-400 hover:text-primary"><span class="material-symbols-outlined">more_vert</span></button>
                                    </td>
                                </tr>
                                <!-- Transaction 3 -->
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30">
                                    <td class="px-6 py-4 font-medium text-slate-900 dark:text-white">#TRX-94815</td>
                                    <td class="px-6 py-4">Emily Chen</td>
                                    <td class="px-6 py-4 text-slate-500">Lab Reports</td>
                                    <td class="px-6 py-4 text-slate-500">Oct 23, 2023</td>
                                    <td class="px-6 py-4 font-semibold text-emerald-600">+$85.00</td>
                                    <td class="px-6 py-4">
                                        <span class="bg-emerald-100 text-emerald-700 text-[10px] font-bold px-2 py-0.5 rounded-full">COMPLETED</span>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <button class="text-slate-400 hover:text-primary"><span class="material-symbols-outlined">more_vert</span></button>
                                    </td>
                                </tr>
                                <!-- Transaction 4 -->
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30">
                                    <td class="px-6 py-4 font-medium text-slate-900 dark:text-white">#TRX-94802</td>
                                    <td class="px-6 py-4">Robert Fox</td>
                                    <td class="px-6 py-4 text-slate-500">Surgery Deposit</td>
                                    <td class="px-6 py-4 text-slate-500">Oct 22, 2023</td>
                                    <td class="px-6 py-4 font-semibold text-emerald-600">+$1,200.00</td>
                                    <td class="px-6 py-4">
                                        <span class="bg-emerald-100 text-emerald-700 text-[10px] font-bold px-2 py-0.5 rounded-full">COMPLETED</span>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <button class="text-slate-400 hover:text-primary"><span class="material-symbols-outlined">more_vert</span></button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="p-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-between text-xs font-medium text-slate-500">
                        <span>Showing 4 of 1,248 transactions</span>
                        <div class="flex gap-2">
                            <button class="px-3 py-1 border border-slate-200 dark:border-slate-800 rounded hover:bg-slate-50 dark:hover:bg-slate-800 disabled:opacity-50" disabled>Previous</button>
                            <button class="px-3 py-1 border border-slate-200 dark:border-slate-800 rounded hover:bg-slate-50 dark:hover:bg-slate-800">Next</button>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
