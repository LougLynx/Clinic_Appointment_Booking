@{
    ViewData["Title"] = "Financial Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediClinic</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <!-- Inter Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    
    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#0d9488",
                        "primary-hover": "#0f766e",
                        "accent-blue": "#3b82f6",
                        "background-light": "#f0fdfa",
                        "surface-light": "#ffffff",
                    },
                    fontFamily: {
                        "display": ["Inter", "Noto Sans", "sans-serif"]
                    },
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
</head>
<body class="bg-background-light text-slate-800 font-display">
    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <aside class="w-64 bg-slate-900 text-slate-300 flex flex-col transition-all duration-300 flex-shrink-0 border-r border-slate-800">
            <!-- Logo -->
            <div class="h-16 flex items-center px-6 border-b border-slate-800 bg-slate-950/50">
                <span class="material-symbols-outlined text-primary text-3xl mr-3">admin_panel_settings</span>
                <h1 class="text-white font-bold text-lg tracking-wide">MediAdmin</h1>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 overflow-y-auto py-6 flex flex-col gap-2 px-3">
                <a asp-area="" asp-controller="Admin" asp-action="Dashboard" 
                   class="flex items-center gap-3 px-4 py-3 hover:bg-slate-800 rounded-lg transition-colors text-slate-400 hover:text-white border-l-4 border-transparent no-underline">
                    <span class="material-symbols-outlined text-[20px]">dashboard</span>
                    <span class="font-medium">Dashboard</span>
                </a>
                <a asp-area="" asp-controller="Admin" asp-action="DoctorManagement" 
                   class="flex items-center gap-3 px-4 py-3 hover:bg-slate-800 rounded-lg transition-colors text-slate-400 hover:text-white border-l-4 border-transparent no-underline">
                    <span class="material-symbols-outlined text-[20px]">stethoscope</span>
                    <span class="font-medium">Doctor Management</span>
                </a>
                <a asp-area="" asp-controller="Admin" asp-action="PatientRecords" 
                   class="flex items-center gap-3 px-4 py-3 hover:bg-slate-800 rounded-lg transition-colors text-slate-400 hover:text-white border-l-4 border-transparent no-underline">
                    <span class="material-symbols-outlined text-[20px]">folder_shared</span>
                    <span class="font-medium">Patient Records</span>
                </a>
                <a asp-area="" asp-controller="Admin" asp-action="Financials" 
                   class="flex items-center gap-3 px-4 py-3 bg-primary/20 text-white rounded-lg transition-colors border-l-4 border-primary no-underline">
                    <span class="material-symbols-outlined text-[20px]">account_balance_wallet</span>
                    <span class="font-medium">Financials</span>
                </a>
                <a asp-area="" asp-controller="Admin" asp-action="Settings" 
                   class="flex items-center gap-3 px-4 py-3 hover:bg-slate-800 rounded-lg transition-colors text-slate-400 hover:text-white border-l-4 border-transparent no-underline">
                    <span class="material-symbols-outlined text-[20px]">settings</span>
                    <span class="font-medium">System Settings</span>
                </a>
            </nav>

            <!-- User Profile -->
            <div class="p-4 border-t border-slate-800">
                <div class="flex items-center gap-3 px-2 mb-3">
                    <div class="w-10 h-10 rounded-full bg-slate-700 flex items-center justify-center text-white font-bold">
                        SA
                    </div>
                    <div>
                        <p class="text-white text-sm font-medium">System Admin</p>
                        <p class="text-xs text-slate-500">admin@mediclinic.com</p>
                    </div>
                </div>
                <!-- Back to Home Button -->
                <a asp-area="" asp-controller="Home" asp-action="Index" 
                   class="flex items-center gap-2 px-4 py-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-colors text-sm no-underline">
                    <span class="material-symbols-outlined text-[18px]">home</span>
                    <span>Back to Home</span>
                </a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Top Header -->
            <header class="h-16 bg-surface-light border-b border-slate-200 flex items-center justify-between px-8 shadow-sm flex-shrink-0 z-10">
                <!-- Search Bar -->
                <div class="flex items-center bg-slate-100 rounded-lg px-3 py-2 w-96 border border-slate-200 focus-within:border-primary focus-within:ring-1 focus-within:ring-primary transition-all">
                    <svg class="h-5 w-5 text-slate-400 mr-2" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M10 2a8 8 0 0 1 6.32 12.9l3.39 3.39a1 1 0 1 1-1.42 1.42l-3.39-3.39A8 8 0 1 1 10 2Zm0 2a6 6 0 1 0 0 12 6 6 0 0 0 0-12Z"/>
                    </svg>
                    <input class="bg-transparent border-none outline-none text-sm w-full text-slate-700 placeholder-slate-400 focus:ring-0 p-0" 
                           placeholder="Search records, doctors..." 
                           type="text" />
                </div>

                <!-- Header Actions -->
                <div class="flex items-center gap-5">
                    <button class="relative text-slate-500 hover:text-primary transition-colors">
                        <span class="material-symbols-outlined">notifications</span>
                        <span class="absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full border border-white"></span>
                    </button>
                    <div class="h-8 w-px bg-slate-200"></div>
                    <button id="btn-export-report" class="flex items-center gap-2 text-slate-600 hover:text-slate-900 font-medium text-sm">
                        <span>Export Report</span>
                        <span class="material-symbols-outlined text-[18px]">download</span>
                    </button>
                </div>
            </header>

            <!-- Main Dashboard Content -->
            <main class="flex-1 overflow-y-auto p-8 bg-slate-50/50 space-y-8">
                <!-- Page Title -->
                <div class="flex flex-col gap-2">
                    <h2 class="text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Financial Performance</h2>
                    <p class="text-slate-500 dark:text-slate-400 max-w-2xl">Monitor clinical revenue streams, operational expenses, and profitability metrics for the current fiscal period.</p>
                </div>

                <!-- KPI Cards -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-sm font-medium text-slate-500">Total Revenue</span>
                            <span id="revenue-growth-badge" class="text-xs font-bold px-2 py-1 rounded-full">--%</span>
                        </div>
                        <p id="total-revenue" class="text-3xl font-bold text-slate-900 dark:text-white">$0.00</p>
                        <p id="prev-revenue-text" class="text-xs text-slate-400 mt-2">vs. $0 last month</p>
                    </div>

                    <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-sm font-medium text-slate-500">Operational Expenses</span>
                            <span id="expenses-growth-badge" class="text-xs font-bold px-2 py-1 rounded-full">--%</span>
                        </div>
                        <p id="total-expenses" class="text-3xl font-bold text-slate-900 dark:text-white">$0.00</p>
                        <p id="prev-expenses-text" class="text-xs text-slate-400 mt-2">vs. $0 last month</p>
                    </div>

                    <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-sm font-medium text-slate-500">Net Profit</span>
                            <span id="profit-growth-badge" class="text-xs font-bold px-2 py-1 rounded-full">--%</span>
                        </div>
                        <p id="net-profit" class="text-3xl font-bold text-slate-900 dark:text-white">$0.00</p>
                        <p id="prev-profit-text" class="text-xs text-slate-400 mt-2">vs. $0 last month</p>
                    </div>
                </div>

                <!-- Charts Section -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <!-- Revenue Trends -->
                    <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                        <div class="flex items-center justify-between mb-8">
                            <div>
                                <h3 class="font-bold text-slate-900 dark:text-white">Revenue Trends</h3>
