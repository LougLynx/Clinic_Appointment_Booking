@{
    ViewData["Title"] = "Financial Dashboard";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <!-- Page Title -->
    <div class="flex flex-col gap-2">
        <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">Financial Performance</h2>
        <p class="text-slate-500 max-w-2xl">Monitor clinical revenue streams, operational expenses, and profitability metrics for the current fiscal period.</p>
    </div>

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded-xl border border-slate-200">
            <div class="flex items-center justify-between mb-4">
                <span class="text-sm font-medium text-slate-500">Total Revenue</span>
                <span id="revenue-growth-badge" class="text-xs font-bold px-2 py-1 rounded-full">--%</span>
            </div>
            <p id="total-revenue" class="text-3xl font-bold text-slate-900">$0.00</p>
            <p id="prev-revenue-text" class="text-xs text-slate-400 mt-2">vs. $0 last month</p>
        </div>

        <div class="bg-white p-6 rounded-xl border border-slate-200">
            <div class="flex items-center justify-between mb-4">
                <span class="text-sm font-medium text-slate-500">Operational Expenses</span>
                <span id="expenses-growth-badge" class="text-xs font-bold px-2 py-1 rounded-full">--%</span>
            </div>
            <p id="total-expenses" class="text-3xl font-bold text-slate-900">$0.00</p>
            <p id="prev-expenses-text" class="text-xs text-slate-400 mt-2">vs. $0 last month</p>
        </div>

        <div class="bg-white p-6 rounded-xl border border-slate-200">
            <div class="flex items-center justify-between mb-4">
                <span class="text-sm font-medium text-slate-500">Net Profit</span>
                <span id="profit-growth-badge" class="text-xs font-bold px-2 py-1 rounded-full">--%</span>
            </div>
            <p id="net-profit" class="text-3xl font-bold text-slate-900">$0.00</p>
            <p id="prev-profit-text" class="text-xs text-slate-400 mt-2">vs. $0 last month</p>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Revenue Trends -->
        <div class="bg-white p-6 rounded-xl border border-slate-200">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h3 class="font-bold text-slate-900">Revenue Trends</h3>
                    <p class="text-sm text-slate-500">Gross earnings over the last 6 months</p>
                </div>
                <select id="revenue-period-select" class="bg-slate-50 border-none rounded-lg text-sm font-medium text-slate-600 py-1">
                    <option value="last6months">Last 6 Months</option>
                    <option value="lastyear">Last Year</option>
                </select>
            </div>
            <div id="revenue-chart-container" class="relative h-64 w-full">
                <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 400 150">
                    <defs>
                        <linearGradient id="revenueGradient" x1="0" x2="0" y1="0" y2="1">
                            <stop offset="0%" stop-color="#13b6ec" stop-opacity="0.2"></stop>
                            <stop offset="100%" stop-color="#13b6ec" stop-opacity="0"></stop>
                        </linearGradient>
                    </defs>
                    <path d="M0 120 Q 50 110, 100 80 T 200 60 T 300 90 T 400 30" fill="none" stroke="#13b6ec" stroke-width="3"></path>
                    <path d="M0 120 Q 50 110, 100 80 T 200 60 T 300 90 T 400 30 V 150 H 0 Z" fill="url(#revenueGradient)"></path>
                </svg>
                <div class="flex justify-between mt-4">
                    <!-- Labels via script -->
                </div>
            </div>
        </div>

        <!-- Expenses by Category -->
        <div class="bg-white p-6 rounded-xl border border-slate-200">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h3 class="font-bold text-slate-900">Expenses by Category</h3>
                    <p class="text-sm text-slate-500">Distribution of operational costs</p>
                </div>
            </div>
            <div id="expenses-category-list" class="space-y-5">
                <!-- Items via script -->
            </div>
        </div>
    </div>

    <!-- Transaction History Table -->
    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="p-6 border-b border-slate-200 flex items-center justify-between">
            <h3 class="font-bold text-slate-900">Recent Transactions</h3>
            <div class="flex gap-2">
                <button class="flex items-center gap-2 px-3 py-1.5 border border-slate-200 rounded-lg text-xs font-semibold hover:bg-slate-50">
                    <span class="material-symbols-outlined text-sm">filter_list</span>
                    Filter
                </button>
                <button id="btn-export-report" class="flex items-center gap-2 px-3 py-1.5 border border-slate-200 rounded-lg text-xs font-semibold hover:bg-slate-50">
                    <span class="material-symbols-outlined text-sm">download</span>
                    Export
                </button>
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-slate-50 text-slate-500 text-xs font-bold uppercase tracking-wider">
                    <tr>
                        <th class="px-6 py-4">Transaction ID</th>
                        <th class="px-6 py-4">Patient / Vendor</th>
                        <th class="px-6 py-4">Category</th>
                        <th class="px-6 py-4">Date</th>
                        <th class="px-6 py-4">Amount</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4"></th>
                    </tr>
                </thead>
                <tbody id="transaction-body" class="divide-y divide-slate-100 text-sm">
                    <tr>
                        <td colspan="7" class="text-center py-10 animate-pulse">Loading transactions...</td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="p-4 border-t border-slate-200 flex items-center justify-between text-xs font-medium text-slate-500">
            <span id="showing-text">Showing 0 of 0 transactions</span>
            <div id="pagination-container" class="flex gap-2">
                <!-- Controls via script -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const API_BASE = "@ViewData["ApiBaseUrl"]";
    const BASE_URL = `${API_BASE}/api/Admin`;
    let currentPage = 1;
    const pageSize = 5;

    const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);

    document.addEventListener("DOMContentLoaded", () => {
        loadFinancialStats();
        initDashboard("last6months");
        loadTransactions(1);

        const periodSelect = document.getElementById('revenue-period-select');
        periodSelect.addEventListener('change', (e) => {
            initDashboard(e.target.value);
        });

        const btnExport = document.getElementById('btn-export-report');
        btnExport.addEventListener('click', async () => {
            const originalContent = btnExport.innerHTML;
            btnExport.innerHTML = `<span class="animate-spin material-symbols-outlined text-[18px]">sync</span> <span>Exporting...</span>`;
            btnExport.disabled = true;

            try {
                const response = await fetch(`${BASE_URL}/export-financial-report`);
                if (!response.ok) throw new Error('Export failed');
                const blob = await response.blob();
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `Financial_Report_${new Date().toISOString().split('T')[0]}.xlsx`;
                document.body.appendChild(a);
                a.click();
                window.URL.revokeObjectURL(url);
                document.body.removeChild(a);
            } catch (error) {
                console.error(error);
                alert("Lỗi khi xuất báo cáo!");
            } finally {
                btnExport.innerHTML = originalContent;
                btnExport.disabled = false;
            }
        });
    });

    async function loadFinancialStats() {
        try {
            const res = await fetch(`${BASE_URL}/financial-stats`);
            const data = await res.json();
            document.getElementById('total-revenue').innerText = formatCurrency(data.totalRevenue);
            document.getElementById('total-expenses').innerText = formatCurrency(data.operationalExpenses);
            document.getElementById('net-profit').innerText = formatCurrency(data.netProfit);
            document.getElementById('prev-revenue-text').innerText = `vs. ${formatCurrency(data.prevRevenue || 0)} last month`;
            document.getElementById('prev-expenses-text').innerText = `vs. ${formatCurrency(data.prevExpenses || 0)} last month`;
            document.getElementById('prev-profit-text').innerText = `vs. ${formatCurrency(data.prevProfit || 0)} last month`;
            updateBadge('revenue-growth-badge', data.revenueGrowth);
            updateBadge('expenses-growth-badge', data.expensesGrowth);
            updateBadge('profit-growth-badge', data.profitGrowth);
        } catch (e) { console.error("Lỗi:", e); }
    }

    function updateBadge(id, value) {
        const badge = document.getElementById(id);
        if (!badge) return;
        const isPositive = value >= 0;
        badge.innerText = (isPositive ? '+' : '') + value + '%';
        badge.className = isPositive ? "bg-emerald-100 text-emerald-700 text-xs font-bold px-2 py-1 rounded-full" : "bg-red-100 text-red-700 text-xs font-bold px-2 py-1 rounded-full";
    }

    async function loadTransactions(page) {
        currentPage = page;
        const tbody = document.getElementById('transaction-body');
        const showingText = document.getElementById('showing-text');
        const paginationContainer = document.getElementById('pagination-container');
        tbody.innerHTML = '<tr><td colspan="7" class="text-center py-10 animate-pulse">Loading transactions...</td></tr>';
        try {
            const res = await fetch(`${BASE_URL}/transactions?page=${page}&pageSize=${pageSize}`);
            const result = await res.json();
            tbody.innerHTML = '';
            if (!result.data || result.data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" class="text-center py-10 text-slate-400">No transactions found</td></tr>';
                showingText.innerText = "Showing 0 of 0 transactions";
                paginationContainer.innerHTML = '';
                return;
            }
            result.data.forEach(t => {
                const isIncome = t.type === 'Income';
                const statusClass = t.status === 'COMPLETED' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700';
                tbody.innerHTML += `
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4 font-medium text-slate-900">${t.transactionId}</td>
                        <td class="px-6 py-4">${t.entityName}</td>
                        <td class="px-6 py-4 text-slate-500">${t.category}</td>
                        <td class="px-6 py-4 text-slate-500">${new Date(t.date).toLocaleDateString()}</td>
                        <td class="px-6 py-4 font-semibold ${isIncome ? 'text-emerald-600' : 'text-red-600'}">
                            ${isIncome ? '+' : '-'}${formatCurrency(t.amount)}
                        </td>
                        <td class="px-6 py-4">
                            <span class="${statusClass} text-[10px] font-bold px-2 py-0.5 rounded-full">${t.status}</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <button class="text-slate-400 hover:text-primary"><span class="material-symbols-outlined">more_vert</span></button>
                        </td>
                    </tr>`;
            });
            const startIdx = (page - 1) * pageSize + 1;
            const endIdx = startIdx + result.data.length - 1;
            showingText.innerHTML = `Showing ${startIdx} to ${endIdx} of ${result.totalRecords} transactions`;
            renderPagination(result.totalPages, page);
        } catch (e) {
            console.error("Lỗi khi load bảng giao dịch:", e);
            tbody.innerHTML = '<tr><td colspan="7" class="text-center py-10 text-red-500">Failed to load data.</td></tr>';
        }
    }

    function renderPagination(total, current) {
        const container = document.getElementById('pagination-container');
        if(!container) return;
        container.innerHTML = `
            <button onclick="loadTransactions(${current - 1})" ${current === 1 ? 'disabled' : ''} class="px-3 py-1 border rounded hover:bg-slate-50 disabled:opacity-50 transition-colors">Previous</button>
            <span class="px-3 py-1 text-xs font-bold text-primary bg-primary/10 rounded">Page ${current} of ${total}</span>
            <button onclick="loadTransactions(${current + 1})" ${current === total || total === 0 ? 'disabled' : ''} class="px-3 py-1 border rounded hover:bg-slate-50 disabled:opacity-50 transition-colors">Next</button>
        `;
    }

    async function initDashboard(period = "last6months") {
        try {
            const res = await fetch(`${BASE_URL}/financial-analytics?period=${period}`);
            const data = await res.json();
            updateSvgChart(data.revenueTrends);
            updateExpenseBars(data.expenseBreakdown);
        } catch (e) {
            console.error("Lỗi tải dữ liệu biểu đồ:", e);
        }
    }

    function updateSvgChart(trends) {
        if (!trends || trends.length === 0) return;
        const container = document.getElementById('revenue-chart-container');
        const pathLine = container.querySelector('svg path:first-of-type');
        const pathArea = container.querySelector('svg path:last-of-type');
        const labelsContainer = container.querySelector('div.flex.justify-between');
        const width = 400;
        const height = 120;
        const maxVal = Math.max(...trends.map(t => t.value)) * 1.2 || 1000;
        labelsContainer.innerHTML = trends.map(t => `<span class="text-[10px] font-bold text-slate-400 uppercase">${t.label}</span>`).join('');
        let startTime = null;
        const duration = 1000;
        function animate(timestamp) {
            if (!startTime) startTime = timestamp;
            let progress = (timestamp - startTime) / duration;
            if (progress > 1) progress = 1;
            const points = trends.map((t, i) => ({
                x: i * (width / (trends.length - 1)),
                y: 150 - ((t.value * progress) / maxVal * height) - 20
            }));
            let d = `M ${points[0].x} ${points[0].y}`;
            for (let i = 0; i < points.length - 1; i++) {
                const midX = (points[i].x + points[i + 1].x) / 2;
                d += ` Q ${midX} ${points[i].y}, ${points[i + 1].x} ${points[i + 1].y}`;
            }
            pathLine.setAttribute('d', d);
            pathArea.setAttribute('d', `${d} V 150 H 0 Z`);
            if (progress < 1) requestAnimationFrame(animate);
        }
        requestAnimationFrame(animate);
    }

    function updateExpenseBars(breakdown) {
        const container = document.getElementById('expenses-category-list');
        container.innerHTML = breakdown.map((item, i) => `
            <div>
                <div class="flex justify-between text-sm mb-1">
                    <span class="text-slate-600">${item.name}</span>
                    <span class="font-bold">${formatCurrency(item.amount)} (${item.percentage}%)</span>
                </div>
                <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
                    <div id="bar-${i}" class="h-full bg-primary rounded-full transition-all duration-1000" style="width: 0%"></div>
                </div>
            </div>
        `).join('');
        
        breakdown.forEach((item, i) => {
            setTimeout(() => {
                const bar = document.getElementById(`bar-${i}`);
                if (bar) bar.style.width = `${item.percentage}%`;
            }, 100);
        });
    }
</script>
}
