    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#0d9488",
                        "primary-hover": "#0f766e",
                        "accent-blue": "#3b82f6",
                        "background-light": "#f0fdfa",
