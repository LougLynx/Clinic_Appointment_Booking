<script>
    const API_BASE = "@ViewData["ApiBaseUrl"]";
    const BASE_URL = `${API_BASE}/api/Admin`;
    let currentPage = 1;
    const pageSize = 5;

    document.addEventListener("DOMContentLoaded", function () {
        loadPatientStats();
        loadPatients(1);

        document.getElementById('sort-filter').addEventListener('change', () => {
        loadPatients(1); // Khi đổi kiểu sort, quay về trang 1
    });

        // Search logic
        document.getElementById('patient-search').addEventListener('input', debounce((e) => {
            loadPatients(1, e.target.value);
        }, 500));
    });

    async function loadPatientStats() {
        try {
            const res = await fetch(`${BASE_URL}/patients-stats`);
            const stats = await res.json();
            document.getElementById('stat-total-patients').innerText = stats.totalPatients.toLocaleString();
            document.getElementById('stat-new-month').innerText = stats.newThisMonth;
            document.getElementById('stat-pending-followup').innerText = stats.pendingFollowUp;
            document.getElementById('stat-active-week').innerText = stats.activeThisWeek;
        } catch (e) { console.error("Error loading stats:", e); }
    }

    async function loadPatients(page = 1, search = "") {
        currentPage = page;
        const tbody = document.getElementById('patientTableBody');
        const sortBy = document.getElementById('sort-filter').value;

    // Lấy giá trị Search nếu không được truyền vào
    if (arguments.length < 2) {
        search = document.getElementById('patient-search').value;
    }
        tbody.innerHTML = '<tr><td colspan="6" class="text-center py-10 text-slate-400 font-medium animate-pulse">Loading patient records...</td></tr>';

        try {
            const url = `${BASE_URL}/patients?search=${encodeURIComponent(search)}&page=${page}&pageSize=${pageSize}&sortBy=${encodeURIComponent(sortBy)}`;
            const res = await fetch(url);
            const result = await res.json();

            tbody.innerHTML = '';
            if (result.data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center py-10 text-slate-400">No patient records found.</td></tr>';
                return;
            }

               result.data.forEach(p => {
        let dateDisplay = '--/--/----';
        if (p.lastVisitDate && !p.lastVisitDate.startsWith('0001')) {
            dateDisplay = new Date(p.lastVisitDate).toLocaleDateString('en-GB');
        }
        const physicianImg = p.physicianImage || `https://ui-avatars.com/api/?name=${encodeURIComponent(p.primaryPhysician)}&background=random`;

        // Kiểm tra trạng thái Active từ dữ liệu trả về
        const isUserActive = p.status === 'Active';

        tbody.innerHTML += `
            <tr class="hover:bg-slate-50 transition-colors border-b border-slate-100 last:border-none">
                <td class="px-6 py-4 text-sm font-mono text-slate-500">#PT-${p.patientId.toString().padStart(4, '0')}</td>
                <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-primary text-xs font-bold">${p.fullName.charAt(0)}</div>
                        <div>
                            <p class="text-sm font-bold text-slate-900">${p.fullName}</p>
                            <p class="text-xs text-slate-500">${p.email}</p>
                        </div>
                    </div>
                </td>
                <td class="px-6 py-4 text-sm font-medium text-slate-700">${dateDisplay}</td>
                <td class="px-6 py-4">
                    <div class="flex items-center gap-2">
                        <img src="${physicianImg}" class="w-6 h-6 rounded-full object-cover">
                        <span class="text-sm font-medium text-slate-600">${p.primaryPhysician || 'None'}</span>
                    </div>
                </td>
                <td class="px-6 py-4">
                    <div id="status-badge-${p.patientId}">
                        <span class="px-2.5 py-0.5 rounded-full text-xs font-bold ${isUserActive ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600'}">
                            ${isUserActive ? 'Active' : 'Inactive'}
                        </span>
                    </div>
                </td>
                <td class="px-6 py-4 text-right">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" value="" class="sr-only peer" ${isUserActive ? 'checked' : ''}
                                   onchange="togglePatientActive(${p.patientId}, this)">
                            <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                        </label>
                    </td>
            </tr>`;
    });

            renderPagination(result.totalPages, result.currentPage, search);

            // Cập nhật text hiển thị số lượng
            const startRange = result.totalRecords === 0 ? 0 : (page - 1) * pageSize + 1;
            const endRange = Math.min(page * pageSize, result.totalRecords);
            document.getElementById('showing-info').innerText = `Showing ${startRange} to ${endRange} of ${result.totalRecords} patients`;

        } catch (e) { console.error("Error loading patients:", e); }
    }

    // HOÀN THIỆN PHÂN TRANG
    function renderPagination(totalPages, current, search) {
        const container = document.getElementById('pagination-controls');
        container.innerHTML = '';
        if (totalPages <= 1) return;

        const btnClass = "px-3 py-1 rounded-md text-xs font-bold transition-all border ";
        const activeClass = "bg-primary text-white border-primary shadow-sm";
        const inactiveClass = "bg-white text-slate-600 border-slate-200 hover:bg-slate-50";

        // Nút Previous
        container.innerHTML += `
            <button onclick="loadPatients(${current - 1}, '${search}')" ${current === 1 ? 'disabled' : ''}
                    class="${btnClass} ${inactiveClass} disabled:opacity-30">
                <span class="material-symbols-outlined text-sm">chevron_left</span>
            </button>`;

        // Thuật toán hiển thị số trang (1 ... 4 5 6 ... 10)
        let pages = [];
        if (totalPages <= 7) {
            for (let i = 1; i <= totalPages; i++) pages.push(i);
        } else {
            if (current <= 4) {
                pages = [1, 2, 3, 4, 5, '...', totalPages];
            } else if (current >= totalPages - 3) {
                pages = [1, '...', totalPages - 4, totalPages - 3, totalPages - 2, totalPages - 1, totalPages];
            } else {
                pages = [1, '...', current - 1, current, current + 1, '...', totalPages];
            }
        }

        pages.forEach(p => {
            if (p === '...') {
                container.innerHTML += `<span class="text-slate-400 px-1 text-xs">...</span>`;
            } else {
                container.innerHTML += `
                    <button onclick="loadPatients(${p}, '${search}')"
                            class="${btnClass} ${p === current ? activeClass : inactiveClass}">
                        ${p}
                    </button>`;
            }
        });

        // Nút Next
        container.innerHTML += `
            <button onclick="loadPatients(${current + 1}, '${search}')" ${current === totalPages ? 'disabled' : ''}
                    class="${btnClass} ${inactiveClass} disabled:opacity-30">
                <span class="material-symbols-outlined text-sm">chevron_right</span>
            </button>`;
    }

        async function togglePatientActive(patientId, checkbox) {
        const originalState = !checkbox.checked;

        try {
            const res = await fetch(`${BASE_URL}/users/${patientId}/toggle-status`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' }
            });

            if (!res.ok) throw new Error("Update failed");

            // Cập nhật Badge trạng thái ngay lập tức mà không load lại bảng
            const badgeContainer = document.getElementById(`status-badge-${patientId}`);
            const isActive = checkbox.checked;

            badgeContainer.innerHTML = `
                <span class="px-2.5 py-0.5 rounded-full text-xs font-bold ${isActive ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600'}">
                    ${isActive ? 'Active' : 'Inactive'}
                </span>
            `;

            // Cập nhật lại các con số thống kê ở trên đầu
            loadPatientStats();

        } catch (e) {
            console.error(e);
            alert("Could not update patient status.");
            checkbox.checked = originalState; // Hoàn tác nếu lỗi
        }
    }

    function debounce(func, timeout = 300) {
        let timer;
        return (...args) => {
            clearTimeout(timer);
            timer = setTimeout(() => { func.apply(this, args); }, timeout);
        };
    }
</script>