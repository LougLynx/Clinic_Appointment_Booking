@model AppointmentConfirmViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Confirm Appointment";
    Layout = "_LayoutMediClinic";

    var dateText = Model.AppointmentDate.ToString("dddd, MMMM dd, yyyy", System.Globalization.CultureInfo.InvariantCulture);
    var timeText = DateTime.Today.Add(Model.AppointmentTime).ToString("hh:mm tt", System.Globalization.CultureInfo.InvariantCulture);
    var feeText = Model.Doctor.ConsultationFee.HasValue ? $"${Model.Doctor.ConsultationFee.Value:N2}" : "Contact for pricing";
    var patientName = string.IsNullOrWhiteSpace(Model.PatientName) ? "Patient" : Model.PatientName;
    
    // Dữ liệu cho API - format ISO date và time
    var appointmentApiData = new {
        doctorId = Model.Doctor.DoctorId,
        appointmentDate = Model.AppointmentDate.ToString("yyyy-MM-dd"),
        appointmentTime = Model.AppointmentTime.ToString(@"hh\:mm\:ss"),
        reasonForVisit = Model.Reason,
        additionalNotes = Model.Notes ?? "",
        isFirstTime = Model.IsFirstTime,
        consultationFee = Model.Doctor.ConsultationFee ?? 0
    };
}
<!-- Anti-forgery token for AJAX -->
@Html.AntiForgeryToken()
<!-- Appointment data for API call -->
<script id="appointmentApiData" type="application/json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(appointmentApiData))</script>

<!-- Page Header with Progress Steps -->
<div class="mb-8 flex flex-col items-center justify-center px-4">
    <h1 class="text-3xl md:text-4xl font-black leading-tight tracking-tight mb-6 text-slate-900 dark:text-white text-center">Book an Appointment</h1>
    
    <!-- Progress Indicator - Step 3 -->
    <div class="w-full max-w-3xl flex items-center justify-between relative">
        <div class="absolute left-0 top-1/2 -translate-y-1/2 w-full h-1 bg-primary -z-10 rounded-full"></div>
        
        <div class="flex flex-col items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-primary text-white font-bold flex items-center justify-center border-4 border-white dark:border-background-dark shadow-sm">
                <span class="material-symbols-outlined text-sm">check</span>
            </div>
            <span class="text-xs font-semibold text-primary">Date &amp; Time</span>
        </div>
        <div class="flex flex-col items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-primary text-white font-bold flex items-center justify-center border-4 border-white dark:border-background-dark shadow-sm">
                <span class="material-symbols-outlined text-sm">check</span>
            </div>
            <span class="text-xs font-semibold text-primary">Patient Info</span>
        </div>
        <div class="flex flex-col items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-primary text-white font-bold flex items-center justify-center border-4 border-white dark:border-background-dark shadow-sm">3</div>
            <span class="text-xs font-semibold text-primary">Confirmation</span>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="flex flex-col lg:flex-row gap-8 px-4">
    <!-- Left Column - Confirmation Form -->
    <div class="flex-1 flex flex-col gap-8">
        <!-- Insurance Information -->
        <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-700 shadow-sm">
            <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">shield</span>
                Insurance Information
            </h2>
            
            <div class="space-y-6">
                <!-- Insurance Toggle -->
                <div class="flex items-center justify-between p-4 border border-slate-200 dark:border-slate-700 rounded-xl bg-slate-50 dark:bg-slate-800/50">
                    <div>
                        <h3 class="font-semibold text-slate-900 dark:text-white">Will you be using insurance?</h3>
                        <p class="text-sm text-slate-500 dark:text-slate-400">Select yes to provide your insurance details for billing.</p>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input checked class="sr-only peer" type="checkbox" />
                        <span class="inline-block w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-primary/30 dark:peer-focus:ring-primary/20 rounded-full peer dark:bg-slate-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-slate-600 peer-checked:bg-primary"></span>
                    </label>
                </div>

                <!-- Insurance Form Fields -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" for="insurance-provider">Insurance Provider</label>
                        <select class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-primary focus:border-primary shadow-sm" id="insurance-provider">
                            <option value="bluecross">Blue Cross Blue Shield</option>
                            <option value="aetna">Aetna</option>
                            <option value="cigna">Cigna</option>
                            <option value="united">UnitedHealthcare</option>
                            <option value="medicare">Medicare</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" for="member-id">Member ID</label>
                        <input class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-primary focus:border-primary shadow-sm placeholder:text-slate-400" 
                               id="member-id" 
                               placeholder="e.g. ABC123456789" 
                               type="text" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" for="group-number">Group Number</label>
                        <input class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-primary focus:border-primary shadow-sm placeholder:text-slate-400" 
                               id="group-number" 
                               placeholder="e.g. 123456" 
                               type="text" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" for="policy-holder">Policy Holder Name</label>
                        <input class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-primary focus:border-primary shadow-sm placeholder:text-slate-400" 
                               id="policy-holder" 
                               placeholder="Full Name" 
                               type="text" 
                               value="@patientName" />
                    </div>
                </div>

                <!-- Info Notice -->
                <div class="p-4 bg-teal-50 dark:bg-teal-900/20 border border-teal-100 dark:border-teal-800 rounded-xl flex items-start gap-3">
                    <span class="material-symbols-outlined text-teal-600 dark:text-teal-400 mt-0.5">info</span>
                    <p class="text-sm text-teal-800 dark:text-teal-300">
                        Your insurance information will be verified prior to your appointment. You may be required to present your physical card at the clinic.
                    </p>
                </div>
            </div>
        </div>

        <!-- Review Details -->
        <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-700 shadow-sm">
            <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">fact_check</span>
                Review Details
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pb-6 border-b border-slate-100 dark:border-slate-800">
                <div>
                    <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Patient Details</h3>
                    <p class="font-medium text-slate-900 dark:text-white">@patientName</p>
                    @if (!string.IsNullOrWhiteSpace(Model.PatientEmail))
                    {
                        <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">@Model.PatientEmail</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.PatientPhone))
                    {
                        <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">@Model.PatientPhone</p>
                    }
                </div>
                <div>
                    <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Visit Information</h3>
                    <p class="font-medium text-slate-900 dark:text-white">Reason: @Model.Reason</p>
                    <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">Status: @(Model.IsFirstTime ? "First-time patient" : "Returning patient")</p>
                    @if (!string.IsNullOrWhiteSpace(Model.Notes))
                    {
                        <p class="text-sm text-slate-600 dark:text-slate-400 mt-1 italic">"@Model.Notes"</p>
                    }
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex justify-between items-center border-t border-slate-200 dark:border-slate-800 pt-6">
            <a asp-area="" asp-controller="Appointment" asp-action="Book" asp-route-doctorId="@Model.Doctor.DoctorId" asp-route-date="@Model.AppointmentDate.ToString("yyyy-MM-dd")" asp-route-time="@Model.AppointmentTime.ToString(@"hh\:mm")"
               class="px-6 py-3 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 font-semibold hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors flex items-center gap-2 no-underline">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                Back
            </a>
        </div>
    </div>

    <!-- Right Column - Final Summary & Confirm -->
    <aside class="w-full lg:w-[350px] shrink-0">
        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-md sticky top-24 overflow-hidden">
            <!-- Doctor Info -->
            <div class="p-6 border-b border-slate-100 dark:border-slate-800">
                <h3 class="font-bold text-slate-900 dark:text-white text-lg mb-4">Appointment Summary</h3>
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-16 h-16 rounded-full overflow-hidden bg-slate-200 dark:bg-slate-800 shrink-0 border-2 border-primary/20">
                        @if (!string.IsNullOrEmpty(Model.Doctor.ProfilePictureUrl))
                        {
                            <img alt="@Model.Doctor.FullName" class="w-full h-full object-cover" src="@Model.Doctor.ProfilePictureUrl" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center text-slate-400 text-sm font-semibold">
                                @(string.IsNullOrEmpty(Model.Doctor.FullName) ? "?" : Model.Doctor.FullName.Substring(0, 1))
                            </div>
                        }
                    </div>
                    <div>
                        <h4 class="font-bold text-slate-900 dark:text-white text-base">@Model.Doctor.FullName</h4>
                        <p class="text-sm text-primary font-medium">@Model.Doctor.SpecialtyName</p>
                        <div class="flex items-center gap-1 mt-1 text-xs text-slate-500">
                            <span class="material-symbols-outlined text-[14px] text-yellow-400" style="font-variation-settings: 'FILL' 1;">star</span>
                            <span>@Model.Doctor.Rating.ToString("0.0") (@Model.Doctor.ReviewCount reviews)</span>
                        </div>
                    </div>
                </div>
                <div class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-400 mt-4">
                    <span class="material-symbols-outlined text-[18px] text-slate-400 mt-0.5">location_on</span>
                    <span>@(string.IsNullOrEmpty(Model.Doctor.Location) ? "Location not provided" : Model.Doctor.Location)</span>
                </div>
            </div>

            <!-- Appointment Details -->
            <div class="p-6 bg-slate-50 dark:bg-slate-800/30 border-b border-slate-100 dark:border-slate-800">
                <div class="space-y-4">
                    <div class="flex items-start gap-3">
                        <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-blue-600 dark:text-blue-400 shrink-0">
                            <span class="material-symbols-outlined text-[18px]">calendar_today</span>
                        </div>
                        <div>
                            <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">Date</p>
                            <p class="text-sm font-semibold text-slate-900 dark:text-white">@dateText</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <div class="w-8 h-8 rounded-full bg-teal-100 dark:bg-teal-900/30 flex items-center justify-center text-teal-600 dark:text-teal-400 shrink-0">
                            <span class="material-symbols-outlined text-[18px]">schedule</span>
                        </div>
                        <div>
                            <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">Time</p>
                            <p class="text-sm font-semibold text-slate-900 dark:text-white">@timeText</p>
                            <p class="text-xs text-slate-500 mt-0.5">Estimated duration: 30-45 min</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <div class="w-8 h-8 rounded-full bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-purple-600 dark:text-purple-400 shrink-0">
                            <span class="material-symbols-outlined text-[18px]">payments</span>
                        </div>
                        <div>
                            <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">Consultation Fee</p>
                            <p class="text-sm font-semibold text-slate-900 dark:text-white">@feeText</p>
                            <p class="text-xs text-slate-500 mt-0.5">Insurance Applied (Copay pending)</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Payment Method Selection -->
            <div class="p-6 border-b border-slate-100 dark:border-slate-800">
                <h3 class="font-bold text-slate-900 dark:text-white text-base mb-4">Payment Method</h3>
                
                <div class="space-y-3">
                    <!-- VNPay Payment (REAL) -->
                    <label class="flex items-center gap-3 p-4 border-2 border-slate-200 dark:border-slate-700 rounded-xl cursor-pointer hover:border-primary transition-colors payment-option" data-payment="vnpay">
                        <input type="radio" name="paymentMethod" value="vnpay" class="w-5 h-5 text-primary focus:ring-primary" checked />
                        <span class="flex-1 block">
                            <span class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-[#ef5323]">account_balance_wallet</span>
                                <span class="font-semibold text-slate-900 dark:text-white">VNPay Online Payment</span>
                            </span>
                            <span class="block text-xs text-slate-500 dark:text-slate-400 mt-1">International & Domestic cards, VNPay QR</span>
                        </span>
                    </label>
                    
                    <!-- Pay Later -->
                    <label class="flex items-center gap-3 p-4 border-2 border-slate-200 dark:border-slate-700 rounded-xl cursor-pointer hover:border-primary transition-colors payment-option" data-payment="later">
                        <input type="radio" name="paymentMethod" value="later" class="w-5 h-5 text-primary focus:ring-primary" />
                        <span class="flex-1 block">
                            <span class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary">schedule</span>
                                <span class="font-semibold text-slate-900 dark:text-white">Pay at Clinic</span>
                            </span>
                            <span class="block text-xs text-slate-500 dark:text-slate-400 mt-1">Pay when you arrive for appointment</span>
                        </span>
                    </label>
                </div>
            </div>

            <!-- Pay Later Section (hidden by default) -->
            <div id="payLaterSection" class="p-6 border-b border-slate-100 dark:border-slate-800 hidden">
                <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-100 dark:border-amber-800 rounded-xl p-4">
                    <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-amber-600 dark:text-amber-400">schedule</span>
                        <div>
                            <h4 class="font-semibold text-amber-900 dark:text-amber-300 text-sm mb-1">Payment at Clinic</h4>
                            <p class="text-xs text-amber-800 dark:text-amber-400">
                                Please arrive 15 minutes early to complete payment at the reception desk. 
                                We accept cash, credit cards, and debit cards.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Final Confirmation -->
            <div class="p-6">
                <div class="flex justify-between items-center mb-6">
                    <span class="text-base font-semibold text-slate-700 dark:text-slate-300">Total Amount:</span>
                    <span class="text-2xl font-black text-slate-900 dark:text-white">@feeText</span>
                </div>
                
                <div class="flex items-start gap-3 mb-6">
                    <input class="mt-1 w-4 h-4 rounded border-slate-300 text-primary focus:ring-primary dark:border-slate-600 dark:bg-slate-800" 
                           id="terms" 
                           type="checkbox" />
                    <label class="text-xs text-slate-600 dark:text-slate-400 leading-snug" for="terms">
                        I agree to the <a href="#" class="text-primary hover:underline">Terms &amp; Conditions</a> and understand the cancellation policy.
                    </label>
                </div>
                
                <button id="confirmButton" class="w-full px-8 py-3 rounded-lg bg-primary text-white font-bold hover:bg-primary/90 transition-colors shadow-md flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
                    <span class="material-symbols-outlined text-[20px]">check_circle</span>
                    <span id="confirmButtonText">Confirm Appointment</span>
                </button>
                
                <p class="text-xs text-center text-slate-500 dark:text-slate-400 mt-3">
                    You will receive a confirmation email shortly
                </p>
            </div>
        </div>
    </aside>
</div>

<form id="antiforgeryForm" style="display:none">@Html.AntiForgeryToken()</form>
<script id="appointmentData" type="application/json">@Html.Raw(JsonSerializer.Serialize(appointmentApiData))</script>

@section Scripts {
    <script>
        (function() {
            const payLaterSection = document.getElementById('payLaterSection');
            const confirmButton = document.getElementById('confirmButton');
            const confirmButtonText = document.getElementById('confirmButtonText');
            const termsCheckbox = document.getElementById('terms');
            const paymentOptions = document.querySelectorAll('.payment-option');
            
            let selectedPaymentMethod = 'vnpay';
            
            // Handle payment method selection
            document.querySelectorAll('input[name="paymentMethod"]').forEach(radio => {
                radio.addEventListener('change', function() {
                    selectedPaymentMethod = this.value;
                    
                    // Update UI based on selection
                    if (selectedPaymentMethod === 'vnpay') {
                        payLaterSection.classList.add('hidden');
                        confirmButtonText.textContent = 'Pay with VNPay';
                    } else {
                        payLaterSection.classList.remove('hidden');
                        confirmButtonText.textContent = 'Confirm Appointment';
                    }
                    
                    // Update border colors
                    paymentOptions.forEach(option => {
                        const radio = option.querySelector('input[type="radio"]');
                        if (radio.checked) {
                            option.classList.add('border-primary', 'bg-primary/5');
                            option.classList.remove('border-slate-200', 'dark:border-slate-700');
                        } else {
                            option.classList.remove('border-primary', 'bg-primary/5');
                            option.classList.add('border-slate-200', 'dark:border-slate-700');
                        }
                    });
                });
            });
            
            // Initialize selected option
            document.querySelector('input[name="paymentMethod"]:checked')?.dispatchEvent(new Event('change'));
            
            // Handle terms checkbox
            termsCheckbox.addEventListener('change', function() {
                confirmButton.disabled = !this.checked;
            });
            
            // Handle confirm button click
            confirmButton.addEventListener('click', function(e) {
                e.preventDefault();
                
                if (!termsCheckbox.checked) {
                    alert('Please agree to the Terms & Conditions');
                    return;
                }
                
                if (selectedPaymentMethod === 'vnpay') {
                    // VNPay - REAL Integration
                    initiateVNPay();
                } else {
                    // Proceed with pay later
                    submitAppointment('pay_later');
                }
            });
            
            async function initiateVNPay() {
                const fee = "@(Model.Doctor.ConsultationFee ?? 0)";
                const reference = "@Model.PaymentReference";
                const tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');

                try {
                    confirmButton.disabled = true;
                    confirmButtonText.textContent = 'Connecting to VNPay...';
                    
                    const formData = new FormData();
                    formData.append('amount', fee);
                    formData.append('reference', reference);
                    formData.append('__RequestVerificationToken', tokenEl.value);

                    const response = await fetch('/Appointment/CreatePaymentUrl', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    if (result.success && result.url) {
                        window.location.href = result.url;
                    } else {
                        alert(result.message || 'Failed to initiate VNPay payment');
                        confirmButton.disabled = false;
                        confirmButtonText.textContent = 'Pay with VNPay';
                    }
                } catch (err) {
                    console.error(err);
                    alert('An error occurred. Please try again.');
                    confirmButton.disabled = false;
                    confirmButtonText.textContent = 'Pay with VNPay';
                }
            }
            
            function showProcessingModal() {
                const modal = document.createElement('div');
                modal.className = 'fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4';
                modal.setAttribute('data-modal', 'processing');
                modal.innerHTML = `
                    <div class="bg-white dark:bg-slate-900 rounded-2xl max-w-md w-full p-6 shadow-2xl text-center">
                        <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center mx-auto mb-4">
                            <span class="material-symbols-outlined text-blue-600 dark:text-blue-400 text-3xl">hourglass_empty</span>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">Processing</h3>
                        <p class="text-sm text-slate-600 dark:text-slate-400 mb-6">
                            Confirming your appointment. Please wait...
                        </p>
                        <div class="flex items-center justify-center gap-2">
                            <div class="w-2 h-2 bg-primary rounded-full animate-bounce" style="animation-delay: 0ms"></div>
                            <div class="w-2 h-2 bg-primary rounded-full animate-bounce" style="animation-delay: 150ms"></div>
                            <div class="w-2 h-2 bg-primary rounded-full animate-bounce" style="animation-delay: 300ms"></div>
                        </div>
                    </div>
                `;
                document.body.appendChild(modal);
                return modal;
            }

            async function submitAppointment(paymentStatus, options) {
                const processingModal = options?.processingModal;
                const dataEl = document.getElementById('appointmentApiData');
                const tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
                if (!dataEl || !tokenEl) {
                    if (processingModal) processingModal.remove();
                    alert('Missing appointment data. Please go back and try again.');
                    return;
                }
                
                let requestData;
                try {
                    requestData = JSON.parse(dataEl.textContent || '{}');
                } catch (e) {
                    if (processingModal) processingModal.remove();
                    alert('Invalid appointment data. Please go back and try again.');
                    return;
                }
                
                confirmButton.disabled = true;
                confirmButtonText.textContent = 'Saving...';
                
                try {
                    const response = await fetch('/Appointment/ConfirmBook', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': tokenEl.value
                        },
                        body: JSON.stringify(requestData)
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        if (processingModal) processingModal.remove();
                        const successModal = document.createElement('div');
                        successModal.className = 'fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4';
                        successModal.innerHTML = `
                            <div class="bg-white dark:bg-slate-900 rounded-2xl max-w-md w-full p-6 shadow-2xl text-center">
                                <div class="w-16 h-16 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center mx-auto mb-4">
                                    <span class="material-symbols-outlined text-green-600 dark:text-green-400 text-3xl">check_circle</span>
                                </div>
                                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">Appointment Confirmed!</h3>
                                <p class="text-sm text-slate-600 dark:text-slate-400 mb-2">
                                    Your appointment has been booked successfully.
                                </p>
                                ${paymentStatus === 'pay_later' ? 
                                    `<p class="text-sm text-amber-600 dark:text-amber-400 mb-6"><span class="material-symbols-outlined text-[16px] align-middle">schedule</span> Remember to pay at the clinic</p>` : 
                                    `<p class="text-sm text-slate-600 dark:text-slate-400 mb-6">Payment will be verified automatically.</p>`}
                                <button onclick="window.location.href='/Appointment/MyAppointments'" class="w-full px-6 py-3 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors font-semibold">
                                    View My Appointments
                                </button>
                            </div>
                        `;
                        document.body.appendChild(successModal);
                    } else {
                        if (processingModal) processingModal.remove();
                        alert(result.message || 'Failed to create appointment. Please try again.');
                        confirmButton.disabled = false;
                        confirmButtonText.textContent = selectedPaymentMethod === 'vnpay' ? 'Pay with VNPay' : 'Confirm Appointment';
                    }
                } catch (err) {
                    console.error(err);
                    if (processingModal) processingModal.remove();
                    alert('An error occurred. Please try again.');
                    confirmButton.disabled = false;
                    confirmButtonText.textContent = selectedPaymentMethod === 'vnpay' ? 'Pay with VNPay' : 'Confirm Appointment';
                }
            }
        })();
    </script>
}
