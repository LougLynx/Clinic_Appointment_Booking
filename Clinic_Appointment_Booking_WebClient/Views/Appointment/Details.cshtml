@using BussinessObjects.DTOs
@model AppointmentDTO
@{
    ViewData["Title"] = "Appointment Details";
    Layout = "_LayoutMediClinic";

    var dateText = Model.AppointmentDate.ToString("dddd, MMMM dd, yyyy");
    var timeText = DateTime.Today.Add(Model.AppointmentTime).ToString("hh:mm tt");
    var status = Model.Status ?? "Unknown";
    var statusClass = status.ToLowerInvariant() switch
    {
        "confirmed" => "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400",
        "pending" => "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400",
        "cancelled" => "bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400",
        "completed" => "bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-300",
        _ => "bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-300"
    };
    var appointmentDateTime = Model.AppointmentDate.Date.Add(Model.AppointmentTime);
    var isPast = appointmentDateTime < DateTime.Now;
    var isCancelled = status.Equals("cancelled", StringComparison.OrdinalIgnoreCase);
    var isCompleted = status.Equals("completed", StringComparison.OrdinalIgnoreCase);
    var canModify = !isPast && !isCancelled && !isCompleted;
}

<!-- Page Header -->
<div class="mb-8 px-4">
    <a asp-area="" asp-controller="Appointment" asp-action="MyAppointments"
       class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline mb-4 no-underline">
        <span class="material-symbols-outlined text-[20px]">arrow_back</span>
        Back to My Appointments
    </a>
    <h1 class="text-3xl md:text-4xl font-black leading-tight tracking-tight mb-2 text-slate-900 dark:text-white">Appointment Details</h1>
    <p class="text-slate-500 dark:text-slate-400 text-base">View your appointment information and manage your booking.</p>
</div>

<!-- Main Content -->
<div class="px-4">
    <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm overflow-hidden">
        <div class="p-6 lg:p-8">
            <!-- Status Badge -->
            <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
                <span class="px-4 py-2 rounded-full text-sm font-semibold @statusClass">@status</span>
                <span class="text-sm text-slate-500 dark:text-slate-400">
                    Booked on @Model.CreatedAt.ToString("MMM dd, yyyy")
                </span>
            </div>

            <!-- Doctor Info -->
            <div class="border-b border-slate-200 dark:border-slate-700 pb-6 mb-6">
                <h2 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Doctor</h2>
                <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                    <div class="w-16 h-16 rounded-full bg-primary/20 flex items-center justify-center flex-shrink-0">
                        <span class="material-symbols-outlined text-3xl text-primary">person</span>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-slate-900 dark:text-white">@Model.DoctorName</h3>
                        <p class="text-primary font-semibold">@Model.SpecialtyName</p>
                        <a asp-area="" asp-controller="Doctors" asp-action="Details" asp-route-id="@Model.DoctorId"
                           class="text-sm font-semibold text-primary hover:underline mt-1 inline-block no-underline">
                            View doctor profile
                        </a>
                    </div>
                </div>
            </div>

            <!-- Appointment Info -->
            <div class="grid gap-6 sm:grid-cols-2 mb-6">
                <div>
                    <span class="text-sm font-semibold text-slate-500 dark:text-slate-400 block mb-1">Date</span>
                    <p class="text-lg font-semibold text-slate-900 dark:text-white">@dateText</p>
                </div>
                <div>
                    <span class="text-sm font-semibold text-slate-500 dark:text-slate-400 block mb-1">Time</span>
                    <p class="text-lg font-semibold text-slate-900 dark:text-white">@timeText</p>
                </div>
                <div>
                    <span class="text-sm font-semibold text-slate-500 dark:text-slate-400 block mb-1">Reason for Visit</span>
                    <p class="text-slate-900 dark:text-white">@Model.ReasonForVisit</p>
                </div>
                <div>
                    <span class="text-sm font-semibold text-slate-500 dark:text-slate-400 block mb-1">Consultation Fee</span>
                    <p class="text-lg font-bold text-primary">@Model.ConsultationFee.ToString("C2")</p>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.AdditionalNotes))
            {
                <div class="mb-6">
                    <span class="text-sm font-semibold text-slate-500 dark:text-slate-400 block mb-2">Additional Notes</span>
                    <p class="text-slate-700 dark:text-slate-300 italic bg-slate-50 dark:bg-slate-800 rounded-lg p-4">"@Model.AdditionalNotes"</p>
                </div>
            }

            @if (Model.IsFirstTime)
            {
                <p class="text-sm text-slate-600 dark:text-slate-400 mb-6">
                    <span class="material-symbols-outlined text-[18px] align-middle mr-1">info</span>
                    This is your first visit with this doctor.
                </p>
            }

            <!-- Action Buttons -->
            <div class="flex flex-wrap gap-3 pt-6 border-t border-slate-200 dark:border-slate-700">
                @if (canModify)
                {
                    <a asp-area="" asp-controller="Appointment" asp-action="Edit" asp-route-id="@Model.AppointmentId"
                       class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary text-white font-bold rounded-lg hover:bg-primary/90 transition-colors no-underline">
                        <span class="material-symbols-outlined text-[20px]">edit</span>
                        Edit Appointment
                    </a>
                    <button type="button"
                            class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-rose-200 dark:border-rose-800 text-rose-600 dark:text-rose-400 font-bold rounded-lg hover:bg-rose-50 dark:hover:bg-rose-900/20 transition-colors"
                            data-cancel-button
                            data-appointment-id="@Model.AppointmentId"
                            data-appointment-title="@($"{Model.DoctorName} - {dateText} {timeText}")">
                        <span class="material-symbols-outlined text-[20px]">cancel</span>
                        Cancel Appointment
                    </button>
                }
                else
                {
                    <p class="text-sm text-slate-500 dark:text-slate-400">
                        @if (isCancelled)
                        {
                            <span>This appointment has been cancelled.</span>
                        }
                        else if (isCompleted)
                        {
                            <span>This appointment has been completed.</span>
                        }
                        else if (isPast)
                        {
                            <span>This appointment has passed. Editing and cancellation are no longer available.</span>
                        }
                    </p>
                }
            </div>
        </div>
    </div>
</div>

<form id="cancelForm" asp-action="Cancel" asp-controller="Appointment" method="post" class="hidden">
    @Html.AntiForgeryToken()
    <input type="hidden" id="cancelAppointmentId" name="appointmentId" />
    <input type="hidden" id="cancelReason" name="reason" />
</form>

<div id="cancelModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
    <div class="w-full max-w-md rounded-2xl bg-white dark:bg-slate-900 p-6 shadow-2xl border border-slate-200 dark:border-slate-700">
        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">Cancel Appointment</h3>
        <p class="text-sm text-slate-600 dark:text-slate-400 mb-4" id="cancelModalTitle"></p>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" for="cancelReasonInput">
            Reason (optional)
        </label>
        <textarea id="cancelReasonInput"
                  class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-rose-500 focus:border-rose-500 shadow-sm placeholder:text-slate-400"
                  rows="3"
                  placeholder="Let us know why you are cancelling"></textarea>
        <div class="mt-5 flex gap-3">
            <button type="button" id="cancelModalClose"
                    class="flex-1 px-4 py-2 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                Close
            </button>
            <button type="button" id="cancelModalConfirm"
                    class="flex-1 px-4 py-2 bg-rose-600 text-white rounded-lg hover:bg-rose-500 transition-colors">
                Cancel Appointment
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const cancelButton = document.querySelector('[data-cancel-button]');
            const modal = document.getElementById('cancelModal');
            const modalTitle = document.getElementById('cancelModalTitle');
            const reasonInput = document.getElementById('cancelReasonInput');
            const cancelIdInput = document.getElementById('cancelAppointmentId');
            const cancelReasonInput = document.getElementById('cancelReason');
            const cancelForm = document.getElementById('cancelForm');
            const closeBtn = document.getElementById('cancelModalClose');
            const confirmBtn = document.getElementById('cancelModalConfirm');

            if (!cancelButton || !modal || !cancelForm) return;

            cancelButton.addEventListener('click', function () {
                const appointmentId = cancelButton.getAttribute('data-appointment-id');
                const title = cancelButton.getAttribute('data-appointment-title') || '';
                if (modalTitle) modalTitle.textContent = title;
                if (reasonInput) reasonInput.value = '';
                if (cancelIdInput) cancelIdInput.value = appointmentId || '';
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            });

            function closeModal() {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }

            closeBtn?.addEventListener('click', closeModal);
            modal.addEventListener('click', function (event) {
                if (event.target === modal) closeModal();
            });

            confirmBtn?.addEventListener('click', function () {
                if (cancelReasonInput && reasonInput) {
                    cancelReasonInput.value = reasonInput.value.trim();
                }
                cancelForm.submit();
            });
        })();
    </script>
}
