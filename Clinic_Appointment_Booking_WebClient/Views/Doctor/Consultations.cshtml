@{
    ViewData["Title"] = "Active Consultation";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediClinic</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <!-- Inter Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    
    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#13b6ec",
                        "primary-dark": "#1e3a8a",
                        "primary-light": "#3b82f6",
                        "background-light": "#f8fafc",
                    },
                    fontFamily: {
                        "display": ["Inter", "Noto Sans", "sans-serif"]
                    },
                },
            },
        }
    </script>
</head>
<body class="bg-background-light text-slate-800 font-display">
    <div class="flex h-screen w-full overflow-hidden">
        <!-- Sidebar -->
        <aside class="w-64 bg-slate-900 text-white flex flex-col h-full flex-shrink-0">
            <!-- Logo -->
            <div class="h-16 flex items-center px-6 border-b border-slate-800">
                <span class="material-symbols-outlined text-2xl mr-3 text-primary">local_hospital</span>
                <span class="text-xl font-bold tracking-wide">MediClinic</span>
            </div>

            <!-- Navigation Menu -->
            <div class="p-6 pb-2 flex-1 overflow-y-auto">
                <p class="text-xs text-slate-400 uppercase tracking-wider font-semibold mb-4">Main Menu</p>
                <nav class="space-y-2">
                    <a asp-area="" asp-controller="Doctor" asp-action="Dashboard" 
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 text-slate-300 transition-colors no-underline">
                        <span class="material-symbols-outlined text-xl">dashboard</span> Dashboard
                    </a>
                    <a asp-area="" asp-controller="Doctor" asp-action="Schedule" 
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 text-slate-300 transition-colors no-underline">
                        <span class="material-symbols-outlined text-xl">calendar_month</span> Schedule
                    </a>
                    <a asp-area="" asp-controller="Doctor" asp-action="Patients" 
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 text-slate-300 transition-colors no-underline">
                        <span class="material-symbols-outlined text-xl">groups</span> My Patients
                    </a>
                    <a asp-area="" asp-controller="Doctor" asp-action="Consultations" 
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-primary/20 text-white font-medium no-underline">
                        <span class="material-symbols-outlined text-xl">medical_information</span> Consultations
                    </a>
                    <a asp-area="" asp-controller="Doctor" asp-action="Earnings" 
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 text-slate-300 transition-colors no-underline">
                        <span class="material-symbols-outlined text-xl">payments</span> Earnings
                    </a>
                </nav>
            </div>

            <!-- User Profile -->
            <div class="mt-auto p-6 border-t border-slate-800">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold">
                        DR
                    </div>
                    <div>
                        <p class="font-medium text-sm">Dr. Sarah Smith</p>
                        <p class="text-xs text-slate-400">Cardiologist</p>
                    </div>
                </div>
                <a asp-area="" asp-controller="Account" asp-action="Logout" 
                   class="mt-4 flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-slate-800 text-slate-300 transition-colors text-sm no-underline">
                    <span class="material-symbols-outlined text-lg">logout</span> Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col h-full overflow-hidden bg-background-light">
            <!-- Top Header -->
            <header class="h-16 flex items-center justify-between px-8 bg-white border-b border-slate-200 flex-shrink-0">
                <div class="flex items-center gap-4">
                    <h1 class="text-2xl font-bold text-slate-800">Active Consultation</h1>
                    <span class="px-3 py-1 bg-red-100 text-red-700 text-xs font-bold uppercase rounded-full tracking-wider flex items-center gap-1">
                        <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span> Live Session
                    </span>
                </div>
                <div class="flex items-center gap-6">
                    <div class="text-sm font-medium text-slate-500 flex items-center gap-2">
                        <span class="material-symbols-outlined text-lg">schedule</span> 10:30 AM - 11:00 AM
                    </div>
                    <button class="relative p-2 text-slate-500 hover:text-primary transition-colors">
                        <span class="material-symbols-outlined">notifications</span>
                    </button>
                </div>
            </header>

            <!-- Consultation Content -->
            <div class="flex-1 overflow-hidden p-6">
                <div class="flex h-full gap-6">
                    <!-- Left Column - Patient Info & History -->
                    <div class="w-[35%] flex flex-col gap-6 overflow-hidden">
                        <!-- Patient Information Card -->
                        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 flex-shrink-0">
                            <div class="flex items-start justify-between mb-4">
                                <div class="flex items-center gap-4">
                                    <div class="w-14 h-14 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 text-xl font-bold">
                                        ED
                                    </div>
                                    <div>
                                        <h2 class="text-lg font-bold text-slate-900">Emily Davis</h2>
                                        <p class="text-sm text-slate-500">32 yrs • Female • ID: P-9824</p>
                                    </div>
                                </div>
                                <button class="text-primary-light hover:text-primary">
                                    <span class="material-symbols-outlined">edit</span>
                                </button>
                            </div>

                            <!-- Patient Details -->
                            <div class="grid grid-cols-2 gap-4 text-sm mb-4">
                                <div>
                                    <p class="text-slate-500 mb-1 text-xs uppercase tracking-wider font-semibold">Blood Type</p>
                                    <p class="font-medium text-slate-800">O Positive</p>
                                </div>
                                <div>
                                    <p class="text-slate-500 mb-1 text-xs uppercase tracking-wider font-semibold">Allergies</p>
                                    <p class="font-medium text-red-600">Penicillin, Peanuts</p>
                                </div>
                            </div>

                            <!-- Today's Vitals -->
                            <div class="bg-slate-50 rounded-lg p-3 border border-slate-100">
                                <p class="text-xs uppercase tracking-wider font-semibold text-slate-500 mb-2">Today's Vitals</p>
                                <div class="flex justify-between text-sm">
                                    <div class="text-center">
                                        <p class="font-bold text-slate-800">120/80</p>
                                        <p class="text-xs text-slate-500">BP</p>
                                    </div>
                                    <div class="text-center">
                                        <p class="font-bold text-slate-800">72</p>
                                        <p class="text-xs text-slate-500">HR</p>
                                    </div>
                                    <div class="text-center">
                                        <p class="font-bold text-slate-800">98.6°F</p>
                                        <p class="text-xs text-slate-500">Temp</p>
                                    </div>
                                    <div class="text-center">
                                        <p class="font-bold text-slate-800">145</p>
                                        <p class="text-xs text-slate-500">Weight</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Medical History Card -->
                        <div class="bg-white rounded-xl border border-slate-200 shadow-sm flex flex-col flex-1 overflow-hidden">
                            <div class="p-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                                <h3 class="font-bold text-slate-800">Medical History</h3>
                                <button class="text-xs text-primary-light font-medium hover:underline">View All</button>
                            </div>
                            <div class="p-4 overflow-y-auto flex-1 space-y-4">
                                <!-- History Entry 1 - Current -->
                                <div class="border-l-2 border-primary-light pl-4 py-1">
                                    <p class="text-xs font-semibold text-primary-light mb-1">Oct 12, 2023 • Dr. Sarah Smith</p>
                                    <p class="text-sm font-bold text-slate-800 mb-1">Routine Checkup</p>
                                    <p class="text-sm text-slate-600 line-clamp-2">Patient reported mild fatigue. Blood work ordered. Prescribed iron supplements to address minor anemia.</p>
                                </div>

                                <!-- History Entry 2 -->
                                <div class="border-l-2 border-slate-200 pl-4 py-1">
                                    <p class="text-xs font-semibold text-slate-500 mb-1">Aug 05, 2023 • Dr. James Wilson</p>
                                    <p class="text-sm font-bold text-slate-800 mb-1">Upper Respiratory Infection</p>
                                    <p class="text-sm text-slate-600 line-clamp-2">Symptoms include cough, congestion, and low-grade fever. Recommended rest, hydration, and OTC decongestants.</p>
                                </div>

                                <!-- History Entry 3 -->
                                <div class="border-l-2 border-slate-200 pl-4 py-1">
                                    <p class="text-xs font-semibold text-slate-500 mb-1">Feb 20, 2023 • Dr. Sarah Smith</p>
                                    <p class="text-sm font-bold text-slate-800 mb-1">Annual Physical</p>
                                    <p class="text-sm text-slate-600 line-clamp-2">All vitals normal. No concerns reported. Updated tetanus vaccination.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column - Consultation Notes & Prescription -->
                    <div class="flex-1 flex flex-col gap-6 overflow-hidden">
                        <!-- Consultation Notes Card -->
                        <div class="bg-white rounded-xl border border-slate-200 shadow-sm flex flex-col flex-1 overflow-hidden">
                            <div class="p-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                                <h2 class="font-bold text-slate-800 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-primary">edit_document</span> Consultation Notes
                                </h2>
                                <div class="flex items-center gap-1 bg-white border border-slate-200 rounded-md p-1 shadow-sm">
                                    <button class="p-1 text-slate-600 hover:bg-slate-100 rounded" title="Bold">
                                        <span class="material-symbols-outlined text-[18px]">format_bold</span>
                                    </button>
                                    <button class="p-1 text-slate-600 hover:bg-slate-100 rounded" title="Italic">
                                        <span class="material-symbols-outlined text-[18px]">format_italic</span>
                                    </button>
                                    <button class="p-1 text-slate-600 hover:bg-slate-100 rounded" title="Underline">
                                        <span class="material-symbols-outlined text-[18px]">format_underlined</span>
                                    </button>
                                    <div class="w-[1px] h-4 bg-slate-200 mx-1"></div>
                                    <button class="p-1 text-slate-600 hover:bg-slate-100 rounded" title="Bullet List">
                                        <span class="material-symbols-outlined text-[18px]">format_list_bulleted</span>
                                    </button>
                                    <button class="p-1 text-slate-600 hover:bg-slate-100 rounded" title="Numbered List">
                                        <span class="material-symbols-outlined text-[18px]">format_list_numbered</span>
                                    </button>
                                </div>
                            </div>
                            <div class="p-4 flex-1">
                                <textarea class="w-full h-full border-none focus:ring-0 resize-none p-0 text-slate-700 leading-relaxed" 
                                          placeholder="Start typing observation notes, diagnosis, and treatment plan..."></textarea>
                            </div>
                        </div>

                        <!-- Digital Prescription Card -->
                        <div class="bg-white rounded-xl border border-slate-200 shadow-sm flex-shrink-0">
                            <div class="p-4 border-b border-slate-100 bg-slate-50/50">
                                <h2 class="font-bold text-slate-800 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-emerald-600">prescriptions</span> Digital Prescription
                                </h2>
                            </div>
                            <div class="p-4 space-y-4">
                                <!-- Medication Search -->
                                <div class="flex gap-3">
                                    <div class="relative flex-1">
                                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
                                        <input class="w-full pl-10 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-primary focus:border-primary" 
                                               placeholder="Search medications..." 
                                               type="text" />
                                    </div>
                                    <button class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium rounded-lg text-sm transition-colors flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[18px]">add</span> Add
                                    </button>
                                </div>

                                <!-- Prescribed Medications -->
                                <div class="space-y-2">
                                    <div class="flex items-center justify-between p-3 border border-slate-200 rounded-lg bg-white">
                                        <div>
                                            <p class="text-sm font-bold text-slate-800">Lisinopril 10mg</p>
                                            <p class="text-xs text-slate-500 mt-0.5">Take 1 tablet by mouth daily</p>
                                        </div>
                                        <div class="flex items-center gap-3">
                                            <select class="text-xs border-slate-200 rounded-md py-1 pl-2 pr-6 focus:ring-primary">
                                                <option>30 days</option>
                                                <option>60 days</option>
                                                <option>90 days</option>
                                            </select>
                                            <button class="text-slate-400 hover:text-red-500 transition-colors p-1">
                                                <span class="material-symbols-outlined text-[18px]">delete</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="flex items-center justify-end gap-4 flex-shrink-0 mt-2">
                            <button class="px-5 py-2.5 border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 font-medium rounded-lg text-sm transition-colors flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px]">share</span> Refer to Specialist
                            </button>
                            <button class="px-5 py-2.5 bg-primary hover:bg-primary/90 text-white font-medium rounded-lg text-sm transition-colors flex items-center gap-2 shadow-sm">
                                <span class="material-symbols-outlined text-[18px]">check_circle</span> Complete Session
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
