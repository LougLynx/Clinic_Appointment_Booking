@{
    ViewData["Title"] = "Earnings & Analytics";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediClinic</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <!-- Inter Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    
    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#13b6ec",
                        "primary-dark": "#1e3a8a",
                        "primary-light": "#3b82f6",
                        "background-light": "#f8fafc",
                    },
                    fontFamily: {
                        "display": ["Inter", "Noto Sans", "sans-serif"]
                    },
                },
            },
        }
    </script>
</head>
<body class="bg-background-light text-slate-800 font-display">
    <div class="flex h-screen w-full overflow-hidden">
        <!-- Sidebar -->
        <aside class="w-64 bg-slate-900 text-white flex flex-col h-full flex-shrink-0">
            <!-- Logo -->
            <div class="h-16 flex items-center px-6 border-b border-slate-800">
                <span class="material-symbols-outlined text-2xl mr-3 text-primary">local_hospital</span>
                <span class="text-xl font-bold tracking-wide">MediClinic</span>
            </div>

            <!-- Navigation Menu -->
            <div class="p-6 pb-2 flex-1 overflow-y-auto">
                <p class="text-xs text-slate-400 uppercase tracking-wider font-semibold mb-4">Main Menu</p>
                <nav class="space-y-2">
                    <a asp-area="" asp-controller="Doctor" asp-action="Dashboard" 
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 text-slate-300 transition-colors no-underline">
                        <span class="material-symbols-outlined text-xl">dashboard</span> Dashboard
                    </a>
                    <a asp-area="" asp-controller="Doctor" asp-action="Schedule" 
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 text-slate-300 transition-colors no-underline">
                        <span class="material-symbols-outlined text-xl">calendar_month</span> Schedule
                    </a>
                    <a asp-area="" asp-controller="Doctor" asp-action="Patients" 
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 text-slate-300 transition-colors no-underline">
                        <span class="material-symbols-outlined text-xl">groups</span> My Patients
                    </a>
                    <a asp-area="" asp-controller="Doctor" asp-action="Consultations" 
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 text-slate-300 transition-colors no-underline">
                        <span class="material-symbols-outlined text-xl">medical_information</span> Consultations
                    </a>
                    <a asp-area="" asp-controller="Doctor" asp-action="Earnings" 
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-primary/20 text-white font-medium no-underline">
                        <span class="material-symbols-outlined text-xl">payments</span> Earnings
                    </a>
                </nav>
            </div>

            <!-- User Profile -->
            <div class="mt-auto p-6 border-t border-slate-800">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold">
                        DR
                    </div>
                    <div>
                        <p class="font-medium text-sm">Dr. Sarah Smith</p>
                        <p class="text-xs text-slate-400">Cardiologist</p>
                    </div>
                </div>
                <a asp-area="" asp-controller="Account" asp-action="Logout" 
                   class="mt-4 flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-slate-800 text-slate-300 transition-colors text-sm no-underline">
                    <span class="material-symbols-outlined text-lg">logout</span> Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col h-full overflow-hidden bg-background-light">
            <!-- Top Header -->
            <header class="h-16 flex items-center justify-between px-8 bg-white border-b border-slate-200 flex-shrink-0">
                <h1 class="text-2xl font-bold text-slate-800">Earnings &amp; Analytics</h1>
                <div class="flex items-center gap-6">
                    <!-- Search Bar -->
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xl">search</span>
                        <input class="pl-10 pr-4 py-2 bg-slate-100 border-none rounded-lg text-sm focus:ring-2 focus:ring-primary w-64" 
                               placeholder="Search transactions..." 
                               type="text" />
                    </div>
                    <!-- Notifications -->
                    <button class="relative p-2 text-slate-500 hover:text-primary transition-colors">
                        <span class="material-symbols-outlined">notifications</span>
                        <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full"></span>
                    </button>
                </div>
            </header>

            <!-- Earnings Content -->
            <div class="flex-1 overflow-y-auto p-8">
                <div class="max-w-7xl mx-auto space-y-6">
                    <!-- Stats Cards -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <!-- Total Revenue -->
                        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-center gap-4">
                            <div class="w-12 h-12 rounded-full bg-green-100 flex items-center justify-center text-green-600">
                                <span class="material-symbols-outlined">account_balance_wallet</span>
                            </div>
                            <div>
                                <p class="text-sm text-slate-500 font-medium">Total Revenue</p>
                                <p class="text-2xl font-bold text-slate-800">$15,420.00</p>
                            </div>
                        </div>

                        <!-- Paid Consultations -->
                        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-center gap-4">
                            <div class="w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center text-primary-light">
                                <span class="material-symbols-outlined">check_circle</span>
                            </div>
                            <div>
                                <p class="text-sm text-slate-500 font-medium">Paid Consultations</p>
                                <p class="text-2xl font-bold text-slate-800">124</p>
                            </div>
                        </div>

                        <!-- Pending Invoices -->
                        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-center gap-4">
                            <div class="w-12 h-12 rounded-full bg-amber-100 flex items-center justify-center text-amber-600">
                                <span class="material-symbols-outlined">pending_actions</span>
                            </div>
                            <div>
                                <p class="text-sm text-slate-500 font-medium">Pending Invoices</p>
                                <p class="text-2xl font-bold text-slate-800">$2,350.00</p>
                            </div>
                        </div>
                    </div>

                    <!-- Earnings Trend Chart -->
                    <div class="bg-white rounded-xl border border-slate-200 shadow-sm">
                        <div class="p-6 border-b border-slate-100 flex justify-between items-center">
                            <h2 class="text-lg font-bold text-slate-800">Earnings Trend</h2>
                            <select class="bg-slate-50 border border-slate-200 text-slate-700 text-sm rounded-lg focus:ring-primary focus:border-primary block p-2">
                                <option>This Month</option>
                                <option>Last Month</option>
                                <option>This Year</option>
                            </select>
                        </div>
                        <div class="p-6 h-72 w-full relative">
                            <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 800 200">
                                <defs>
                                    <linearGradient id="chartGradient" x1="0%" x2="0%" y1="0%" y2="100%">
                                        <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.3"></stop>
                                        <stop offset="100%" stop-color="#3b82f6" stop-opacity="0"></stop>
                                    </linearGradient>
                                </defs>
                                <!-- Grid Lines -->
                                <path d="M0 40 L800 40" stroke="#f1f5f9" stroke-width="1"></path>
                                <path d="M0 80 L800 80" stroke="#f1f5f9" stroke-width="1"></path>
                                <path d="M0 120 L800 120" stroke="#f1f5f9" stroke-width="1"></path>
                                <path d="M0 160 L800 160" stroke="#f1f5f9" stroke-width="1"></path>
                                <path d="M0 200 L800 200" stroke="#f1f5f9" stroke-width="1"></path>
                                <!-- Area Fill -->
                                <path d="M0 150 Q 100 100, 200 120 T 400 80 T 600 100 T 800 40 L800 200 L0 200 Z" fill="url(#chartGradient)"></path>
                                <!-- Line -->
                                <path d="M0 150 Q 100 100, 200 120 T 400 80 T 600 100 T 800 40" fill="none" stroke="#3b82f6" stroke-width="3"></path>
                                <!-- Data Points -->
                                <circle cx="200" cy="120" fill="white" r="4" stroke="#3b82f6" stroke-width="2"></circle>
                                <circle cx="400" cy="80" fill="white" r="4" stroke="#3b82f6" stroke-width="2"></circle>
                                <circle cx="600" cy="100" fill="white" r="4" stroke="#3b82f6" stroke-width="2"></circle>
                                <circle cx="800" cy="40" fill="white" r="4" stroke="#3b82f6" stroke-width="2"></circle>
                            </svg>
                            <div class="flex justify-between mt-2 text-xs font-medium text-slate-400 px-2">
                                <span>Week 1</span>
                                <span>Week 2</span>
                                <span>Week 3</span>
                                <span>Week 4</span>
                            </div>
                        </div>
                    </div>

                    <!-- Transaction History Table -->
                    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                        <div class="p-6 border-b border-slate-100 flex justify-between items-center">
                            <h2 class="text-lg font-bold text-slate-800">Transaction History</h2>
                            <button class="text-sm flex items-center gap-1 text-slate-500 hover:text-slate-800 font-medium">
                                <span class="material-symbols-outlined text-[18px]">filter_list</span> Filter
                            </button>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead>
                                    <tr class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider">
                                        <th class="px-6 py-4 font-semibold">Date</th>
                                        <th class="px-6 py-4 font-semibold">Patient Name</th>
                                        <th class="px-6 py-4 font-semibold">Service Type</th>
                                        <th class="px-6 py-4 font-semibold">Amount</th>
                                        <th class="px-6 py-4 font-semibold">Status</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100 text-sm">
                                    <!-- Transaction 1 -->
                                    <tr class="hover:bg-slate-50 transition-colors">
                                        <td class="px-6 py-4 whitespace-nowrap text-slate-600">Oct 24, 2023</td>
                                        <td class="px-6 py-4 whitespace-nowrap font-medium text-slate-800">Michael Johnson</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-slate-500">Routine Checkup</td>
                                        <td class="px-6 py-4 whitespace-nowrap font-medium text-slate-800">$150.00</td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                Paid
                                            </span>
                                        </td>
                                    </tr>

                                    <!-- Transaction 2 -->
                                    <tr class="hover:bg-slate-50 transition-colors">
                                        <td class="px-6 py-4 whitespace-nowrap text-slate-600">Oct 24, 2023</td>
                                        <td class="px-6 py-4 whitespace-nowrap font-medium text-slate-800">Emily Davis</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-slate-500">Blood Pressure Monitor</td>
                                        <td class="px-6 py-4 whitespace-nowrap font-medium text-slate-800">$80.00</td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
                                                Processing
                                            </span>
                                        </td>
                                    </tr>

                                    <!-- Transaction 3 -->
                                    <tr class="hover:bg-slate-50 transition-colors">
                                        <td class="px-6 py-4 whitespace-nowrap text-slate-600">Oct 23, 2023</td>
                                        <td class="px-6 py-4 whitespace-nowrap font-medium text-slate-800">Robert Smith</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-slate-500">Follow-up</td>
                                        <td class="px-6 py-4 whitespace-nowrap font-medium text-slate-800">$100.00</td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                Paid
                                            </span>
                                        </td>
                                    </tr>

                                    <!-- Transaction 4 -->
                                    <tr class="hover:bg-slate-50 transition-colors">
                                        <td class="px-6 py-4 whitespace-nowrap text-slate-600">Oct 22, 2023</td>
                                        <td class="px-6 py-4 whitespace-nowrap font-medium text-slate-800">Amanda Lee</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-slate-500">Test Results Review</td>
                                        <td class="px-6 py-4 whitespace-nowrap font-medium text-slate-800">$120.00</td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                Paid
                                            </span>
                                        </td>
                                    </tr>

                                    <!-- Transaction 5 -->
                                    <tr class="hover:bg-slate-50 transition-colors">
                                        <td class="px-6 py-4 whitespace-nowrap text-slate-600">Oct 21, 2023</td>
                                        <td class="px-6 py-4 whitespace-nowrap font-medium text-slate-800">John Doe</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-slate-500">Cardiology Consult</td>
                                        <td class="px-6 py-4 whitespace-nowrap font-medium text-slate-800">$250.00</td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
                                                Processing
                                            </span>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
