@{
    ViewData["Title"] = "Doctor Schedule";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - MediDash</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#1e3a8a",
                        "primary-light": "#3b82f6",
                        "background-light": "#f8fafc",
                    },
                    fontFamily: {
                        "display": ["Inter", "Noto Sans", "sans-serif"]
                    },
                },
            },
        }
    </script>
</head>
<body class="bg-background-light text-slate-800 font-display">
    <div class="flex h-screen w-full overflow-hidden">
        <aside class="w-64 bg-primary text-white flex flex-col h-full flex-shrink-0">
            <div class="h-16 flex items-center px-6 border-b border-blue-800/50">
                <span class="material-symbols-outlined text-2xl mr-3">local_hospital</span>
                <span class="text-xl font-bold tracking-wide">MediDash</span>
            </div>
            <div class="p-6 pb-2">
                <p class="text-xs text-blue-300 uppercase tracking-wider font-semibold mb-4">Main Menu</p>
                <nav class="space-y-2">
                    <a asp-area="" asp-controller="Doctor" asp-action="Dashboard" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-blue-800/30 text-blue-100 transition-colors no-underline">
                        <span class="material-symbols-outlined text-xl">dashboard</span> Dashboard
                    </a>
                    <a asp-area="" asp-controller="Doctor" asp-action="Schedule" class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-blue-800/50 text-white font-medium no-underline">
                        <span class="material-symbols-outlined text-xl">calendar_month</span> Schedule
                    </a>
                    <a asp-area="" asp-controller="Doctor" asp-action="Patients" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-blue-800/30 text-blue-100 transition-colors no-underline">
                        <span class="material-symbols-outlined text-xl">groups</span> My Patients
                    </a>
                    <a asp-area="" asp-controller="Doctor" asp-action="Consultations" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-blue-800/30 text-blue-100 transition-colors no-underline">
                        <span class="material-symbols-outlined text-xl">medical_information</span> Consultations
                    </a>
                    <a asp-area="" asp-controller="Doctor" asp-action="Earnings" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-blue-800/30 text-blue-100 transition-colors no-underline">
                        <span class="material-symbols-outlined text-xl">payments</span> Earnings
                    </a>
                </nav>
            </div>
            <div class="mt-auto p-6 border-t border-blue-800/50">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-blue-300 flex items-center justify-center text-primary font-bold">
                        DR
                    </div>
                    <div>
                        <p class="font-medium text-sm">Dr. Sarah Smith</p>
                        <p class="text-xs text-blue-300">Cardiologist</p>
                    </div>
                </div>
                <a asp-area="" asp-controller="Account" asp-action="Logout" class="mt-4 flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-blue-800/30 text-blue-100 transition-colors text-sm no-underline">
                    <span class="material-symbols-outlined text-lg">logout</span> Logout
                </a>
            </div>
        </aside>
        <main class="flex-1 flex flex-col h-full overflow-hidden bg-background-light">
            <header class="h-16 flex items-center justify-between px-8 bg-white border-b border-slate-200 flex-shrink-0">
                <h1 class="text-2xl font-bold text-slate-800">Schedule</h1>
                <div class="flex items-center gap-6">
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xl">search</span>
                        <input class="pl-10 pr-4 py-2 bg-slate-100 border-none rounded-lg text-sm focus:ring-2 focus:ring-primary-light w-64" placeholder="Search patients or events..." type="text" />
                    </div>
                    <button class="relative p-2 text-slate-500 hover:text-primary transition-colors">
                        <span class="material-symbols-outlined">notifications</span>
                        <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full"></span>
                    </button>
                </div>
            </header>
            <div class="flex-1 flex overflow-hidden">
                <div class="flex-1 flex flex-col overflow-hidden bg-white border-r border-slate-200">
                    <div class="p-6 border-b border-slate-200 flex items-center justify-between">
                        <div class="flex items-center gap-4">
                            <h2 class="text-xl font-bold text-slate-800">October 2023</h2>
                            <div class="flex items-center gap-1 border border-slate-200 rounded-lg p-1 bg-slate-50">
                                <button class="p-1 text-slate-500 hover:bg-white hover:text-slate-800 hover:shadow-sm rounded transition-all"><span class="material-symbols-outlined text-sm">chevron_left</span></button>
                                <button class="px-3 py-1 text-sm font-medium text-slate-700 hover:bg-white hover:shadow-sm rounded transition-all">Today</button>
                                <button class="p-1 text-slate-500 hover:bg-white hover:text-slate-800 hover:shadow-sm rounded transition-all"><span class="material-symbols-outlined text-sm">chevron_right</span></button>
                            </div>
                        </div>
                        <div class="flex items-center gap-1 border border-slate-200 rounded-lg p-1 bg-slate-50">
                            <button class="px-3 py-1.5 text-sm font-medium bg-white text-slate-800 shadow-sm rounded">Month</button>
                            <button class="px-3 py-1.5 text-sm font-medium text-slate-600 hover:text-slate-800 rounded">Week</button>
                            <button class="px-3 py-1.5 text-sm font-medium text-slate-600 hover:text-slate-800 rounded">Day</button>
                        </div>
                    </div>
                    <div class="flex-1 overflow-auto p-6 bg-slate-50/50">
                        <div class="grid grid-cols-7 gap-px bg-slate-200 rounded-xl overflow-hidden shadow-sm border border-slate-200">
                            <div class="bg-white p-3 text-center text-sm font-semibold text-slate-500">Sun</div>
                            <div class="bg-white p-3 text-center text-sm font-semibold text-slate-500">Mon</div>
                            <div class="bg-white p-3 text-center text-sm font-semibold text-slate-500">Tue</div>
                            <div class="bg-white p-3 text-center text-sm font-semibold text-slate-500">Wed</div>
                            <div class="bg-white p-3 text-center text-sm font-semibold text-slate-500">Thu</div>
                            <div class="bg-white p-3 text-center text-sm font-semibold text-slate-500">Fri</div>
                            <div class="bg-white p-3 text-center text-sm font-semibold text-slate-500">Sat</div>
                            <div class="bg-slate-50 min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100">
                                <span class="text-sm text-slate-400 font-medium ml-1">1</span>
                            </div>
                            <div class="bg-slate-50 min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100">
                                <span class="text-sm text-slate-400 font-medium ml-1">2</span>
                            </div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100">
                                <span class="text-sm text-slate-700 font-medium ml-1">3</span>
                                <div class="px-2 py-1 text-xs rounded bg-blue-100 text-blue-700 border border-blue-200 truncate cursor-pointer hover:shadow-sm">09:00 Consultation</div>
                            </div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100 ring-2 ring-primary-light ring-inset rounded-lg z-10">
                                <span class="text-sm text-primary-light font-bold ml-1 flex items-center justify-between">
                                    4 <span class="w-1.5 h-1.5 rounded-full bg-primary-light mr-1"></span>
                                </span>
                                <div class="px-2 py-1 text-xs rounded bg-blue-100 text-blue-700 border border-blue-200 truncate cursor-pointer hover:shadow-sm font-medium">09:00 Routine</div>
                                <div class="px-2 py-1 text-xs rounded bg-orange-100 text-orange-700 border border-orange-200 truncate cursor-pointer hover:shadow-sm font-medium">11:30 Surgery</div>
                                <div class="px-2 py-1 text-xs rounded bg-blue-100 text-blue-700 border border-blue-200 truncate cursor-pointer hover:shadow-sm font-medium">14:00 Follow-up</div>
                            </div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100">
                                <span class="text-sm text-slate-700 font-medium ml-1">5</span>
                                <div class="px-2 py-1 text-xs rounded bg-emerald-100 text-emerald-700 border border-emerald-200 truncate cursor-pointer hover:shadow-sm">10:00 New Patient</div>
                            </div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100">
                                <span class="text-sm text-slate-700 font-medium ml-1">6</span>
                                <div class="px-2 py-1 text-xs rounded bg-orange-100 text-orange-700 border border-orange-200 truncate cursor-pointer hover:shadow-sm">08:00 Surgery</div>
                            </div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100">
                                <span class="text-sm text-slate-700 font-medium ml-1">7</span>
                            </div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100">
                                <span class="text-sm text-slate-700 font-medium ml-1">8</span>
                            </div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100">
                                <span class="text-sm text-slate-700 font-medium ml-1">9</span>
                                <div class="px-2 py-1 text-xs rounded bg-blue-100 text-blue-700 border border-blue-200 truncate cursor-pointer hover:shadow-sm">09:00 Consultation</div>
                                <div class="px-2 py-1 text-xs rounded bg-blue-100 text-blue-700 border border-blue-200 truncate cursor-pointer hover:shadow-sm">14:00 Follow-up</div>
                            </div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100">
                                <span class="text-sm text-slate-700 font-medium ml-1">10</span>
                            </div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100">
                                <span class="text-sm text-slate-700 font-medium ml-1">11</span>
                                <div class="px-2 py-1 text-xs rounded bg-emerald-100 text-emerald-700 border border-emerald-200 truncate cursor-pointer hover:shadow-sm">11:00 New Patient</div>
                            </div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100">
                                <span class="text-sm text-slate-700 font-medium ml-1">12</span>
                                <div class="px-2 py-1 text-xs rounded bg-blue-100 text-blue-700 border border-blue-200 truncate cursor-pointer hover:shadow-sm">15:00 Review</div>
                            </div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100">
                                <span class="text-sm text-slate-700 font-medium ml-1">13</span>
                                <div class="px-2 py-1 text-xs rounded bg-orange-100 text-orange-700 border border-orange-200 truncate cursor-pointer hover:shadow-sm">08:00 Surgery</div>
                                <div class="px-2 py-1 text-xs rounded bg-blue-100 text-blue-700 border border-blue-200 truncate cursor-pointer hover:shadow-sm">13:00 Follow-up</div>
                            </div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100">
                                <span class="text-sm text-slate-700 font-medium ml-1">14</span>
                            </div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100"><span class="text-sm text-slate-700 font-medium ml-1">15</span></div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100"><span class="text-sm text-slate-700 font-medium ml-1">16</span></div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100"><span class="text-sm text-slate-700 font-medium ml-1">17</span></div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100"><span class="text-sm text-slate-700 font-medium ml-1">18</span></div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100"><span class="text-sm text-slate-700 font-medium ml-1">19</span></div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100"><span class="text-sm text-slate-700 font-medium ml-1">20</span></div>
                            <div class="bg-white min-h-[120px] p-2 flex flex-col gap-1 border-t border-slate-100"><span class="text-sm text-slate-700 font-medium ml-1">21</span></div>
                        </div>
                    </div>
                </div>
                <div class="w-96 bg-white overflow-y-auto border-l border-slate-200 flex flex-col">
                    <div class="p-6 border-b border-slate-200 sticky top-0 bg-white z-10">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-lg font-bold text-slate-800">Daily Agenda</h3>
                            <p class="text-sm text-slate-500">Oct 4, 2023</p>
                        </div>
                        <button class="w-full py-2 bg-primary text-white rounded-lg font-medium hover:bg-primary/90 transition-colors flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">add</span> New Appointment
                        </button>
                    </div>
                    <div class="p-6 space-y-6">
                        <div class="relative pl-4 border-l-2 border-blue-500">
                            <div class="mb-1 flex items-center justify-between">
                                <span class="text-sm font-bold text-slate-800">09:00 AM - 09:30 AM</span>
                                <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-blue-100 text-blue-700">Consultation</span>
                            </div>
                            <p class="font-bold text-slate-900">Michael Johnson</p>
                            <p class="text-sm text-slate-500 mb-3 flex items-center gap-1">
                                <span class="material-symbols-outlined text-[16px]">stethoscope</span> Routine Checkup
                            </p>
                            <div class="flex gap-2">
                                <button class="flex-1 py-1.5 text-xs font-medium bg-blue-50 text-blue-700 hover:bg-blue-100 rounded border border-blue-200 transition-colors">Start Consultation</button>
                                <button class="px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-100 rounded border border-slate-200 transition-colors">Reschedule</button>
                            </div>
                        </div>
                        <div class="relative pl-4 border-l-2 border-orange-500">
                            <div class="mb-1 flex items-center justify-between">
                                <span class="text-sm font-bold text-slate-800">11:30 AM - 01:00 PM</span>
                                <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-orange-100 text-orange-700">Surgery</span>
                            </div>
                            <p class="font-bold text-slate-900">Emily Davis</p>
                            <p class="text-sm text-slate-500 mb-3 flex items-center gap-1">
                                <span class="material-symbols-outlined text-[16px]">content_cut</span> Minor Procedure
                            </p>
                            <div class="flex gap-2">
                                <button class="flex-1 py-1.5 text-xs font-medium bg-orange-50 text-orange-700 hover:bg-orange-100 rounded border border-orange-200 transition-colors">Prepare</button>
                                <button class="px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-100 rounded border border-slate-200 transition-colors">Reschedule</button>
                            </div>
                        </div>
                        <div class="relative pl-4 border-l-2 border-blue-500">
                            <div class="mb-1 flex items-center justify-between">
                                <span class="text-sm font-bold text-slate-800">02:00 PM - 02:30 PM</span>
                                <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-blue-100 text-blue-700">Consultation</span>
                            </div>
                            <p class="font-bold text-slate-900">Robert Smith</p>
                            <p class="text-sm text-slate-500 mb-3 flex items-center gap-1">
                                <span class="material-symbols-outlined text-[16px]">healing</span> Follow-up
                            </p>
                            <div class="flex gap-2">
                                <button class="flex-1 py-1.5 text-xs font-medium bg-slate-50 text-slate-700 hover:bg-slate-100 rounded border border-slate-200 transition-colors">View Records</button>
                                <button class="px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-100 rounded border border-slate-200 transition-colors">Reschedule</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
