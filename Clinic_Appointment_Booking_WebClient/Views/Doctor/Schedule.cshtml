@using System.Globalization
@model Clinic_Appointment_Booking_WebClient.Models.ViewModels.DoctorScheduleViewModel
@{
    ViewData["Title"] = "Doctor Schedule";
    Layout = null;
    var today = DateTime.Today;
    
    // Calculate normalized month for display logic
    var targetMonth = new DateTime(Model.ReferenceDate.Year, Model.ReferenceDate.Month, 1);

    // Check if any appointment is for today (for notification dot)
    var hasTodayPending = Model.Appointments.Any(a => a.AppointmentDate.Date == today.Date && a.Status == "Pending");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - MediClinic</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <!-- Inter Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    
    <style>
        /* Anti-FOUC styles */
        body { opacity: 0; transition: opacity 0.4s ease-in-out; }
        body.ready { opacity: 1; }
        
        .nav-item-active {
            background-color: rgba(19, 182, 236, 0.2);
            color: white;
            font-weight: 500;
        }
        
        .nav-item-hover:hover {
            background-color: rgba(30, 41, 59, 1);
            color: #13b6ec;
        }

        .material-symbols-outlined {
            display: inline-block;
            font-feature-settings: 'liga';
            -webkit-font-smoothing: antialiased;
        }

        .calendar-day-today {
            box-shadow: inset 0 0 0 2px #13b6ec;
        }

        .appointment-tag-pending { background-color: #fef3c7; color: #92400e; border: 1px solid #fde68a; }
        .appointment-tag-confirmed { background-color: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
        .appointment-tag-inprogress { background-color: #dbeafe; color: #1e40af; border: 1px solid #bfdbfe; }
    </style>
    
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#13b6ec",
                        "background-light": "#f8fafc",
                    },
                    fontFamily: {
                        "display": ["Inter", "Noto Sans", "sans-serif"]
                    },
                },
            },
        }

        window.addEventListener('DOMContentLoaded', (event) => {
            document.body.classList.add('loaded');
        });
    </script>
</head>
<body class="bg-background-light text-slate-800 font-display">
    <div class="flex h-screen w-full overflow-hidden">
        <!-- Sidebar -->
        <aside class="w-64 bg-slate-900 text-white flex flex-col h-full flex-shrink-0">
            <!-- Logo -->
            <div class="h-16 flex items-center px-6 border-b border-slate-800">
                <span class="material-symbols-outlined text-2xl mr-3 text-primary">local_hospital</span>
                <span class="text-xl font-bold tracking-wide">MediClinic</span>
            </div>

            <!-- Navigation Menu -->
            <div class="p-6 pb-2 flex-1 overflow-y-auto">
                <p class="text-xs text-slate-400 uppercase tracking-wider font-semibold mb-4">Main Menu</p>
                <nav class="space-y-2">
                    <a asp-area="" asp-controller="Doctor" asp-action="Schedule" 
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg nav-item-active no-underline">
                        <span class="material-symbols-outlined text-xl">calendar_month</span> Schedule
                    </a>
                    <a asp-area="" asp-controller="Doctor" asp-action="Patients" 
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg nav-item-hover text-slate-300 transition-colors no-underline">
                        <span class="material-symbols-outlined text-xl">groups</span> My Patients
                    </a>
                </nav>
            </div>

            <div class="mt-auto p-6 border-t border-slate-800">
                <div class="flex items-center gap-3">
                    @if (ViewData["DoctorProfilePicture"] != null && !string.IsNullOrEmpty(ViewData["DoctorProfilePicture"].ToString()))
                    {
                        <img src="@ViewData["DoctorProfilePicture"]" 
                             class="w-10 h-10 rounded-full object-cover border-2 border-primary shadow-sm" 
                             alt="Profile"
                             onerror="this.onerror=null; this.innerHTML='<div class=\'w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold\'>DR</div>'; this.outerHTML=this.innerHTML;" />
                    }
                    else
                    {
                        <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold">
                            DR
                        </div>
                    }
                    <div>
                        <p class="font-medium text-sm">@Context.Session.GetString("UserName")</p>
                        <p class="text-xs text-slate-400">@Context.Session.GetString("UserRole")</p>
                    </div>
                </div>
                <a asp-area="" asp-controller="Account" asp-action="Logout" 
                   class="mt-4 flex items-center gap-2 px-3 py-2 rounded-lg nav-item-hover text-slate-300 transition-colors text-sm no-underline">
                    <span class="material-symbols-outlined text-lg">logout</span> Logout
                </a>
            </div>
        </aside>

        <main class="flex-1 flex flex-col h-full overflow-hidden bg-background-light">

            <div class="flex-1 flex overflow-hidden">
                <!-- Calendar Section -->
                <!-- Full Width Calendar Section -->
                <div class="flex-1 flex flex-col overflow-hidden bg-white">
                    <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between bg-white sticky top-0 z-10">
                        <div class="flex items-center gap-6">
                            <!-- Navigation Arrows & Date Selector -->
                            <div class="flex items-center gap-3">
                                @{
                                    var prevRouteDate = Model.ViewType == "Week" ? Model.ReferenceDate.AddDays(-7) : 
                                                       Model.ViewType == "Day" ? Model.ReferenceDate.AddDays(-1) : 
                                                       Model.ReferenceDate.AddMonths(-1);
                                    var nextRouteDate = Model.ViewType == "Week" ? Model.ReferenceDate.AddDays(7) : 
                                                       Model.ViewType == "Day" ? Model.ReferenceDate.AddDays(1) : 
                                                       Model.ReferenceDate.AddMonths(1);
                                }
                                <a asp-action="Schedule" asp-route-month="@prevRouteDate.ToString("yyyy-MM-dd")" asp-route-viewType="@Model.ViewType"
                                   class="flex items-center justify-center w-8 h-8 text-slate-400 hover:text-slate-800 hover:bg-slate-100 rounded-full transition-all no-underline">
                                    <span class="material-symbols-outlined text-lg">chevron_left</span>
                                </a>
                                
                                <div class="flex items-center gap-2 group cursor-pointer">
                                    <div class="relative">
                                        <select onchange="location.href='@Url.Action("Schedule")?viewType=@Model.ViewType&month=@(Model.ReferenceDate.Year)-' + this.value + '-01'" 
                                                class="appearance-none border-none bg-transparent font-bold text-slate-800 text-lg cursor-pointer focus:ring-0 pl-0 pr-6 py-0">
                                            @for (int i = 1; i <= 12; i++)
                                            {
                                                <option value="@(i.ToString("D2"))" selected="@(Model.ReferenceDate.Month == i)">@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option>
                                            }
                                        </select>
                                        <span class="material-symbols-outlined absolute right-0 top-1/2 -translate-y-1/2 text-slate-400 text-sm pointer-events-none">expand_more</span>
                                    </div>
                                    <div class="relative ml-1">
                                        <select onchange="location.href='@Url.Action("Schedule")?viewType=@Model.ViewType&month=' + this.value + '-@(Model.ReferenceDate.ToString("MM"))-01'" 
                                                class="appearance-none border-none bg-transparent font-bold text-slate-800 text-lg cursor-pointer focus:ring-0 pl-0 pr-6 py-0">
                                            @for (int i = 2024; i <= 2028; i++)
                                            {
                                                <option value="@i" selected="@(Model.ReferenceDate.Year == i)">@i</option>
                                            }
                                        </select>
                                        <span class="material-symbols-outlined absolute right-0 top-1/2 -translate-y-1/2 text-slate-400 text-sm pointer-events-none">expand_more</span>
                                    </div>
                                </div>

                                <a asp-action="Schedule" asp-route-month="@nextRouteDate.ToString("yyyy-MM-dd")" asp-route-viewType="@Model.ViewType"
                                   class="flex items-center justify-center w-8 h-8 text-slate-400 hover:text-slate-800 hover:bg-slate-100 rounded-full transition-all no-underline">
                                    <span class="material-symbols-outlined text-lg">chevron_right</span>
                                </a>
                            </div>

                            <div class="h-6 w-px bg-slate-200"></div>

                            <!-- Today Button -->
                            <a asp-action="Schedule" asp-route-viewType="@Model.ViewType" 
                               class="px-4 py-1.5 text-sm font-semibold text-slate-600 hover:text-slate-900 border border-slate-200 rounded-md hover:bg-slate-50 transition-all no-underline">
                                Today
                            </a>
                        </div>

                        <!-- View Type Switcher -->
                        <div class="flex items-center p-1 bg-slate-100 rounded-lg border border-slate-200">
                            <a asp-action="Schedule" asp-route-viewType="Month" asp-route-month="@Model.ReferenceDate.ToString("yyyy-MM-dd")" 
                               class="px-4 py-1.5 text-sm font-bold rounded-md no-underline transition-all @(Model.ViewType == "Month" ? "bg-white text-slate-900 shadow-sm" : "text-slate-500 hover:text-slate-700")">
                                Month
                            </a>
                            <a asp-action="Schedule" asp-route-viewType="Week" asp-route-month="@Model.ReferenceDate.ToString("yyyy-MM-dd")" 
                               class="px-4 py-1.5 text-sm font-bold rounded-md no-underline transition-all @(Model.ViewType == "Week" ? "bg-white text-slate-900 shadow-sm" : "text-slate-500 hover:text-slate-700")">
                                Week
                            </a>
                            <a asp-action="Schedule" asp-route-viewType="Day" asp-route-month="@Model.ReferenceDate.ToString("yyyy-MM-dd")" 
                               class="px-4 py-1.5 text-sm font-bold rounded-md no-underline transition-all @(Model.ViewType == "Day" ? "bg-white text-slate-900 shadow-sm" : "text-slate-500 hover:text-slate-700")">
                                Day
                            </a>
                        </div>
                    </div>

                    <!-- Calendar Grid -->
                    <div class="flex-1 overflow-auto p-6 bg-slate-50/50">
                        <div class="grid @(Model.ViewType == "Day" ? "grid-cols-1" : "grid-cols-7") gap-px bg-slate-200 rounded-xl overflow-hidden shadow-sm border border-slate-200">
                            @if (Model.ViewType != "Day")
                            {
                                @foreach (var dayName in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
                                {
                                    <div class="bg-white p-3 text-center text-sm font-bold text-slate-500 uppercase tracking-wider border-b border-slate-100">@dayName</div>
                                }
                            }
                            else
                            {
                                <div class="bg-white p-4 text-center text-lg font-black text-slate-800 uppercase tracking-widest border-b border-slate-100">@Model.ReferenceDate.ToString("dddd, MMMM dd, yyyy")</div>
                            }

                            @foreach (var day in Model.DaysInCalendar)
                            {
                                var isCurrentMonth = day.Month == targetMonth.Month;
                                var dayAppointments = Model.Appointments.Where(a => a.AppointmentDate.Date == day.Date).OrderBy(a => a.AppointmentTime).ToList();
                                <div class="@(isCurrentMonth || Model.ViewType == "Day" ? "bg-white" : "bg-slate-50") @(Model.ViewType == "Day" ? "min-h-[800px]" : Model.ViewType == "Week" ? "min-h-[500px]" : "min-h-[140px]") p-3 flex flex-col gap-1 border-t border-slate-100 @(day.Date == DateTime.Today ? "bg-blue-50/20" : "") group hover:bg-slate-50 transition-colors">
                                    <div class="flex items-center justify-between ml-1 mb-2">
                                        <span class="text-sm @(day.Date == DateTime.Today ? "bg-primary text-white w-7 h-7 flex items-center justify-center rounded-full font-bold shadow-sm" : isCurrentMonth ? "text-slate-700 font-bold" : "text-slate-400 font-normal")">
                                            @day.Day
                                        </span>
                                    </div>
                                    
                                    <div class="space-y-2 overflow-y-auto pr-1 scrollbar-hide">
                                        @foreach (var appt in dayAppointments)
                                        {
                                            var statusClass = appt.Status.ToLower() switch
                                            {
                                                "pending" => "bg-amber-50 text-amber-700 border-amber-200",
                                                "confirmed" => "bg-emerald-50 text-emerald-700 border-emerald-200",
                                                _ => "bg-slate-50 text-slate-600 border-slate-200"
                                            };

                                            <div onclick="showAppointmentDetails(@appt.AppointmentId)" 
                                               class="cursor-pointer block @(Model.ViewType == "Day" ? "px-6 py-4 text-sm" : Model.ViewType == "Week" ? "px-3 py-2 text-xs" : "px-2 py-1.5 text-[10px]") rounded-xl @statusClass border-l-4 font-black transition-all hover:scale-[1.01] hover:shadow-md no-underline mb-2" 
                                               title="@appt.AppointmentTime.ToString(@"hh\:mm") - @appt.ReasonForVisit">
                                                <div class="flex @(Model.ViewType == "Day" ? "flex-row items-center justify-between" : "flex-col") pointer-events-none">
                                                    <div class="flex flex-col">
                                                        <span class="@(Model.ViewType == "Day" ? "text-xs uppercase tracking-wider mb-1" : "text-[8px]") opacity-70">@appt.AppointmentTime.ToString(@"hh\:mm")</span>
                                                        <span class="truncate @(Model.ViewType == "Day" ? "text-lg" : "")">@appt.PatientName</span>
                                                    </div>
                                                    @if (Model.ViewType == "Day")
                                                    {
                                                        <div class="text-right">
                                                            <span class="block text-sm opacity-60 italic">@appt.ReasonForVisit</span>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            </div>
        </main>
    </div>

    <!-- Appointment Details Modal -->
    <div id="appointmentModal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm transition-opacity duration-300">
        <div class="bg-white w-full max-w-lg rounded-[2.5rem] shadow-2xl overflow-hidden transform transition-all scale-95 opacity-0 duration-300" id="modalContent">
            <!-- Modal Header -->
            <div class="relative h-32 bg-primary flex items-center justify-center overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary-600 to-primary-700 opacity-90"></div>
                <div class="absolute -right-10 -top-10 w-40 h-40 bg-white/10 rounded-full blur-2xl"></div>
                <div class="absolute -left-10 -bottom-10 w-40 h-40 bg-white/10 rounded-full blur-2xl"></div>
                
                <h3 class="relative text-white text-2xl font-black tracking-tight" id="modalPatientName">Patient Name</h3>
                <button onclick="closeModal()" class="absolute top-6 right-6 w-8 h-8 rounded-full bg-white/20 hover:bg-white/30 text-white flex items-center justify-center transition-all group active:scale-90">
                    <span class="material-symbols-outlined text-lg font-black group-hover:rotate-90 transition-transform">close</span>
                </button>
            </div>

            <!-- Modal Body -->
            <div class="p-8 space-y-8">
                <div class="grid grid-cols-2 gap-6">
                    <div class="space-y-1">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Time & Status</p>
                        <div class="flex items-center gap-2">
                            <span class="text-lg font-extrabold text-slate-800" id="modalTime">09:00</span>
                            <span class="px-3 py-1 text-[10px] font-black uppercase rounded-full bg-blue-50 text-blue-600 border border-blue-100" id="modalStatus">Confirmed</span>
                        </div>
                    </div>
                    <div class="space-y-1">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Date</p>
                        <span class="text-lg font-extrabold text-slate-800" id="modalDate">March 25, 2026</span>
                    </div>
                </div>

                <div class="space-y-2">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Reason for Visit</p>
                    <div class="p-5 bg-slate-50 rounded-2xl border border-slate-100 flex items-start gap-4">
                        <span class="material-symbols-outlined text-primary text-2xl">stethoscope</span>
                        <p class="text-slate-700 font-bold leading-relaxed" id="modalReason">General Checkup</p>
                    </div>
                </div>

                <div class="space-y-2">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Additional Notes</p>
                    <p class="text-slate-500 font-medium italic pl-1" id="modalNotes">No notes available.</p>
                </div>

                <div class="flex gap-4 pt-4">
                    <button class="flex-1 py-4 bg-slate-100 hover:bg-slate-200 text-slate-600 font-black rounded-2xl active:scale-[0.98] transition-all" onclick="closeModal()">
                        Close
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        const allAppointments = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Appointments));

        function showAppointmentDetails(id) {
            const appt = allAppointments.find(a => a.AppointmentId === id);
            if (!appt) return;

            document.getElementById('modalPatientName').textContent = appt.PatientName;
            document.getElementById('modalTime').textContent = appt.AppointmentTime.substring(0, 5); // hh:mm
            document.getElementById('modalStatus').textContent = appt.Status;
            document.getElementById('modalDate').textContent = new Date(appt.AppointmentDate).toLocaleDateString(undefined, { month: 'long', day: 'numeric', year: 'numeric' });
            document.getElementById('modalReason').textContent = appt.ReasonForVisit;
            document.getElementById('modalNotes').textContent = appt.AdditionalNotes || "No additional notes.";

            const modal = document.getElementById('appointmentModal');
            const content = document.getElementById('modalContent');
            
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            
            setTimeout(() => {
                modal.classList.add('opacity-100');
                content.classList.remove('scale-95', 'opacity-0');
                content.classList.add('scale-100', 'opacity-100');
            }, 10);
        }

        function closeModal() {
            const modal = document.getElementById('appointmentModal');
            const content = document.getElementById('modalContent');
            
            content.classList.remove('scale-100', 'opacity-100');
            content.classList.add('scale-95', 'opacity-0');
            
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex', 'opacity-100');
            }, 300);
        }

        // Close on escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeModal();
        });

        // Close on click outside
        document.getElementById('appointmentModal').addEventListener('click', (e) => {
            if (e.target === document.getElementById('appointmentModal')) closeModal();
        });

        // Anti-FOUC show body
        window.addEventListener('load', () => {
            document.body.classList.add('ready');
        });
    </script>
</body>
</html>
