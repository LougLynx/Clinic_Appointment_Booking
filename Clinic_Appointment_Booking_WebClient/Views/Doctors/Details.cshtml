@model BussinessObjects.DTOs.DoctorDetailDTO
@{
    ViewData["Title"] = $"{Model.FullName} - Doctor Profile";
    Layout = "_LayoutMediClinic";
    var isLoggedIn = Context.Session.GetString("AccessToken") != null;
}

<!-- Back Button -->
<div class="mb-8 px-4">
    <a asp-area="" asp-controller="Doctors" asp-action="Index" class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-primary transition-colors no-underline">
        <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19 11H7.83l4.58-4.59a1 1 0 1 0-1.41-1.41l-6.3 6.3a1 1 0 0 0 0 1.42l6.3 6.3a1 1 0 1 0 1.41-1.41L7.83 13H19a1 1 0 1 0 0-2Z"/>
        </svg>
        Back to Directory
    </a>
</div>

<!-- Main Content -->
<div class="flex flex-col lg:flex-row gap-8 px-4">
    <!-- Left Column - Doctor Info -->
    <div class="flex-1 flex flex-col gap-8">
        <!-- Doctor Header Card -->
        <div class="bg-white dark:bg-slate-900 rounded-xl overflow-hidden border border-slate-200 dark:border-slate-700 shadow-sm p-6 lg:p-8 flex flex-col md:flex-row gap-8 items-start">
            <div class="w-full md:w-48 h-48 md:h-auto shrink-0 bg-slate-200 dark:bg-slate-800 rounded-lg overflow-hidden relative">
                @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                {
                    <img alt="@Model.FullName, @Model.SpecialtyName" class="w-full h-full object-cover aspect-square" src="@Model.ProfilePictureUrl" />
                }
                else
                {
                    <div class="w-full h-full flex items-center justify-center text-slate-400">
                        <svg class="h-24 w-24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-4.418 0-8 2.239-8 5v1a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-1c0-2.761-3.582-5-8-5Z"/>
                        </svg>
                    </div>
                }
            </div>
            <div class="flex-1">
                <div class="flex justify-between items-start mb-2">
                    <div>
                        <h1 class="text-3xl font-black text-slate-900 dark:text-white leading-tight mb-1">@Model.FullName</h1>
                        <p class="text-primary text-lg font-medium mb-3">@Model.SpecialtyName</p>
                    </div>
                    <div class="flex items-center gap-1 bg-primary/10 dark:bg-primary/20 px-3 py-1.5 rounded-lg text-primary font-bold">
                        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M12 3.5 9.25 9.3 3 10l4.6 4.2L6.4 20.5 12 17.2l5.6 3.3-1.2-6.3L21 10l-6.25-.7L12 3.5Z"/>
                        </svg>
                        @Model.Rating.ToString("0.0")
                    </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
                    <div class="flex items-center gap-3 text-slate-600 dark:text-slate-400">
                        <svg class="h-5 w-5 text-primary/80" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M9 4a2 2 0 0 0-2 2v1H5a3 3 0 0 0-3 3v6a3 3 0 0 0 3 3h14a3 3 0 0 0 3-3v-6a3 3 0 0 0-3-3h-2V6a2 2 0 0 0-2-2H9Zm0 2h6v1H9V6Zm-5 6h16v4a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-4Z"/>
                        </svg>
                        <span>@Model.YearsOfExperience Years Experience</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Location))
                    {
                        <div class="flex items-center gap-3 text-slate-600 dark:text-slate-400">
                            <svg class="h-5 w-5 text-primary/80" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M12 2a7 7 0 0 0-7 7c0 5.25 6.2 11.5 6.45 11.76a1 1 0 0 0 1.42 0C12.8 20.5 19 14.25 19 9a7 7 0 0 0-7-7Zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5Z"/>
                            </svg>
                            <span>@Model.Location</span>
                        </div>
                    }
                    @if (Model.Languages != null && Model.Languages.Count > 0)
                    {
                        <div class="flex items-center gap-3 text-slate-600 dark:text-slate-400">
                            <svg class="h-5 w-5 text-primary/80" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm6.93 9H15.9a15.6 15.6 0 0 0-1.15-5.1A8.02 8.02 0 0 1 18.93 11ZM12 4.07A13.6 13.6 0 0 1 13.85 11h-3.7A13.6 13.6 0 0 1 12 4.07ZM5.07 13H8.1a15.6 15.6 0 0 0 1.15 5.1A8.02 8.02 0 0 1 5.07 13Zm0-2A8.02 8.02 0 0 1 9.25 5.9 15.6 15.6 0 0 0 8.1 11Zm6.93 8.93A13.6 13.6 0 0 1 10.15 13h3.7A13.6 13.6 0 0 1 12 19.93ZM14.75 18.1A15.6 15.6 0 0 0 15.9 13h3.03a8.02 8.02 0 0 1-4.18 5.1Z"/>
                            </svg>
                            <span>@string.Join(", ", Model.Languages)</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Education))
                    {
                        <div class="flex items-center gap-3 text-slate-600 dark:text-slate-400">
                            <svg class="h-5 w-5 text-primary/80" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M12 3 1 9l11 6 9-4.91V17h2V9L12 3Zm-6 9.43V16l6 3.27L18 16v-3.57l-6 3.27-6-3.27Z"/>
                            </svg>
                            <span>@Model.Education</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Gender))
                    {
                        <div class="flex items-center gap-3 text-slate-600 dark:text-slate-400">
                            @if (Model.Gender == "Male")
                            {
                                <svg class="h-5 w-5 text-primary/80" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                    <path d="M15 2h7v7h-2V5.41l-4.16 4.16A6 6 0 1 1 12 6a5.94 5.94 0 0 1 2.41.5L18.59 2.3H15V2ZM8 12a4 4 0 1 0 4-4 4 4 0 0 0-4 4Z"/>
                                </svg>
                            }
                            else
                            {
                                <svg class="h-5 w-5 text-primary/80" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                    <path d="M12 2a6 6 0 0 0-1 11.92V17H9a1 1 0 0 0 0 2h2v2a1 1 0 0 0 2 0v-2h2a1 1 0 0 0 0-2h-2v-3.08A6 6 0 0 0 12 2Zm0 2a4 4 0 1 1-4 4 4 4 0 0 1 4-4Z"/>
                                </svg>
                            }
                            <span>@Model.Gender</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                    {
                        <div class="flex items-center gap-3 text-slate-600 dark:text-slate-400">
                            <svg class="h-5 w-5 text-primary/80" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M6.6 10.8a15.3 15.3 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24 11.4 11.4 0 0 0 3.6.58 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C11.4 21 3 12.6 3 2a1 1 0 0 1 1-1h3.46a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .58 3.6 1 1 0 0 1-.24 1l-2.2 2.2Z"/>
                            </svg>
                            <span>@Model.PhoneNumber</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- About Me Section -->
        @if (!string.IsNullOrEmpty(Model.Bio))
        {
            <div class="bg-white dark:bg-slate-900 rounded-xl p-6 lg:p-8 border border-slate-200 dark:border-slate-700 shadow-sm">
                <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4 border-b border-slate-100 dark:border-slate-800 pb-2">About Me</h2>
                <p class="text-slate-600 dark:text-slate-400 leading-relaxed whitespace-pre-line">@Model.Bio</p>
            </div>
        }

        <!-- Specializations Section -->
        @if (Model.Specializations != null && Model.Specializations.Any())
        {
            <div class="bg-white dark:bg-slate-900 rounded-xl p-6 lg:p-8 border border-slate-200 dark:border-slate-700 shadow-sm">
                <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4 border-b border-slate-100 dark:border-slate-800 pb-2">Specializations</h2>
                <div class="flex flex-wrap gap-2">
                    @foreach (var specialization in Model.Specializations)
                    {
                        <span class="px-3 py-1.5 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-full text-sm font-medium">@specialization</span>
                    }
                </div>
            </div>
        }

        <!-- Available Time Slots -->
        @if (Model.AvailableTimeSlots != null && Model.AvailableTimeSlots.Any())
        {
            <div class="bg-white dark:bg-slate-900 rounded-xl p-6 lg:p-8 border border-slate-200 dark:border-slate-700 shadow-sm">
                <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4 border-b border-slate-100 dark:border-slate-800 pb-2">Available Time Slots</h2>
                <div class="space-y-4">
                    @foreach (var daySlots in Model.AvailableTimeSlots.GroupBy(s => s.Date.Date).OrderBy(g => g.Key).Take(7))
                    {
                        <div>
                            <h3 class="font-semibold text-slate-900 dark:text-white mb-2">
                                @daySlots.Key.ToString("dddd, MMMM dd, yyyy")
                            </h3>
                            <div class="flex flex-wrap gap-2">
                                @foreach (var slot in daySlots.OrderBy(s => s.StartTime))
                                {
                                    if (slot.IsAvailable)
                                    {
                                        <button class="px-3 py-1.5 text-sm rounded-md border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:border-primary hover:text-primary transition-colors"
                                                onclick="selectTimeSlot('@slot.Date.ToString("yyyy-MM-dd")', '@slot.StartTime.ToString("hh\\:mm")')">
                                            @slot.StartTime.ToString("hh:mm tt")
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="px-3 py-1.5 text-sm rounded-md border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 text-slate-400 dark:text-slate-600 cursor-not-allowed" disabled>
                                            @slot.StartTime.ToString("hh:mm tt")
                                        </button>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Right Column - Booking Sidebar -->
    <aside class="w-full lg:w-80 shrink-0 relative">
        <div class="sticky top-24 bg-white dark:bg-slate-900 rounded-xl p-6 border border-primary/30 shadow-md">
            <h3 class="font-bold text-xl text-slate-900 dark:text-white mb-4">Book Appointment</h3>
            
            <!-- Fee Information -->
            @if (Model.ConsultationFee.HasValue)
            {
                <div class="border-t border-b border-slate-100 dark:border-slate-800 py-4 mb-6">
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-slate-600 dark:text-slate-400">Consultation Fee</span>
                        <span class="font-bold text-slate-900 dark:text-white text-xl">$@Model.ConsultationFee.Value.ToString("N0")</span>
                    </div>
                    <p class="text-xs text-slate-500 dark:text-slate-500">* Insurance may cover partial or full amount</p>
                </div>
            }

            <!-- Quick Stats -->
            <div class="space-y-3 mb-6">
                <div class="flex items-center justify-between text-sm">
                    <span class="text-slate-600 dark:text-slate-400">Experience</span>
                    <span class="font-semibold text-slate-900 dark:text-white">@Model.YearsOfExperience years</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-slate-600 dark:text-slate-400">Rating</span>
                    <span class="font-semibold text-slate-900 dark:text-white">@Model.Rating.ToString("0.0") / 5.0</span>
                </div>
                @if (Model.AvailableTimeSlots != null)
                {
                    var availableCount = Model.AvailableTimeSlots.Count(s => s.IsAvailable);
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-slate-600 dark:text-slate-400">Available Slots</span>
                        <span class="font-semibold text-slate-900 dark:text-white">@availableCount slots</span>
                    </div>
                }
            </div>

            <!-- Book Button: show Login prompt when not logged in -->
            @if (Context.Session.GetString("AccessToken") != null)
            {
                <a asp-area="" asp-controller="Appointment" asp-action="Book" asp-route-doctorId="@Model.DoctorId" 
                   class="w-full flex items-center justify-center rounded-lg h-12 px-4 bg-primary text-white text-base font-bold hover:bg-primary/90 transition-colors shadow-md no-underline">
                    Book Appointment
                </a>
            }
            else
            {
                <a asp-area="" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Url.Action("Book", "Appointment", new { doctorId = Model.DoctorId })" 
                   class="w-full flex items-center justify-center rounded-lg h-12 px-4 bg-primary/80 text-white text-base font-bold hover:bg-primary/90 transition-colors shadow-md no-underline">
                    Login to Book
                </a>
            }

            <!-- Contact Options -->
            <div class="mt-4 pt-4 border-t border-slate-100 dark:border-slate-800">
                <p class="text-xs text-slate-500 dark:text-slate-500 text-center mb-3">Need help booking?</p>
                <div class="flex gap-2">
                    @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                    {
                        <a href="tel:@Model.PhoneNumber" 
                           class="flex-1 flex items-center justify-center gap-1 rounded-lg h-9 px-3 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-sm font-semibold hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors no-underline">
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M6.6 10.8a15.3 15.3 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24 11.4 11.4 0 0 0 3.6.58 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C11.4 21 3 12.6 3 2a1 1 0 0 1 1-1h3.46a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .58 3.6 1 1 0 0 1-.24 1l-2.2 2.2Z"/>
                            </svg>
                            Call
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <a href="mailto:@Model.Email" 
                           class="flex-1 flex items-center justify-center gap-1 rounded-lg h-9 px-3 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-sm font-semibold hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors no-underline">
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M4 5h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Zm0 2v.2l8 4.8 8-4.8V7H4Zm0 10h16V9.3l-7.5 4.5a1 1 0 0 1-1 0L4 9.3V17Z"/>
                            </svg>
                            Email
                        </a>
                    }
                </div>
            </div>
        </div>
    </aside>
</div>

@section Scripts {
    <script>
        function selectTimeSlot(dateStr, timeStr) {
            // Navigate to booking page with selected date/time
            const baseUrl = '@Url.Action("Book", "Appointment", new { doctorId = Model.DoctorId })';
            window.location.href = `${baseUrl}&date=${encodeURIComponent(dateStr)}&time=${encodeURIComponent(timeStr)}`;
        }
    </script>
}
