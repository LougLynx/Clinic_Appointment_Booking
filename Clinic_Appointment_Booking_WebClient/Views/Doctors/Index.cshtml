                           class="flex-1 flex items-center justify-center cursor-pointer rounded-lg h-10 px-4 bg-primary text-white text-sm font-bold hover:bg-primary/90 transition-colors shadow-sm no-underline">
                            Book Now
                        </a>
                    </div>
