                </div>
                <div class="p-5 flex-1 flex flex-col justify-between">
                    <div>
                        <div class="flex justify-between items-start mb-1">
                            <h3 class="text-lg font-bold text-slate-900 dark:text-white leading-tight">Dr. Emily Chen</h3>
                            <button class="text-slate-400 hover:text-red-500 transition-colors">
                                <span class="material-symbols-outlined text-[20px]">favorite_border</span>
                            </button>
                        </div>
                        <p class="text-primary text-sm font-medium mb-2">Cardiology</p>
                        <div class="flex flex-col gap-2 mb-4">
                            <div class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
