@{
    ViewData["Title"] = "Our Doctors Directory";
    Layout = "_LayoutMediClinic";
}

<!-- Page Header -->
<div class="mb-8 px-4">
    <h1 class="text-4xl font-black leading-tight tracking-tight mb-2 text-slate-900 dark:text-white">Our Doctors Directory</h1>
    <p class="text-slate-500 dark:text-slate-400 text-base font-normal leading-normal">Find and book appointments with our top-rated medical professionals.</p>
</div>

<!-- Main Content with Sidebar -->
<div class="flex flex-col lg:flex-row gap-8 px-4">
    <!-- Sidebar Filters -->
    <aside class="w-full lg:w-64 shrink-0 flex flex-col gap-6">
        <!-- Search Box -->
        <div>
            <label class="flex flex-col w-full h-12">
                <div class="flex w-full flex-1 items-stretch rounded-lg h-full border border-slate-200 dark:border-slate-700 overflow-hidden bg-white dark:bg-slate-900 focus-within:ring-2 focus-within:ring-primary focus-within:border-primary">
                    <div class="text-slate-400 dark:text-slate-500 flex items-center justify-center pl-4 bg-transparent">
                        <span class="material-symbols-outlined text-[20px]">search</span>
                    </div>
                    <input class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-r-lg text-slate-900 dark:text-white focus:outline-0 focus:ring-0 border-none bg-transparent h-full placeholder:text-slate-400 dark:placeholder:text-slate-500 px-3 text-sm font-normal leading-normal" 
                           placeholder="Search by name..." 
                           type="text" />
                </div>
            </label>
        </div>

        <!-- Filters Panel -->
        <div class="bg-white dark:bg-slate-900 rounded-xl p-5 border border-slate-200 dark:border-slate-700 shadow-sm">
            <h3 class="font-bold text-slate-900 dark:text-white mb-4">Filters</h3>

            <!-- Specialty Filter -->
            <div class="mb-5">
                <h4 class="text-sm font-semibold text-slate-700 dark:text-slate-300 mb-3 flex items-center justify-between">
                    Specialty
                    <span class="material-symbols-outlined text-[18px]">expand_more</span>
                </h4>
                <div class="flex flex-col gap-2">
                    <label class="flex items-center gap-3">
                        <input checked class="form-checkbox h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary dark:border-slate-600 dark:bg-slate-800" type="checkbox" />
                        <span class="text-sm text-slate-600 dark:text-slate-400">All Specialties</span>
                    </label>
                    <label class="flex items-center gap-3">
                        <input class="form-checkbox h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary dark:border-slate-600 dark:bg-slate-800" type="checkbox" />
                        <span class="text-sm text-slate-600 dark:text-slate-400">Cardiology</span>
                    </label>
                    <label class="flex items-center gap-3">
                        <input class="form-checkbox h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary dark:border-slate-600 dark:bg-slate-800" type="checkbox" />
                        <span class="text-sm text-slate-600 dark:text-slate-400">Dermatology</span>
                    </label>
                    <label class="flex items-center gap-3">
                        <input class="form-checkbox h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary dark:border-slate-600 dark:bg-slate-800" type="checkbox" />
                        <span class="text-sm text-slate-600 dark:text-slate-400">Neurology</span>
                    </label>
                    <label class="flex items-center gap-3">
                        <input class="form-checkbox h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary dark:border-slate-600 dark:bg-slate-800" type="checkbox" />
                        <span class="text-sm text-slate-600 dark:text-slate-400">Pediatrics</span>
                    </label>
                    <a class="text-xs text-primary font-medium mt-1 hover:underline" href="#">Show more</a>
                </div>
            </div>

            <!-- Availability Filter -->
            <div class="mb-5 border-t border-slate-100 dark:border-slate-800 pt-5">
                <h4 class="text-sm font-semibold text-slate-700 dark:text-slate-300 mb-3 flex items-center justify-between">
                    Availability
                    <span class="material-symbols-outlined text-[18px]">expand_more</span>
                </h4>
                <div class="flex flex-col gap-2">
                    <label class="flex items-center gap-3">
                        <input checked class="form-radio h-4 w-4 border-slate-300 text-primary focus:ring-primary dark:border-slate-600 dark:bg-slate-800" name="availability" type="radio" />
                        <span class="text-sm text-slate-600 dark:text-slate-400">Anytime</span>
                    </label>
                    <label class="flex items-center gap-3">
                        <input class="form-radio h-4 w-4 border-slate-300 text-primary focus:ring-primary dark:border-slate-600 dark:bg-slate-800" name="availability" type="radio" />
                        <span class="text-sm text-slate-600 dark:text-slate-400">Available Today</span>
                    </label>
                    <label class="flex items-center gap-3">
                        <input class="form-radio h-4 w-4 border-slate-300 text-primary focus:ring-primary dark:border-slate-600 dark:bg-slate-800" name="availability" type="radio" />
                        <span class="text-sm text-slate-600 dark:text-slate-400">Available Tomorrow</span>
                    </label>
                    <label class="flex items-center gap-3">
                        <input class="form-radio h-4 w-4 border-slate-300 text-primary focus:ring-primary dark:border-slate-600 dark:bg-slate-800" name="availability" type="radio" />
                        <span class="text-sm text-slate-600 dark:text-slate-400">Next 7 Days</span>
                    </label>
                </div>
            </div>

            <!-- Gender Filter -->
            <div class="border-t border-slate-100 dark:border-slate-800 pt-5">
                <h4 class="text-sm font-semibold text-slate-700 dark:text-slate-300 mb-3 flex items-center justify-between">
                    Gender
                    <span class="material-symbols-outlined text-[18px]">expand_more</span>
                </h4>
                <div class="flex flex-col gap-2">
                    <label class="flex items-center gap-3">
                        <input checked class="form-checkbox h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary dark:border-slate-600 dark:bg-slate-800" type="checkbox" />
                        <span class="text-sm text-slate-600 dark:text-slate-400">Any</span>
                    </label>
                    <label class="flex items-center gap-3">
                        <input class="form-checkbox h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary dark:border-slate-600 dark:bg-slate-800" type="checkbox" />
                        <span class="text-sm text-slate-600 dark:text-slate-400">Female</span>
                    </label>
                    <label class="flex items-center gap-3">
                        <input class="form-checkbox h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary dark:border-slate-600 dark:bg-slate-800" type="checkbox" />
                        <span class="text-sm text-slate-600 dark:text-slate-400">Male</span>
                    </label>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Content Area -->
    <div class="flex-1 flex flex-col gap-6">
        <!-- Results Header -->
        <div class="flex justify-between items-center bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm">
            <p class="text-sm text-slate-500 dark:text-slate-400">
                Showing <span class="font-bold text-slate-900 dark:text-white">1-4</span> of <span class="font-bold text-slate-900 dark:text-white">42</span> doctors
            </p>
            <div class="flex items-center gap-2">
                <span class="text-sm text-slate-500 dark:text-slate-400">Sort by:</span>
                <button class="flex items-center gap-1 text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-primary dark:hover:text-primary transition-colors">
                    Recommended
                    <span class="material-symbols-outlined text-[18px]">swap_vert</span>
                </button>
            </div>
        </div>

        <!-- Doctor Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2 gap-6">
