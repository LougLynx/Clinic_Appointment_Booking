@{
    ViewData["Title"] = "Contact Us";
    Layout = "_LayoutMediClinic";
}

<!-- Page Header -->
<div class="mb-10 px-4">
    <h1 class="text-4xl md:text-5xl font-black leading-tight tracking-tight mb-4 text-slate-900 dark:text-slate-100">Contact Us</h1>
    <p class="text-lg text-slate-700 dark:text-slate-300">Get in touch with us for any inquiries, appointment bookings, or feedback. We are here to help.</p>
</div>

<!-- Main Content -->
<div class="flex flex-col lg:flex-row gap-12 px-4">
    <!-- Contact Form -->
    <div class="w-full lg:w-1/2 bg-white dark:bg-slate-900 rounded-2xl p-6 md:p-8 shadow-sm border border-slate-200 dark:border-slate-800">
        <h2 class="text-2xl font-bold mb-6 text-slate-900 dark:text-slate-100">Send us a Message</h2>
        
        <form asp-area="" asp-controller="Home" asp-action="Contact" method="post" class="space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

            <!-- Name Fields -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" for="firstName">First Name</label>
                    <input name="FirstName" 
                           class="w-full px-4 py-3 rounded-lg border border-slate-300 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" 
                           id="firstName" 
                           placeholder="John" 
                           type="text" 
                           required />
                    @* <span asp-validation-for="FirstName" class="text-red-600 text-xs mt-1"></span> *@
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" for="lastName">Last Name</label>
                    <input name="LastName" 
                           class="w-full px-4 py-3 rounded-lg border border-slate-300 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" 
                           id="lastName" 
                           placeholder="Doe" 
                           type="text" 
                           required />
                    @* <span asp-validation-for="LastName" class="text-red-600 text-xs mt-1"></span> *@
                </div>
            </div>

            <!-- Email -->
            <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" for="email">Email Address</label>
                <input name="Email" 
                       class="w-full px-4 py-3 rounded-lg border border-slate-300 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" 
                       id="email" 
                       placeholder="john.doe@example.com" 
                       type="email" 
                       required />
                @* <span asp-validation-for="Email" class="text-red-600 text-xs mt-1"></span> *@
            </div>

            <!-- Subject -->
            <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" for="subject">Subject</label>
                <input name="Subject" 
                       class="w-full px-4 py-3 rounded-lg border border-slate-300 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" 
                       id="subject" 
                       placeholder="How can we help you?" 
                       type="text" 
                       required />
                @* <span asp-validation-for="Subject" class="text-red-600 text-xs mt-1"></span> *@
            </div>

            <!-- Message -->
            <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" for="message">Message</label>
                <textarea name="Message" 
                          class="w-full px-4 py-3 rounded-lg border border-slate-300 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent min-h-[150px] resize-y transition-all" 
                          id="message" 
                          placeholder="Write your message here..." 
                          required></textarea>
                @* <span asp-validation-for="Message" class="text-red-600 text-xs mt-1"></span> *@
            </div>

            <!-- Submit Button -->
            <button class="w-full flex items-center justify-center rounded-lg h-12 px-6 bg-primary text-white text-base font-bold leading-normal hover:bg-primary/90 transition-colors shadow-md" 
                    type="submit">
                Send Message
            </button>
        </form>
    </div>

    <!-- Contact Information -->
    <div class="w-full lg:w-1/2 flex flex-col gap-8">
        <!-- Contact Details Card -->
        <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 md:p-8 shadow-sm border border-slate-200 dark:border-slate-800">
            <h2 class="text-2xl font-bold mb-6 text-slate-900 dark:text-slate-100">Contact Information</h2>
            
            <div class="space-y-6">
                <!-- Location -->
                <div class="flex items-start gap-4">
                    <div class="bg-primary/10 dark:bg-primary/20 p-3 rounded-full text-primary mt-1 shrink-0">
                        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M12 2a7 7 0 0 0-7 7c0 5.25 6.2 11.5 6.45 11.76a1 1 0 0 0 1.42 0C12.8 20.5 19 14.25 19 9a7 7 0 0 0-7-7Zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5Z"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-lg mb-1 text-slate-900 dark:text-slate-100">Our Location</h3>
                        <p class="text-slate-700 dark:text-slate-300 leading-relaxed">
                            123 Health Avenue, Medical District<br />
                            New York, NY 10001
                        </p>
                    </div>
                </div>

                <!-- Phone -->
                <div class="flex items-start gap-4">
                    <div class="bg-primary/10 dark:bg-primary/20 p-3 rounded-full text-primary mt-1 shrink-0">
                        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M6.6 10.8a15.3 15.3 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24 11.4 11.4 0 0 0 3.6.58 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C11.4 21 3 12.6 3 2a1 1 0 0 1 1-1h3.46a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .58 3.6 1 1 0 0 1-.24 1l-2.2 2.2Z"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-lg mb-1 text-slate-900 dark:text-slate-100">Phone Number</h3>
                        <p class="text-slate-700 dark:text-slate-300">
                            Main: <a href="tel:+15551234567" class="text-primary hover:underline">(555) 123-4567</a><br />
                            Emergency: <a href="tel:+15559876543" class="text-primary hover:underline">(555) 987-6543</a>
                        </p>
                    </div>
                </div>

                <!-- Email -->
                <div class="flex items-start gap-4">
                    <div class="bg-primary/10 dark:bg-primary/20 p-3 rounded-full text-primary mt-1 shrink-0">
                        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M4 5h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Zm0 2v.2l8 4.8 8-4.8V7H4Zm0 10h16V9.3l-7.5 4.5a1 1 0 0 1-1 0L4 9.3V17Z"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-lg mb-1 text-slate-900 dark:text-slate-100">Email Address</h3>
                        <p class="text-slate-700 dark:text-slate-300">
                            <a href="mailto:info@mediclinic.com" class="text-primary hover:underline">info@mediclinic.com</a><br />
                            <a href="mailto:appointments@mediclinic.com" class="text-primary hover:underline">appointments@mediclinic.com</a>
                        </p>
                    </div>
                </div>

                <!-- Operating Hours -->
                <div class="flex items-start gap-4">
                    <div class="bg-primary/10 dark:bg-primary/20 p-3 rounded-full text-primary mt-1 shrink-0">
                        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm1 11h4a1 1 0 0 1 0 2h-5a1 1 0 0 1-1-1V7a1 1 0 0 1 2 0Z"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-lg mb-1 text-slate-900 dark:text-slate-100">Operating Hours</h3>
                        <p class="text-slate-700 dark:text-slate-300">
                            Mon - Fri: 8:00 AM - 8:00 PM<br />
                            Saturday: 9:00 AM - 5:00 PM<br />
                            Sunday: Closed
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Map Placeholder -->
        <div class="bg-slate-200 dark:bg-slate-800 rounded-2xl h-64 md:h-80 w-full overflow-hidden relative shadow-sm border border-slate-200 dark:border-slate-800">
            <div class="absolute inset-0 flex items-center justify-center text-slate-500 dark:text-slate-400 flex-col gap-2">
                <svg class="h-9 w-9" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M9 4 4 6v14l5-2 6 2 5-2V4l-5 2-6-2Zm0 2.18L13 7.5v10.32l-4-1.33V6.18Zm6 1.32 3-1.2v10.02l-3 1.2V7.5Z"/>
                </svg>
                <span class="font-medium">Interactive Map Integration</span>
                <p class="text-sm text-slate-400">Google Maps or similar service</p>
            </div>
        </div>

        <!-- Social Links -->
        <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
            <h3 class="font-bold text-lg mb-4 text-slate-900 dark:text-slate-100">Follow Us</h3>
            <div class="flex items-center gap-4">
                <a href="#" class="w-10 h-10 rounded-full bg-primary/10 dark:bg-primary/20 hover:bg-primary hover:text-white text-primary flex items-center justify-center transition-colors">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm6.93 9H15.9a15.6 15.6 0 0 0-1.15-5.1A8.02 8.02 0 0 1 18.93 11ZM12 4.07A13.6 13.6 0 0 1 13.85 11h-3.7A13.6 13.6 0 0 1 12 4.07ZM5.07 13H8.1a15.6 15.6 0 0 0 1.15 5.1A8.02 8.02 0 0 1 5.07 13Zm0-2A8.02 8.02 0 0 1 9.25 5.9 15.6 15.6 0 0 0 8.1 11Zm6.93 8.93A13.6 13.6 0 0 1 10.15 13h3.7A13.6 13.6 0 0 1 12 19.93ZM14.75 18.1A15.6 15.6 0 0 0 15.9 13h3.03a8.02 8.02 0 0 1-4.18 5.1Z"/>
                    </svg>
                </a>
                <a href="#" class="w-10 h-10 rounded-full bg-primary/10 dark:bg-primary/20 hover:bg-primary hover:text-white text-primary flex items-center justify-center transition-colors">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M18 8a3 3 0 0 0-2.82 2H8.82a3 3 0 0 0 0 4h6.36A3 3 0 1 0 18 8Zm0-2a5 5 0 0 1 5 5 5 5 0 0 1-7.9 4H8.9A5 5 0 1 1 8 9h6.1A5 5 0 0 1 18 6Z"/>
                    </svg>
                </a>
                <a href="#" class="w-10 h-10 rounded-full bg-primary/10 dark:bg-primary/20 hover:bg-primary hover:text-white text-primary flex items-center justify-center transition-colors">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M4 4h12a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H9l-4.3 3.2A1 1 0 0 1 3 18.4V7a3 3 0 0 1 3-3Zm2 5h8a1 1 0 0 1 0 2H6a1 1 0 0 1 0-2Zm0 4h5a1 1 0 0 1 0 2H6a1 1 0 0 1 0-2Z"/>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</div>
