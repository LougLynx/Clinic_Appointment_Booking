                    <img alt="Patient review" 
                         class="w-10 h-10 rounded-full border-2 border-white dark:border-slate-900 object-cover" 
                         src="https://lh3.googleusercontent.com/aida-public/AB6AXuBP0ngpVl5dlHtIm61Ne7kdxVhjovowLEVYWsWz-cpRjviBu64HD_7rkSDeSuGIJnA8PYKfxcWdR0Knn1IFYC7Q13x6CSF8jJIEURv-KWXPxicm2SuJB6aMr3DISI-S1iGu_qxpPxeW04NuvFRU1JNdIjpL8GmALr4PoSqD_2JjpIc690kNveCoc204vpJ8YXaX9l3X5QaDbKfpHkGEdsVYE_sbcYYKWujTGAc6WKdUTEdH4fyizoS6D0KumKCWl5f3kb3Rg6ZP7OB9" />
                    <img alt="Patient review" 
