@{
    ViewData["Title"] = "Home Page";
    Layout = "_LayoutMediClinic";
}

@section Styles {
    <style>
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        
        /* Background decorations */
        .bg-decoration {
            position: absolute;
            pointer-events: none;
            z-index: 0;
        }
    </style>
}

<!-- Background Decorations -->
<div class="bg-decoration top-32 left-8 text-primary/10 rotate-12 hidden lg:block">
    <span class="material-symbols-outlined text-[150px]">ecg_heart</span>
</div>
<div class="bg-decoration top-1/2 right-10 text-primary/10 -rotate-12 hidden lg:block">
    <span class="material-symbols-outlined text-[200px]">genetics</span>
</div>
<div class="bg-decoration bottom-1/4 left-1/4 text-primary/5 rotate-45 hidden lg:block">
    <span class="material-symbols-outlined text-[120px]">medical_services</span>
</div>

<!-- Hero Section with Image Carousel -->
<section class="@("container") px-4 lg:px-8 mb-20 relative z-10 section-separator">
    <div class="flex flex-col gap-8 lg:flex-row-reverse items-center bg-white dark:bg-slate-900 rounded-3xl premium-shadow border border-slate-100 dark:border-slate-800 overflow-hidden">
        <!-- Image Carousel -->
        <div class="relative w-full lg:w-1/2 min-h-[400px] lg:h-[550px] group">
            <div id="carousel" class="flex w-full h-full snap-x snap-mandatory overflow-x-auto hide-scrollbar">
                <!-- Slide 1 -->
                <div class="w-full h-full flex-shrink-0 snap-center relative">
                    <img alt="High-Tech Diagnostic Equipment" class="w-full h-full object-cover" 
                         src="https://images.pexels.com/photos/9574453/pexels-photo-9574453.jpeg?auto=compress&cs=tinysrgb&w=1600" />
                    <div class="absolute inset-0 bg-slate-900/30"></div>
                    <div class="absolute bottom-8 left-8 bg-white/90 dark:bg-slate-900/90 backdrop-blur-sm px-5 py-3 rounded-xl shadow-lg border border-white/20">
                        <p class="text-sm font-bold text-primary mb-1 uppercase tracking-wider">State of the art</p>
                        <p class="text-lg font-black text-slate-800 dark:text-slate-100">High-Tech Diagnostics</p>
                    </div>
                </div>
                
                <!-- Slide 2 -->
                <div class="w-full h-full flex-shrink-0 snap-center relative">
                    <img alt="Doctor-Patient Consultation" class="w-full h-full object-cover" 
                         src="https://images.pexels.com/photos/7108157/pexels-photo-7108157.jpeg?auto=compress&cs=tinysrgb&w=1600" />
                    <div class="absolute inset-0 bg-slate-900/30"></div>
                    <div class="absolute bottom-8 left-8 bg-white/90 dark:bg-slate-900/90 backdrop-blur-sm px-5 py-3 rounded-xl shadow-lg border border-white/20">
                        <p class="text-sm font-bold text-primary mb-1 uppercase tracking-wider">Compassionate</p>
                        <p class="text-lg font-black text-slate-800 dark:text-slate-100">Friendly Expert Care</p>
                    </div>
                </div>
                
                <!-- Slide 3 -->
                <div class="w-full h-full flex-shrink-0 snap-center relative">
                    <img alt="Modern Laboratory Facility" class="w-full h-full object-cover" 
                         src="https://images.pexels.com/photos/11661517/pexels-photo-11661517.jpeg?auto=compress&cs=tinysrgb&w=1600" />
                    <div class="absolute inset-0 bg-slate-900/30"></div>
                    <div class="absolute bottom-8 left-8 bg-white/90 dark:bg-slate-900/90 backdrop-blur-sm px-5 py-3 rounded-xl shadow-lg border border-white/20">
                        <p class="text-sm font-bold text-primary mb-1 uppercase tracking-wider">Precision</p>
                        <p class="text-lg font-black text-slate-800 dark:text-slate-100">Modern Laboratories</p>
                    </div>
                </div>
            </div>
            
            <!-- Carousel Indicators -->
            <div class="absolute bottom-6 right-6 flex gap-2">
                <div class="carousel-dot w-8 h-2 rounded-full bg-primary shadow-sm"></div>
                <div class="carousel-dot w-2 h-2 rounded-full bg-white/60 shadow-sm"></div>
                <div class="carousel-dot w-2 h-2 rounded-full bg-white/60 shadow-sm"></div>
            </div>
            
            <!-- Navigation Arrows -->
            <button onclick="prevSlide()" class="absolute top-1/2 left-4 -translate-y-1/2 w-10 h-10 bg-white/80 dark:bg-slate-900/80 rounded-full flex items-center justify-center text-slate-800 dark:text-slate-200 shadow-lg hover:bg-white transition-colors opacity-0 group-hover:opacity-100">
                <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <button onclick="nextSlide()" class="absolute top-1/2 right-4 -translate-y-1/2 w-10 h-10 bg-white/80 dark:bg-slate-900/80 rounded-full flex items-center justify-center text-slate-800 dark:text-slate-200 shadow-lg hover:bg-white transition-colors opacity-0 group-hover:opacity-100">
                <span class="material-symbols-outlined">chevron_right</span>
            </button>
        </div>
        
        <!-- Hero Content -->
        <div class="flex flex-col gap-8 p-8 lg:p-12 lg:w-1/2">
            <div class="flex flex-col gap-4 text-left">
                <span class="text-primary font-bold tracking-wider uppercase text-sm">Trusted Healthcare</span>
                <h1 class="text-4xl md:text-5xl font-black leading-tight tracking-tight text-slate-900 dark:text-slate-100">
                    Expert Medical Care <br />You Can Trust
                </h1>
                <p class="text-slate-600 dark:text-slate-400 text-lg leading-relaxed max-w-md">
                    Book an appointment with our experienced doctors today and get the personalized care you and your family deserve.
                </p>
            </div>
            
            <!-- Search Form -->
            <div class="w-full max-w-[500px] relative z-20">
                <form asp-area="" asp-controller="Doctors" asp-action="Search" method="get">
                    <div class="flex w-full items-stretch rounded-xl h-14 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-md overflow-hidden focus-within:ring-4 focus-within:ring-primary/20 transition-all">
                        <div class="flex items-center justify-center pl-4 text-slate-400">
                            <span class="material-symbols-outlined">search</span>
                        </div>
                        <input name="query" 
                               class="w-full bg-transparent border-none text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-0 px-3 text-base placeholder-slate-400" 
                               placeholder="Search doctors or specialties..." 
                               type="text" />
                        <button type="submit" 
                                class="flex items-center justify-center px-6 bg-primary text-white font-bold text-sm tracking-wide hover:bg-primary/90 transition-colors">
                            Search
                        </button>
                    </div>
                </form>
            </div>

            <!-- Reviews Section -->
            <div class="flex items-center gap-4 mt-2">
                <div class="flex -space-x-3">
