                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
                    </div>
                    <p class="text-slate-600 dark:text-slate-400 font-medium mt-1">4.9/5 from over 2,000 reviews</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="@("container") px-4 lg:px-8 mb-20 relative z-10 section-separator">
    <div class="flex flex-col gap-10">
        <div class="flex flex-col gap-4 text-center items-center">
            <h2 class="text-3xl md:text-4xl font-black leading-tight tracking-tight text-slate-900 dark:text-slate-100 max-w-2xl">
                Why Choose MediClinic
            </h2>
            <p class="text-slate-600 dark:text-slate-400 text-lg max-w-2xl">
                We are committed to providing the highest quality medical services with compassion and state-of-the-art facilities.
            </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Feature 1 -->
            <div class="flex flex-col items-center text-center gap-4 rounded-3xl border border-slate-100 dark:border-slate-800 bg-white dark:bg-slate-900 p-8 premium-shadow transition-all duration-300">
                <div class="w-16 h-16 rounded-full bg-primary/20 flex items-center justify-center text-primary mb-2 shadow-inner">
                    <span class="material-symbols-outlined text-3xl">stethoscope</span>
                </div>
                <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100">Expert Doctors</h3>
                <p class="text-slate-600 dark:text-slate-400">Our team consists of highly qualified, board-certified professionals dedicated to your health.</p>
            </div>
            
            <!-- Feature 2 -->
            <div class="flex flex-col items-center text-center gap-4 rounded-3xl border border-slate-100 dark:border-slate-800 bg-white dark:bg-slate-900 p-8 premium-shadow transition-all duration-300">
                <div class="w-16 h-16 rounded-full bg-primary/20 flex items-center justify-center text-primary mb-2 shadow-inner">
                    <span class="material-symbols-outlined text-3xl">biotech</span>
                </div>
                <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100">Modern Equipment</h3>
                <p class="text-slate-600 dark:text-slate-400">We utilize the latest medical equipment and technology for fast, accurate diagnoses.</p>
            </div>
            
            <!-- Feature 3 -->
            <div class="flex flex-col items-center text-center gap-4 rounded-3xl border border-slate-100 dark:border-slate-800 bg-white dark:bg-slate-900 p-8 premium-shadow transition-all duration-300">
                <div class="w-16 h-16 rounded-full bg-primary/20 flex items-center justify-center text-primary mb-2 shadow-inner">
                    <span class="material-symbols-outlined text-3xl">support_agent</span>
                </div>
                <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100">24/7 Support</h3>
                <p class="text-slate-600 dark:text-slate-400">Our medical support team is available round-the-clock to assist you with any emergencies.</p>
            </div>
        </div>
    </div>
</section>

<!-- Facilities Section -->
<section class="@("container") px-4 lg:px-8 mb-16 relative z-10 w-full">
    <div class="flex flex-col gap-10">
        <div class="flex flex-col gap-4 text-center items-center">
            <h2 class="text-3xl md:text-4xl font-black leading-tight tracking-tight text-slate-900 dark:text-slate-100 max-w-2xl">
                Our Facilities
            </h2>
            <p class="text-slate-600 dark:text-slate-400 text-lg max-w-2xl">
                Take a virtual tour of our state-of-the-art clinic designed for your comfort, privacy, and healing.
            </p>
        </div>
        
        <div class="relative group/facilities">
            <!-- Navigation Buttons -->
            <button onclick="prevFacility()" class="absolute -left-4 top-1/2 -translate-y-1/2 w-12 h-12 bg-white dark:bg-slate-900 rounded-full flex items-center justify-center text-slate-800 dark:text-slate-200 shadow-xl border border-slate-100 dark:border-slate-800 hover:bg-primary hover:text-white transition-all z-20 opacity-0 group-hover/facilities:opacity-100 -translate-x-4 group-hover/facilities:translate-x-0">
                <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <button onclick="nextFacility()" class="absolute -right-4 top-1/2 -translate-y-1/2 w-12 h-12 bg-white dark:bg-slate-900 rounded-full flex items-center justify-center text-slate-800 dark:text-slate-200 shadow-xl border border-slate-100 dark:border-slate-800 hover:bg-primary hover:text-white transition-all z-20 opacity-0 group-hover/facilities:opacity-100 translate-x-4 group-hover/facilities:translate-x-0">
                <span class="material-symbols-outlined">chevron_right</span>
            </button>

            <div id="facilitiesCarousel" class="flex gap-8 overflow-x-auto snap-x snap-mandatory hide-scrollbar pb-8 pt-2 px-2 scroll-smooth">
                <!-- Facility 1 -->
                <div class="min-w-[320px] md:min-w-[450px] h-[320px] rounded-3xl overflow-hidden snap-center flex-shrink-0 premium-shadow border border-slate-100 dark:border-slate-800 relative group">
                    <img alt="Welcoming Reception Area" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
                         src="https://images.pexels.com/photos/33812025/pexels-photo-33812025.jpeg?auto=compress&cs=tinysrgb&w=1600" />
                    <div class="absolute inset-0 bg-slate-900/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                        <h4 class="text-white font-bold text-xl">Welcoming Reception</h4>
                    </div>
                </div>
                
                <!-- Facility 2 -->
                <div class="min-w-[320px] md:min-w-[450px] h-[320px] rounded-3xl overflow-hidden snap-center flex-shrink-0 premium-shadow border border-slate-100 dark:border-slate-800 relative group">
                    <img alt="Private Consultation Rooms" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
                         src="https://images.pexels.com/photos/8312841/pexels-photo-8312841.jpeg?auto=compress&cs=tinysrgb&w=1600" />
                    <div class="absolute inset-0 bg-slate-900/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                        <h4 class="text-white font-bold text-xl">Private Consultation Rooms</h4>
                    </div>
                </div>
                
                <!-- Facility 3 -->
                <div class="min-w-[320px] md:min-w-[450px] h-[320px] rounded-3xl overflow-hidden snap-center flex-shrink-0 premium-shadow border border-slate-100 dark:border-slate-800 relative group">
                    <img alt="Advanced Imaging Center" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
                         src="https://images.pexels.com/photos/7088838/pexels-photo-7088838.jpeg?auto=compress&cs=tinysrgb&w=1600" />
                    <div class="absolute inset-0 bg-slate-900/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                        <h4 class="text-white font-bold text-xl">Advanced Imaging Center</h4>
                    </div>
                </div>
                
                <!-- Facility 4 -->
                <div class="min-w-[320px] md:min-w-[450px] h-[320px] rounded-3xl overflow-hidden snap-center flex-shrink-0 premium-shadow border border-slate-100 dark:border-slate-800 relative group">
                    <img alt="Sterile Operating Theaters" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
                         src="https://images.pexels.com/photos/33916262/pexels-photo-33916262.jpeg?auto=compress&cs=tinysrgb&w=1600" />
                    <div class="absolute inset-0 bg-slate-900/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                        <h4 class="text-white font-bold text-xl">Sterile Operating Theaters</h4>
                    </div>
                </div>
            </div>
            
            <!-- Indicators -->
            <div class="flex justify-center gap-2 mt-4">
                <div class="facility-dot w-8 h-1.5 rounded-full bg-primary transition-all duration-300"></div>
                <div class="facility-dot w-3 h-1.5 rounded-full bg-slate-200 dark:bg-slate-700 transition-all duration-300"></div>
                <div class="facility-dot w-3 h-1.5 rounded-full bg-slate-200 dark:bg-slate-700 transition-all duration-300"></div>
                <div class="facility-dot w-3 h-1.5 rounded-full bg-slate-200 dark:bg-slate-700 transition-all duration-300"></div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // --- Hero Carousel ---
        let currentHeroSlide = 0;
        const heroCarousel = document.getElementById('carousel');
        const heroDots = document.querySelectorAll('.carousel-dot');
        const totalHeroSlides = 3;

        function updateHeroCarousel() {
            if (!heroCarousel) return;
            const slideWidth = heroCarousel.offsetWidth;
            heroCarousel.scrollTo({ left: slideWidth * currentHeroSlide, behavior: 'smooth' });
            
            heroDots.forEach((dot, index) => {
                const isActive = index === currentHeroSlide;
                dot.classList.toggle('w-8', isActive);
                dot.classList.toggle('bg-primary', isActive);
                dot.classList.toggle('w-2', !isActive);
                dot.classList.toggle('bg-white/60', !isActive);
            });
        }

        function nextHeroSlide() {
            currentHeroSlide = (currentHeroSlide + 1) % totalHeroSlides;
            updateHeroCarousel();
        }
        function prevHeroSlide() {
            currentHeroSlide = (currentHeroSlide - 1 + totalHeroSlides) % totalHeroSlides;
            updateHeroCarousel();
        }

        // --- Facilities Carousel ---
        let currentFacilitySlide = 0;
        const facilitiesCarousel = document.getElementById('facilitiesCarousel');
        const facilityDots = document.querySelectorAll('.facility-dot');
        const facilityItemsCount = facilitiesCarousel ? facilitiesCarousel.children.length : 0;

        function updateFacilityCarousel() {
            if (!facilitiesCarousel || !facilitiesCarousel.children[0]) return;
            const itemWidth = facilitiesCarousel.children[0].offsetWidth + 32; 
            facilitiesCarousel.scrollTo({ left: itemWidth * currentFacilitySlide, behavior: 'smooth' });
            
            facilityDots.forEach((dot, index) => {
                const isActive = index === currentFacilitySlide;
                dot.className = isActive 
                    ? 'facility-dot w-8 h-1.5 rounded-full bg-primary transition-all duration-300'
                    : 'facility-dot w-3 h-1.5 rounded-full bg-slate-200 dark:bg-slate-700 transition-all duration-300';
            });
        }

        function nextFacility() {
            currentFacilitySlide = (currentFacilitySlide + 1) % facilityItemsCount;
            updateFacilityCarousel();
        }

        function prevFacility() {
            currentFacilitySlide = (currentFacilitySlide - 1 + facilityItemsCount) % facilityItemsCount;
            updateFacilityCarousel();
        }

        document.addEventListener('DOMContentLoaded', () => {
            // Hero autoplay
            setInterval(nextHeroSlide, 5000);
            
            // Facilities scroll sync
            if (facilitiesCarousel) {
                facilitiesCarousel.addEventListener('scroll', () => {
                    const item = facilitiesCarousel.children[0];
                    if (item) {
                        const newIdx = Math.round(facilitiesCarousel.scrollLeft / (item.offsetWidth + 32));
                        if (newIdx !== currentFacilitySlide && newIdx < facilityItemsCount) {
                            currentFacilitySlide = newIdx;
                            // Update dots locally for smoother scroll response
                            facilityDots.forEach((dot, index) => {
                                const isActive = index === currentFacilitySlide;
                                dot.className = isActive 
                                    ? 'facility-dot w-8 h-1.5 rounded-full bg-primary transition-all duration-300'
                                    : 'facility-dot w-3 h-1.5 rounded-full bg-slate-200 dark:bg-slate-700 transition-all duration-300';
                            });
                        }
                    }
                }, { passive: true });
            }
        });

        // Expose to window for onclick handlers
        window.nextSlide = nextHeroSlide;
        window.prevSlide = prevHeroSlide;
        window.nextFacility = nextFacility;
        window.prevFacility = prevFacility;
    </script>
}
