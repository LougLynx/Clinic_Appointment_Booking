<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediClinic</title>
    
    <!-- Preload critical resources -->
    <link rel="preconnect" href="https://cdn.tailwindcss.com">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <!-- Material Symbols - Load first to prevent icon FOUC -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet" />
    
    <!-- Anti-FOUC & Page Transition Styles -->
    <style>
        /* Modern Anti-FOUC */
        body { 
            opacity: 0; 
            transition: opacity 0.4s ease-out; 
        }
        body.ready { 
            opacity: 1; 
        }

        /* Ensure Material Icons render as blocks to prevent layout shift */
        .material-symbols-outlined {
            display: inline-block;
            font-feature-settings: 'liga';
            -webkit-font-smoothing: antialiased;
        }

        /* Modern separation styles */
        .glass-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.07);
        }

        .section-separator {
            position: relative;
            padding-bottom: 2rem;
            margin-bottom: 2rem;
        }

        .section-separator::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 80%;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(0,0,0,0.05), transparent);
        }

        .premium-shadow {
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04), 0 4px 6px -2px rgba(0, 0, 0, 0.02);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .premium-shadow:hover {
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.08), 0 8px 10px -6px rgba(0, 0, 0, 0.04);
            transform: translateY(-2px);
        }
    </style>
    
    <!-- Reveal Script -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
             // Let tailwind run its check
             setTimeout(() => { document.body.classList.add('ready'); }, 50);
        });
        window.addEventListener('load', () => {
             document.body.classList.add('ready');
        });
    </script>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    
    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#13b6ec",
                        "background-light": "#f6f8f8",
                        "background-dark": "#101d22",
                    },
                    fontFamily: {
                        "display": ["Inter", "Noto Sans", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display">
    <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden group/design-root">
        <div class="layout-container flex h-full grow flex-col">
            <!-- Header -->
            <header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-200 dark:border-slate-800 px-4 sm:px-6 lg:px-10 py-4 bg-white dark:bg-slate-900 shadow-sm sticky top-0 z-50">
                <!-- Logo -->
                <div class="flex items-center gap-4 text-primary">
                    <svg class="h-6 w-6 sm:h-7 sm:w-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 2c-1.657 0-3 1.343-3 3v2H7a3 3 0 0 0-3 3v7a5 5 0 0 0 5 5h6a5 5 0 0 0 5-5v-7a3 3 0 0 0-3-3h-2V5c0-1.657-1.343-3-3-3Zm1 5V5a1 1 0 1 0-2 0v2h2Zm-1 5a1 1 0 0 1 1 1v2h2a1 1 0 1 1 0 2h-2v2a1 1 0 1 1-2 0v-2H9a1 1 0 1 1 0-2h2v-2a1 1 0 0 1 1-1Z"/>
                    </svg>
                    <h2 class="text-lg sm:text-xl font-bold leading-tight tracking-tight text-slate-900 dark:text-slate-100">
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="no-underline text-slate-900 dark:text-slate-100 hover:text-primary transition-colors">MediClinic</a>
                    </h2>
                </div>

                <!-- Desktop Navigation -->
                <div class="hidden lg:flex flex-1 justify-end gap-8 items-center">
                    <nav class="flex items-center gap-8">
                        <a class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "text-primary font-bold border-b-2 border-primary pb-1" : "text-slate-700 dark:text-slate-300") text-sm font-semibold hover:text-primary transition-colors" 
                           asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        <a class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Doctors" ? "text-primary font-bold border-b-2 border-primary pb-1" : "text-slate-700 dark:text-slate-300") text-sm font-semibold hover:text-primary transition-colors" 
                           asp-area="" asp-controller="Doctors" asp-action="Index">Doctors</a>
                        <a class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Specialties" ? "text-primary font-bold border-b-2 border-primary pb-1" : "text-slate-700 dark:text-slate-300") text-sm font-semibold hover:text-primary transition-colors" 
                           asp-area="" asp-controller="Specialties" asp-action="Index">Specialties</a>
                        <a class="@(ViewContext.RouteData.Values["action"]?.ToString() == "About" ? "text-primary font-bold border-b-2 border-primary pb-1" : "text-slate-700 dark:text-slate-300") text-sm font-semibold hover:text-primary transition-colors" 
                           asp-area="" asp-controller="Home" asp-action="About">About Us</a>
                        <a class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "text-primary font-bold border-b-2 border-primary pb-1" : "text-slate-700 dark:text-slate-300") text-sm font-semibold hover:text-primary transition-colors" 
                           asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>
                       
                        @{
                            var navUserRole = Context.Session.GetString("UserRole");
                        }
                        
                        @if (navUserRole == "Admin")
                        {
                            <a class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "text-primary font-bold border-b-2 border-primary pb-1" : "text-slate-700 dark:text-slate-300") text-sm font-semibold hover:text-primary transition-colors flex items-center gap-1" 
                               asp-area="" asp-controller="Admin" asp-action="Dashboard">
                                <span class="material-symbols-outlined text-[18px]">admin_panel_settings</span>
                                Admin
                            </a>
                        }
                        
                        @if (navUserRole == "Doctor")
                        {
                            <a class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Doctor" ? "text-primary font-bold border-b-2 border-primary pb-1" : "text-slate-700 dark:text-slate-300") text-sm font-semibold hover:text-primary transition-colors flex items-center gap-1" 
                               asp-area="" asp-controller="Doctor" asp-action="Dashboard">
                                <span class="material-symbols-outlined text-[18px]">medical_services</span>
                                Doctor
                            </a>
                        }
                    </nav>

                    @{
                        var userName = Context.Session.GetString("UserName");
                        var userEmail = Context.Session.GetString("UserEmail");
                        var userRole = Context.Session.GetString("UserRole");
                        var isLoggedIn = !string.IsNullOrEmpty(userName);
                    }

                    @if (!isLoggedIn)
                    {
                        <!-- Auth Buttons (when not logged in) -->
                        <div class="flex gap-2 items-center">
                            <a asp-area="" asp-controller="Account" asp-action="Login" 
                               class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-4 bg-primary text-white text-sm font-bold hover:bg-primary/90 transition-colors no-underline">
                                <span class="truncate">Login</span>
                            </a>
                            <a asp-area="" asp-controller="Account" asp-action="Register" 
                               class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-4 bg-primary/10 hover:bg-primary/20 text-primary text-sm font-bold transition-colors no-underline">
                                <span class="truncate">Sign Up</span>
                            </a>
                        </div>
                    }
                    else
                    {
                        <!-- User Profile (when logged in) -->
                        <div class="flex items-center gap-3">
                            <div class="relative">
                                <button onclick="toggleUserDropdown()" class="flex items-center gap-2 text-slate-600 dark:text-slate-300 hover:text-primary transition-colors">
                                    <span class="material-symbols-outlined text-[32px]">account_circle</span>
                                    <span class="text-sm font-medium hidden xl:inline">@userName</span>
                                    <span class="material-symbols-outlined text-[18px]" id="userDropdownIcon">expand_more</span>
                                </button>
                                <!-- Dropdown Menu -->
                                <div id="userDropdown" class="hidden absolute right-0 mt-2 w-56 bg-white dark:bg-slate-800 rounded-lg shadow-lg border border-slate-200 dark:border-slate-700 py-2 z-50">
                                    <div class="px-4 py-3 border-b border-slate-200 dark:border-slate-700">
                                        <p class="text-sm font-semibold text-slate-900 dark:text-slate-100">@userName</p>
                                        <p class="text-xs text-slate-500 dark:text-slate-400 truncate">@userEmail</p>
                                        <span class="inline-block mt-1 px-2 py-0.5 text-xs font-semibold rounded-full @(userRole == "Admin" ? "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400" : userRole == "Doctor" ? "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400" : "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400")">
                                            @userRole
                                        </span>
                                    </div>
                                    <a asp-area="" asp-controller="Account" asp-action="Profile" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700 no-underline">
                                        <span class="material-symbols-outlined text-[18px]">person</span>
                                        My Profile
                                    </a>
                                    @if (userRole == "Patient")
                                    {
                                        <a asp-area="" asp-controller="Appointment" asp-action="MyAppointments" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
                                            <span class="material-symbols-outlined text-[18px]">calendar_month</span>
                                            My Appointments
                                        </a>
                                    }
                                    @if (userRole == "Doctor")
                                    {
                                        <a asp-area="" asp-controller="Doctor" asp-action="Dashboard" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
                                            <span class="material-symbols-outlined text-[18px]">dashboard</span>
                                            Doctor Dashboard
                                        </a>
                                    }
                                    @if (userRole == "Admin")
                                    {
                                        <a asp-area="" asp-controller="Admin" asp-action="Dashboard" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
                                            <span class="material-symbols-outlined text-[18px]">admin_panel_settings</span>
                                            Admin Dashboard
                                        </a>
                                    }
                                    <a asp-area="" asp-controller="Account" asp-action="Settings" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700 no-underline">
                                        <span class="material-symbols-outlined text-[18px]">settings</span>
                                        Settings
                                    </a>
                                    <hr class="my-2 border-slate-200 dark:border-slate-700" />
                                    <a asp-area="" asp-controller="Account" asp-action="Logout" class="flex items-center gap-2 px-4 py-2 text-sm text-red-600 hover:bg-slate-100 dark:hover:bg-slate-700">
                                        <span class="material-symbols-outlined text-[18px]">logout</span>
                                        Logout
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Mobile Menu Button -->
                <button class="lg:hidden flex items-center justify-center p-2 text-slate-900 dark:text-slate-100 hover:text-primary transition-colors" 
                        onclick="toggleMobileMenu()">
                    <span class="material-symbols-outlined text-[28px]">menu</span>
                </button>
            </header>

            <!-- Mobile Menu (Hidden by default) -->
            <div id="mobileMenu" class="hidden lg:hidden bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 shadow-lg">
                <nav class="flex flex-col px-4 py-4 gap-2">
                    <a class="px-4 py-3 text-sm font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" 
                       asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    <a class="px-4 py-3 text-sm font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" 
                       asp-area="" asp-controller="Doctors" asp-action="Index">Doctors</a>
                    <a class="px-4 py-3 text-sm font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" 
                       asp-area="" asp-controller="Specialties" asp-action="Index">Specialties</a>
                    <a class="px-4 py-3 text-sm font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" 
                       asp-area="" asp-controller="Home" asp-action="About">About Us</a>
                    <a class="px-4 py-3 text-sm font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" 
                       asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>

                    @if (navUserRole == "Admin")
                    {
                        <a class="px-4 py-3 text-sm font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors flex items-center gap-2" 
                           asp-area="" asp-controller="Admin" asp-action="Dashboard">
                            <span class="material-symbols-outlined text-[18px]">admin_panel_settings</span>
                            Admin Panel
                        </a>
                    }
                    @if (navUserRole == "Doctor")
                    {
                        <a class="px-4 py-3 text-sm font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors flex items-center gap-2" 
                           asp-area="" asp-controller="Doctor" asp-action="Dashboard">
                            <span class="material-symbols-outlined text-[18px]">medical_services</span>
                            Doctor Panel
                        </a>
                    }

                    <hr class="my-2 border-slate-200 dark:border-slate-700" />

                    @if (!isLoggedIn)
                    {
                        <a asp-area="" asp-controller="Account" asp-action="Login" 
                           class="px-4 py-3 text-sm font-bold text-center bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors no-underline">
                            Login
                        </a>
                        <a asp-area="" asp-controller="Account" asp-action="Register" 
                           class="px-4 py-3 text-sm font-bold text-center bg-primary/10 text-primary rounded-lg hover:bg-primary/20 transition-colors no-underline">
                            Sign Up
                        </a>
                    }
                    else
                    {
                        <a asp-area="" asp-controller="Account" asp-action="Profile" class="flex items-center gap-2 px-4 py-3 text-sm font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors no-underline">
                            <span class="material-symbols-outlined text-[18px]">person</span>
                            My Profile
                        </a>
                        @if (userRole == "Patient")
                        {
                            <a asp-area="" asp-controller="Appointment" asp-action="MyAppointments" class="flex items-center gap-2 px-4 py-3 text-sm font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors no-underline">
                                <span class="material-symbols-outlined text-[18px]">calendar_month</span>
                                My Appointments
                            </a>
                        }
                        <a asp-area="" asp-controller="Account" asp-action="Settings" class="flex items-center gap-2 px-4 py-3 text-sm font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors no-underline">
                            <span class="material-symbols-outlined text-[18px]">settings</span>
                            Settings
                        </a>
                        <a asp-area="" asp-controller="Account" asp-action="Logout" class="flex items-center gap-2 px-4 py-3 text-sm font-semibold text-red-600 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors no-underline">
                            <span class="material-symbols-outlined text-[18px]">logout</span>
                            Logout
                        </a>
                    }
                </nav>
            </div>

            <!-- Main Content -->
            <main class="flex-1 w-full max-w-[1200px] mx-auto flex flex-col pt-8 pb-16">
                @RenderBody()
            </main>

            <!-- Footer -->
            <footer class="mt-auto border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 pt-16 pb-8 px-6 sm:px-10 lg:px-20">
                <div class="max-w-[1200px] mx-auto">
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
                        <!-- Column 1: Brand -->
                        <div class="flex flex-col gap-6">
                            <div class="flex items-center gap-3 text-primary">
                                <svg class="h-8 w-8" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 2c-1.657 0-3 1.343-3 3v2H7a3 3 0 0 0-3 3v7a5 5 0 0 0 5 5h6a5 5 0 0 0 5-5v-7a3 3 0 0 0-3-3h-2V5c0-1.657-1.343-3-3-3Zm1 5V5a1 1 0 1 0-2 0v2h2Zm-1 5a1 1 0 0 1 1 1v2h2a1 1 0 1 1 0 2h-2v2a1 1 0 1 1-2 0v-2H9a1 1 0 1 1 0-2h2v-2a1 1 0 0 1 1-1Z"/>
                                </svg>
                                <span class="text-2xl font-bold tracking-tight text-slate-900 dark:text-slate-100">MediClinic</span>
                            </div>
                            <p class="text-slate-600 dark:text-slate-400 leading-relaxed text-sm">
                                Providing world-class healthcare with a personal touch. Our dedicated team of professionals is here to ensure you and your family receive the best medical care possible.
                            </p>
                            <div class="flex items-center gap-4">
                                <a href="#" class="w-9 h-9 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-600 dark:text-slate-400 hover:bg-primary hover:text-white transition-all duration-300">
                                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953h-1.513c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                                </a>
                                <a href="#" class="w-9 h-9 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-600 dark:text-slate-400 hover:bg-blue-400 hover:text-white transition-all duration-300">
                                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.84 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
                                </a>
                                <a href="#" class="w-9 h-9 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-600 dark:text-slate-400 hover:bg-pink-600 hover:text-white transition-all duration-300">
                                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.584.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                                </a>
                            </div>
                        </div>

                        <!-- Column 2: Quick Links -->
                        <div class="flex flex-col gap-6">
                            <h3 class="text-sm font-bold uppercase tracking-wider text-slate-900 dark:text-slate-100">Quick Links</h3>
                            <ul class="flex flex-col gap-3">
                                <li><a asp-controller="Home" asp-action="Index" class="text-sm text-slate-600 dark:text-slate-400 hover:text-primary transition-colors no-underline">Home</a></li>
